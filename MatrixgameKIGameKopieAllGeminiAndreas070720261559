class Node1D:
    """ Repräsentiert einen Knoten in einem eindimensionalen binären Suchbaum """
    def __init__(self, atom, coordinate_value):
        self.atom = atom
        self.val = coordinate_value
        self.left = None
        self.right = None

def insert_1d_tree(root, atom, val):
    """ Fügt ein Atom basierend auf seinem Koordinatenwert in den Baum ein """
    if root is None:
        return Node1D(atom, val)
    if val < root.val:
        root.left = insert_1d_tree(root.left, atom, val)
    else:
        root.right = insert_1d_tree(root.right, atom, val)
    return root

def range_query_1d(root, low, high, result_list):
    """ Gibt alle Atome zurück, deren Koordinate im Intervall [low, high] liegt """
    if root is None:
        return
    if root.val > low:
        range_query_1d(root.left, low, high, result_list)
    if low <= root.val <= high:
        result_list.append(root.atom)
    if root.val < high:
        range_query_1d(root.right, low, high, result_list)


class SpatialBinaryTreeFilter:
    def __init__(self):
        self.tree_x = None
        self.tree_y = None
        self.tree_z = None

    def rebuild_trees(self, all_atoms):
        """ Reinitialisiert die Bäume in jedem Zeitschritt neu """
        self.tree_x = None
        self.tree_y = None
        self.tree_z = None
        for atom in all_atoms:
            self.tree_x = insert_1d_tree(self.tree_x, atom, atom.pos[0])
            self.tree_y = insert_1d_tree(self.tree_y, atom, atom.pos[1])
            self.tree_z = insert_1d_tree(self.tree_z, atom, atom.pos[2])

    def find_neighbors_within_radius(self, target_atom, r_max):
        """ 
        Nutzt die 3 Binärbäume, um potenzielle Bindungspartner 
        ohne O(N^2)-Vergleiche zu isolieren.
        """
        candidates_x = []
        candidates_y = []
        candidates_z = []

        # 1. Eindimensionale Bereichsabfragen in O(log N)
        range_query_1d(self.tree_x, target_atom.pos[0] - r_max, target_atom.pos[0] + r_max, candidates_x)
        range_query_1d(self.tree_y, target_atom.pos[1] - r_max, target_atom.pos[1] + r_max, candidates_y)
        range_query_1d(self.tree_z, target_atom.pos[2] - r_max, target_atom.pos[2] + r_max, candidates_z)

        # 2. Schnittmengenbildung (Nur Atome, die in allen 3 Dimensionen nah genug sind)
        intersected_candidates = set(candidates_x) & set(candidates_y) & set(candidates_z)
        
        # Das Ziel-Atom selbst aus der Liste entfernen
        intersected_candidates.discard(target_atom)
        
        return intersected_candidates

