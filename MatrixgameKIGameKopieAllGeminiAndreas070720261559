        """
        # Bereinigung der geschweiften Klammern
        clean_data = raw_string.strip("{}").split("; ")
        
        z = int(clean_data[0])
        symbol = clean_data[1]
        name = clean_data[2]
        density = float(clean_data[3])
        element_type = clean_data[4]
        config = clean_data[5].strip("{}")
        
