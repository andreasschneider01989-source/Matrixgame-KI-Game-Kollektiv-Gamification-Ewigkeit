import copy

class TimeNode:
    """ Repräsentiert einen historischen Zustandspunkt im 4. Binärbaum """
    def __init__(self, timestamp, atom_snapshots, molecule_edges_snapshot):
        self.t = timestamp                     # Nicht-relative Zeitachse in Sekunden
        self.atom_snapshots = atom_snapshots   # Tiefenkopie der atomaren Zustände
        self.edges_snapshot = molecule_edges_snapshot # Zustand des Bindungsnetzwerks
        self.left = None
        self.right = None

def insert_time_snapshot(root, timestamp, atoms, edges):
    """ Fügt einen neuen Systemzustand chronologisch in den Zeitbaum ein """
    if root is None:
        # Erstelle eine isolierte Momentaufnahme der aktuellen Daten
        return TimeNode(timestamp, copy.deepcopy(atoms), copy.deepcopy(edges))
    
    if timestamp < root.t:
        root.left = insert_time_snapshot(root.left, timestamp, atoms, edges)
    else:
        root.right = insert_time_snapshot(root.right, timestamp, atoms, edges)
    return root

def find_closest_past_state(root, target_t):
    """ 
    Sucht den Zustand, der dem gewünschten Zielzeitpunkt am nächsten kommt,
    ohne ihn zu überschreiten (kausales Limes-Kriterium).
    """
    if root is None:
        return None
    
    if root.t == target_t:
        return root
    
    if target_t < root.t:
        return find_closest_past_state(root.left, target_t)
    
    # Wenn das Ziel größer ist, könnte dieser Knoten richtig sein, 
    # es sei denn, im rechten Teilbaum gibt es eine noch bessere Annäherung.
    right_candidate = find_closest_past_state(root.right, target_t)
    if right_candidate is not None and right_candidate.t <= target_t:
        return right_candidate
    return root


