            return [0.0, 0.0, 0.0]
            
        force_magnitude = G * (body_a.mass * body_b.mass) / distance_squared
        
        return [
            force_magnitude * (dx / distance),
            force_magnitude * (dy / distance),
            force_magnitude * (dz / distance)
        ]

