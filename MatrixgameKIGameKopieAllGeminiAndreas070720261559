    def calculate_inverse_square_force(self, body_a, body_b):
        """
        Berechnet die Kraftwirkung basierend auf Formelsammlung 1.2
        """
        G = self.constants["G"].value
        dx = body_b.pos[0] - body_a.pos[0]
        dy = body_b.pos[1] - body_a.pos[1]
        dz = body_b.pos[2] - body_a.pos[2]
        
        distance_squared = dx**2 + dy**2 + dz**2
        distance = math.sqrt(distance_squared)
        
        # Guardian-Schutz vor unquantifizierten Singularitäten (lim r -> 0)
        l_planck = 1.616e-35
