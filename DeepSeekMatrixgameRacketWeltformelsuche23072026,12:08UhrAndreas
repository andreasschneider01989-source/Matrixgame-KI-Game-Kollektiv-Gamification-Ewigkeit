## 3. Kinematik-Berechnungen

```racket
;; ============================================================
;; KINEMATIK-FUNKTIONEN
;; ============================================================

;; Weg-Zeit-Gesetz: s = 0.5 * a * t²
(define (weg a t)
  (* 0.5 a (sqr t)))

;; Geschwindigkeit bei gleichmäßiger Beschleunigung
(define (geschwindigkeit-nach-zeit a t v0)
  (+ v0 (* a t)))

;; Beschleunigung aus Weg und Zeit
(define (beschleunigung-aus-weg-zeit s t)
  (/ (* 2 s) (sqr t)))

;; Zeit aus Weg und Beschleunigung
(define (zeit-aus-weg-beschleunigung s a)
  (if (zero? a)
      (error "Beschleunigung darf nicht Null sein!")
      (sqrt (/ (* 2 s) a))))

;; ============================================================
;; ENERGIEFUNKTIONEN
;; ============================================================

;; Kinetische Energie: E = 0.5 * m * v²
(define (kinetische-energie masse vx vy vz)
  (* 0.5 masse (+ (sqr vx) (sqr vy) (sqr vz))))

;; Potentielle Energie: E = m * g * h
(define (potentielle-energie masse g h)
  (* masse g h))

;; Gesamtenergie eines Systems (kinetisch + potentiell)
(define (system-energie körper)
  (let ((v (körper-v körper)))
    (+ (kinetische-energie (körper-masse körper)
                           (geschwindigkeit-vx v)
                           (geschwindigkeit-vy v)
                           (geschwindigkeit-vz v))
       ;; Vereinfachte potentielle Energie
       (* (körper-masse körper) 9.81 (pos-y (körper-pos körper))))))
