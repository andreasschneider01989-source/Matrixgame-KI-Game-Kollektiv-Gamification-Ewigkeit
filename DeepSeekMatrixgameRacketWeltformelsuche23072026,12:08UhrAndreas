## 8. Lumini Strings – Selbstgenerierende Wissensnetzwerke

```racket
;; ============================================================
;; LUMINI STRINGS - SELBSTGENERIERENDE WISSENSNETZWERKE
;; ============================================================

;; Wissensknoten
(struct wissen
  (id
   name
   kategorie     ;; "Axiom" | "Hypothese" | "Formel" | "Berechnung"
   inhalt
   verknüpfungen ;; Liste von IDs
   gewicht       ;; Relevanz/Verifizierungsgrad
   erzeugt-am)
  #:transparent)

;; Wissensnetzwerk
(struct netzwerk
  (knoten
   kanten
   aktivität))  ;; Liste der aktuell aktiven Knoten

;; Neuen Wissensknoten erzeugen
(define (neues-wissen name kategorie inhalt verknüpfungen)
  (wissen (random 1000000)
          name
          kategorie
          inhalt
          verknüpfungen
          1.0
          (current-seconds)))

;; Wissensnetzwerk initialisieren
(define (init-netzwerk)
  (let* ((axiome (list 
                  (neues-wissen "Existenz" "Axiom" "Es existiert eine Form von Existenz" '())
                  (neues-wissen "Veränderung" "Axiom" "Es existiert die Möglichkeit für Veränderung" '(1))
                  (neues-wissen "F=ma" "Axiom" "Kraft = Masse * Beschleunigung" '(1 2))
                  (neues-wissen "Gravitation" "Axiom" "F = G * m1 * m2 / r²" '(3))
                  (neues-wissen "Dreikörperproblem" "Hypothese" "Berechnung von 3 Körpern unter Gravitation" '(4)))))
    (netzwerk axiome '() (map wissen-id axiome))))

;; Neues Wissen aus existierendem ableiten (Lumini-String)
(define (ableiten netz auswahl)
  (match-define (netzwerk knoten kanten aktiv) netz)
  (let* ((neues (neues-wissen 
                 (string-append "Abgeleitet von " (wissen-name auswahl))
                 "Hypothese"
                 (string-append "Neue Erkenntnis aus: " (wissen-inhalt auswahl))
                 (list (wissen-id auswahl))))
         (neue-knoten (cons neues knoten)))
    (netzwerk neue-knoten 
              (cons (list (wissen-id auswahl) (wissen-id neues) "ableitung") kanten)
              (cons (wissen-id neues) aktiv))))

;; Wissensnetzwerk exportieren
(define (netzwerk→string netz)
  (match-define (netzwerk knoten kanten aktiv) netz)
  (string-append 
   "Wissensnetzwerk\n"
   "================\n"
   "Knoten: " (number->string (length knoten)) "\n"
   "Kanten: " (number->string (length kanten)) "\n"
   "Aktiv: " (number->string (length aktiv)) "\n\n"
   (apply string-append 
          (map (lambda (k)
                 (string-append "  [" (number->string (wissen-id k)) "] "
                                (wissen-name k) " (" (wissen-kategorie k) ")\n"
                                "    → " (wissen-inhalt k) "\n"))
               knoten))))

;; ============================================================
;; KOMPLETTES SYSTEM STARTEN
;; ============================================================

(define (start-full-system)
  (printf "\n========================================\n")
  (printf "  MATRIXGAME + LUMINI STRINGS\n")
  (printf "  Vollständiges System\n")
  (printf "========================================\n\n")
  
  (start-matrixgame)
  (newline)
  (start-ki-game)
  (newline)
  
  (printf "Starte Wissensnetzwerk...\n")
  (let ((netz (init-netzwerk)))
    (printf (netzwerk→string netz))
    (printf "\nLeite neues Wissen ab...\n")
    (let ((neues-netz (ableiten netz (car (netzwerk-knoten netz)))))
      (printf (netzwerk→string neues-netz)))))

;; ============================================================
;; AUSFÜHRUNG
;; ============================================================

(start-full-system)
