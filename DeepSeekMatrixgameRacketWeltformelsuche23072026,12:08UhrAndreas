## 2. Körper- und Positionssystem

```racket
;; ============================================================
;; KÖRPER-SYSTEM FÜR DAS MATRIXGAME
;; ============================================================

(struct position (x y z) #:transparent)
(struct geschwindigkeit (vx vy vz) #:transparent)
(struct beschleunigung (ax ay az) #:transparent)

;; Körper-Struktur
(struct körper
  (name
   masse          ;; in kg
   pos            ;; position
   v              ;; geschwindigkeit
   a              ;; beschleunigung
   kraft          ;; wirkende Kraft
   radius         ;; für Kollisionen
   farbe)         ;; für Visualisierung
  #:transparent)

;; Körper-Konstruktor
(define (make-körper name masse x y z vx vy vz radius farbe)
  (körper name 
          (masse masse)
          (position x y z)
          (geschwindigkeit vx vy vz)
          (beschleunigung 0 0 0)
          (kraft 0 0 0)
          radius
          farbe))

;; Sonne (Referenzkörper)
(define (make-sonne x y z)
  (make-körper "Sonne" 1.989e30 x y z 0 0 0 10 "yellow"))

;; Planet
(define (make-planet name masse x y z vx vy vz radius farbe)
  (make-körper name masse x y z vx vy vz radius farbe))

;; ============================================================
;; PHYSIK-ENGINE
;; ============================================================

;; Berechnung der Gravitationskraft zwischen zwei Körpern
(define (gravitationskraft-zwischen k1 k2)
  (let* ((dx (- (pos-x (körper-pos k2)) (pos-x (körper-pos k1))))
         (dy (- (pos-y (körper-pos k2)) (pos-y (körper-pos k1))))
         (dz (- (pos-z (körper-pos k2)) (pos-z (körper-pos k1))))
         (r (sqrt (+ (sqr dx) (sqr dy) (sqr dz))))
         (r2 (sqr r)))
    (if (zero? r2)
        (values 0 0 0)
        (let ((F (* G (/ (* (körper-masse k1) (körper-masse k2)) r2))))
          (values (/ (* F dx) r)
                  (/ (* F dy) r)
                  (/ (* F dz) r))))))

;; Berechnung aller Kräfte auf einen Körper
(define (berechne-kräfte körper liste)
  (let loop ((rest liste) (fx 0) (fy 0) (fz 0))
    (if (null? rest)
        (values fx fy fz)
        (let* ((other (car rest))
               (dx (- (pos-x (körper-pos other)) (pos-x (körper-pos körper))))
               (dy (- (pos-y (körper-pos other)) (pos-y (körper-pos körper))))
               (dz (- (pos-z (körper-pos other)) (pos-z (körper-pos körper))))
               (r (sqrt (+ (sqr dx) (sqr dy) (sqr dz)))))
          (if (or (zero? r) (eq? körper other))
              (loop (cdr rest) fx fy fz)
              (let ((F (* G (/ (* (körper-masse körper) (körper-masse other)) (sqr r)))))
                (loop (cdr rest)
                      (+ fx (/ (* F dx) r))
                      (+ fy (/ (* F dy) r))
                      (+ fz (/ (* F dz) r)))))))))

;; Schrittweises Update der Physik (Euler-Verfahren)
(define (update-körper körper dt)
  (let* ((ax (/ (kraft-x (körper-kraft körper)) (körper-masse körper)))
         (ay (/ (kraft-y (körper-kraft körper)) (körper-masse körper)))
         (az (/ (kraft-z (körper-kraft körper)) (körper-masse körper)))
         (vx (+ (geschwindigkeit-vx (körper-v körper)) (* ax dt)))
         (vy (+ (geschwindigkeit-vy (körper-v körper)) (* ay dt)))
         (vz (+ (geschwindigkeit-vz (körper-v körper)) (* az dt))))
    (körper (körper-name körper)
            (körper-masse körper)
            (position (+ (pos-x (körper-pos körper)) (* vx dt))
                      (+ (pos-y (körper-pos körper)) (* vy dt))
                      (+ (pos-z (körper-pos körper)) (* vz dt)))
            (geschwindigkeit vx vy vz)
            (beschleunigung ax ay az)
            (kraft 0 0 0)
            (körper-radius körper)
            (körper-farbe körper))))
