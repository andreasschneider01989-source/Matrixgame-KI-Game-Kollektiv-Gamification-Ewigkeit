## 5. Visualisierung (SVG-Export)

```racket
;; ============================================================
;; VISUALISIERUNGS-MODUL
;; ============================================================

(define (körper→svg k)
  (let* ((x (pos-x (körper-pos k)))
         (y (pos-y (körper-pos k)))
         (r (körper-radius k))
         (farbe (körper-farbe k)))
    (string-append
     "<circle cx=\"" (number->string x) "\" cy=\"" (number->string y) "\" r=\"" (number->string r) "\" fill=\"" farbe "\" />\n"
     "<text x=\"" (number->string (+ x r 5)) "\" y=\"" (number->string y) "\" font-size=\"12\">" (körper-name k) "</text>")))

(define (simulation→svg sim)
  (let* ((körper (simulation-körperliste sim))
         (svg (string-append 
               "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n"
               "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"800\" height=\"600\" viewBox=\"-500 -500 1000 1000\">\n"
               "<rect width=\"800\" height=\"600\" fill=\"black\"/>\n")))
    (foldl (lambda (k acc) (string-append acc (körper→svg k) "\n")) svg körper)
    (string-append svg "</svg>")))

;; Export nach Datei
(define (export-svg sim filename)
  (let ((svg (simulation→svg sim)))
    (with-output-to-file filename
      (lambda () (display svg))
      #:exists 'replace)))
