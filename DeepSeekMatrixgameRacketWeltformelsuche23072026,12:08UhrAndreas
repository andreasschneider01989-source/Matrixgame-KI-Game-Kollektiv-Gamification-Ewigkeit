## 7. Erweiterte Hypothese: Polarität (Elektromagnetismus)

```racket
;; ============================================================
;; ERWEITERUNG: POLARITÄT / ELEKTROMAGNETISMUS
;; ============================================================

;; Zusätzliches Axiom: Ladung
(struct ladung (wert) #:transparent)

;; Coulomb-Gesetz
(define k_e 8.9875e9)

(define (coulomb-kraft q1 q2 r)
  (if (zero? r)
      (error "Abstand darf nicht Null sein!")
      (* k_e (/ (* q1 q2) (sqr r)))))

;; Geladener Körper
(struct geladener-körper
  (name
   masse
   ladung
   pos
   v
   a
   kraft
   radius
   farbe)
  #:transparent)

;; Kraftberechnung inkl. elektromagnetischer Wechselwirkung
(define (gesamtkraft k1 k2)
  (let* ((dx (- (pos-x (geladener-körper-pos k2)) (pos-x (geladener-körper-pos k1))))
         (dy (- (pos-y (geladener-körper-pos k2)) (pos-y (geladener-körper-pos k1))))
         (dz (- (pos-z (geladener-körper-pos k2)) (pos-z (geladener-körper-pos k1))))
         (r (sqrt (+ (sqr dx) (sqr dy) (sqr dz)))))
    (if (zero? r)
        (values 0 0 0)
        (let* ((F_grav (* G (/ (* (geladener-körper-masse k1) (geladener-körper-masse k2)) (sqr r))))
               (F_coul (* k_e (/ (* (geladener-körper-ladung k1) (geladener-körper-ladung k2)) (sqr r))))
               (F_ges (+ F_grav F_coul)))
          (values (/ (* F_ges dx) r)
                  (/ (* F_ges dy) r)
                  (/ (* F_ges dz) r))))))
