## 4. Simulation und Gamification

```racket
;; ============================================================
;; SIMULATIONS-ENGINE FÜR DAS MATRIXGAME
;; ============================================================

;; Simulations-Status
(struct simulation
  (körperliste
   dt              ;; Zeitschritt
   aktuelle-zeit
   laufend
   schritte))

;; Initialisierung einer Simulation
(define (init-simulation körperliste dt)
  (simulation körperliste dt 0 #t 0))

;; Ein Simulationsschritt
(define (simulations-schritt sim)
  (match-define (simulation körper dt zeit laufend schritte) sim)
  (if (not laufend)
      sim
      (let* ((aktualisierte-körper
              (map (lambda (k)
                     (let-values (((fx fy fz) (berechne-kräfte k körper)))
                       (update-körper 
                        (körper (körper-name k)
                                (körper-masse k)
                                (körper-pos k)
                                (körper-v k)
                                (körper-a k)
                                (kraft fx fy fz)
                                (körper-radius k)
                                (körper-farbe k))
                        dt)))
                   körper)))
        (simulation aktualisierte-körper 
                    dt 
                    (+ zeit dt) 
                    laufend 
                    (+ schritte 1)))))

;; Simulation über n Schritte ausführen
(define (simuliere sim n)
  (let loop ((s sim) (i 0))
    (if (>= i n)
        s
        (loop (simulations-schritt s) (+ i 1)))))

