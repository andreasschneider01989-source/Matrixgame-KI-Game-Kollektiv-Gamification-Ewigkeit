;; INPUT → OPERATION → OUTPUT MODELL
;; ============================================================

;; Generisches OIO-Modell
(struct oio
  (input      ;; Messergebnisse oder Sinneswahrnehmung
   operation  ;; Entscheidungsfindung / Informationsverarbeitung
   output))   ;; Ausgabe / Aktion

;; MinMax-Operation für Spielzüge
(define (minmax-operation bewertungsfunktion züge tiefe)
  (lambda (input)
    (let ((zug (argmax (lambda (zug)
                         (bewertungsfunktion zug tiefe))
                       züge)))
      (oio input "MinMax" zug))))

;; NMaxMax-Operation
(define (nmaxmax-operation bewertungsfunktion züge n tiefe)
  (lambda (input)
    (let ((zug (argmax (lambda (zug)
                         (bewertungsfunktion zug tiefe))
                       (take (sort züge > #:key (lambda (z) (bewertungsfunktion z tiefe)))
                             n))))
      (oio input "NMaxMax" zug))))

;; LLM-Operation (vereinfacht)
(define (llm-operation prompt)
  (lambda (input)
    (oio input "LLM" (string-append "Antwort auf: " prompt))))

;; Neuronales Netz Operation (vereinfacht)
(define (neural-operation input)
  (oio input "NeuralNet" (map (lambda (x) (* x (random))) input)))

;; ============================================================
;; SPIELMECHANIK FÜR DAS MATRIXGAME
;; ============================================================

;; Spiel-Status
(struct spiel
  (simulation
   spieler
   ki-spieler
   züge
   punktestand))

;; Bewegung eines Körpers durch einen Spieler
(define (spieler-bewegung spiel körper-id neue-position)
  (match-define (spiel sim spieler ki züge punkte) spiel)
  (let* ((körper (list-ref (simulation-körperliste sim) körper-id))
         (neuer-körper (körper (körper-name körper)
                               (körper-masse körper)
                               neue-position
                               (körper-v körper)
                               (körper-a körper)
                               (körper-kraft körper)
                               (körper-radius körper)
                               (körper-farbe körper)))
         (neue-liste (list-set (simulation-körperliste sim) körper-id neuer-körper))
         (neue-sim (simulation neue-liste
                               (simulation-dt sim)
                               (simulation-aktuelle-zeit sim)
                               (simulation-laufend sim)
                               (simulation-schritte sim))))
    (spiel neue-sim spieler ki (cons (list "Bewegung" körper-id neue-position) züge) punkte)))
