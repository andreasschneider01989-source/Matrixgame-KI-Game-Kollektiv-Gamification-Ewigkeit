import math
from typing import List, Tuple, Optional


class BoardState:
    """Repräsentiert den diskreten Zustand s im Matrixgame-Zustandsraum S."""

    def __init__(self, board: Optional[List[List[int]]] = None, turn: int = 1):
        # 1: Spieler 1 (X), -1: Spieler -1 (O), 0: Leer
        self.board = board if board is not None else [[0] * 3 for _ in range(3)]
        self.turn = turn

    def get_valid_actions(self) -> List[Tuple[int, int]]:
        """Gibt die Menge der erlaubten Aktionen A(s) zurück."""
        return [(r, c) for r in range(3) for c in range(3) if self.board[r][c] == 0]

    def apply_action(self, action: Tuple[int, int]) -> 'BoardState':
        """Wendet Aktion a auf Zustand s an und erzeugt den Folgezustand s'."""
        r, c = action
        new_board = [row[:] for row in self.board]
        new_board[r][c] = self.turn
        return BoardState(new_board, turn=-self.turn)

    def check_winner(self) -> Optional[int]:
        """Prüft die Abbruchbedingung und gibt den Belohnungswert R(s) zurück."""
        # Zeilen und Spalten
        for i in range(3):
            if abs(sum(self.board[i])) == 3:
                return self.board[i][0]
            if abs(sum(self.board[r][i] for r in range(3))) == 3:
                return self.board[0][i]

        # Diagonale 1 und 2
        if abs(self.board[0][0] + self.board[1][1] + self.board[2][2]) == 3:
            return self.board[1][1]
        if abs(self.board[0][2] + self.board[1][1] + self.board[2][0]) == 3:
            return self.board[1][1]

        # Unentschieden (Keine Aktionen mehr möglich)
        if not self.get_valid_actions():
            return 0

        # Spiel noch nicht beendet
        return None

    def is_terminal(self) -> bool:
        return self.check_winner() is not None

    def display(self) -> None:
        """Visualisiert den aktuellen Zustand im Terminal."""
        symbols = {1: 'X', -1: 'O', 0: '.'}
        for row in self.board:
            print(" ".join(symbols[val] for val in row))
        print()


class DecisionEngine:
    """Berechnet den optimalen Zug a* auf Basis der exakten Baumbewertung."""

    def evaluate(self, state: BoardState) -> Tuple[int, Optional[Tuple[int, int]]]:
        """Rekursive Evaluierung des Minimax-Werts V(s)."""
        winner = state.check_winner()
        if winner is not None:
            return winner, None

        if state.turn == 1:
            best_value = -math.inf
            best_action = None
            for action in state.get_valid_actions():
                next_state = state.apply_action(action)
                value, _ = self.evaluate(next_state)
                if value > best_value:
                    best_value = value
                    best_action = action
            return int(best_value), best_action
        else:
            best_value = math.inf
            best_action = None
            for action in state.get_valid_actions():
                next_state = state.apply_action(action)
                value, _ = self.evaluate(next_state)
                if value < best_value:
                    best_value = value
                    best_action = action
            return int(best_value), best_action


if __name__ == "__main__":
    # Testläufe und Verifikation der Entscheidungslogik
    engine = DecisionEngine()
    
    # Beispielzustand: Spieler 1 (X) steht vor einem erzwungenen Gewinnzug
    custom_board = [
        [1,  1, 0],
        [-1, -1, 0],
        [0,  0, 0]
    ]
    state = BoardState(board=custom_board, turn=1)
    
    print("--- Startzustand s ---")
    state.display()
    
    value, optimal_action = engine.evaluate(state)
    print(f"Berechneter Wert V(s): {value}")
    print(f"Optimaler Zug a*: {optimal_action}")
    
    # Zug ausführen
    next_state = state.apply_action(optimal_action)
    print("\n--- Folgezustand s' nach Zug a* ---")
    next_state.display()

