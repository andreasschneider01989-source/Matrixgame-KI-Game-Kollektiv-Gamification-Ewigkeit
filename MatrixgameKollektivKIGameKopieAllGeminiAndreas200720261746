package ordner1;

import java.util.ArrayList;
import java.util.List;

public class MoveGenerator {

    /**
     * Generiert den diskreten Aktionsraum für eine gegebene Einheit im aktuellen Zustand.
     */
    public static List<Action> generateLegalActions(Unit unit, GameState state) {
        List<Action> actions = new ArrayList<>();
        
        if (unit.leben <= 0) return actions;

        // 1. Interaktionen (Angriffe) kompilieren
        for (Unit other : state.getUnitList()) {
            if (other.team != unit.team && unit.getDistance(other) <= unit.distance) {
                actions.add(new Action(Action.Type.ATTACK, unit, other));
            }
        }

        // 2. Bewegungsmöglichkeiten diskretisieren (Beispiel: 8 Richtungsvektoren)
        double[][] directions = {
            {1, 0}, {0, 1}, {-1, 0}, {0, -1},
            {0.707, 0.707}, {-0.707, 0.707}, {-0.707, -0.707}, {0.707, -0.707}
        };

        for (double[] dir : directions) {
            double nextX = unit.posX + dir[0] * unit.speed;
            double nextY = unit.posY + dir[1] * unit.speed;
            
            // Logische Spielfeldbegrenzung einhalten
            if (nextX >= 0 && nextX <= 1920 && nextY >= 0 && nextY <= 1080) {
                actions.add(new Action(Action.Type.MOVE, unit, nextX, nextY));
            }
        }

        // 3. Passiv-Aktion
        actions.add(new Action(Action.Type.WAIT, unit, unit.posX, unit.posY));

        return actions;
    }
}

