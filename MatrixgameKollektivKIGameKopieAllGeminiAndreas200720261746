private void updateGameState() {
    if (ende) return;
    zeitSchritt++;

    List<Unit> toRemove = new ArrayList<>();
    
    // Phase 1: Strategien anwenden und Geschwindigkeiten berechnen
    for (Unit unit : unitList) {
        unit.updateVelocity(unitList);
    }

    // Phase 2: Interaktionen (Bewegung und Kampf) ausführen
    for (Unit unit : unitList) {
        Unit gegner = unit.nextGegner(unitList);

        if (gegner != null) {
            if (unit.getDistance(gegner) <= unit.distance) {
                gegner.leben -= unit.damage;
                if (gegner.leben <= 0) {
                    toRemove.add(gegner);
                }
            } else {
                unit.move(1); // Nutzt die berechneten vx, vy Werte
            }
        }
    }

    // Phase 3: Sicheres Entfernen toter Einheiten NACH der Schleife
    unitList.removeAll(toRemove);

    // Phase 4: Terminierung prüfen
    long team1Count = unitList.stream().filter(u -> u.team == 1).count();
    long team2Count = unitList.stream().filter(u -> u.team == 2).count();

    if (team1Count == 0 || team2Count == 0) {
        ende = true;
        System.out.println("Spiel beendet nach Sch突きten: " + zeitSchritt);
