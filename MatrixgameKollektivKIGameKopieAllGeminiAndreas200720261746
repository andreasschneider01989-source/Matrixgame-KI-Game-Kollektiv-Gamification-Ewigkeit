package ordner1;

import java.util.ArrayList;
import java.util.List;

public class GameState {
    private final List<Unit> unitList;
    private int zeitSchritt;
    private boolean ende;

    public GameState(List<Unit> units) {
        this.unitList = new ArrayList<>(units);
        this.zeitSchritt = 0;
        this.ende = false;
    }

    // Deep-Copy Konstruktor für MCTS / Suchbäume (Klonen des Zustands)
    public GameState(GameState source) {
        this.unitList = new ArrayList<>();
        for (Unit u : source.unitList) {
            this.unitList.add(new Unit(u)); // Setzt funktionierenden Copy-Konstruktor in Unit voraus
        }
        this.zeitSchritt = source.zeitSchritt;
        this.ende = source.ende;
    }

    public List<Unit> getUnitList() { return unitList; }
    public int getZeitSchritt() { return zeitSchritt; }
    public boolean isEnde() { return ende; }

    /**
     * Reines Anwenden einer Aktion auf den Zustand (Die Transition δ)
     */
    public void applyAction(Action action) {
        if (ende) return;

        switch (action.type) {
            case MOVE:
                action.actor.posX = action.targetX;
                action.actor.posY = action.targetY;
                break;
            case ATTACK:
                if (action.target != null) {
                    action.target.leben -= action.actor.damage;
                }
                break;
            case WAIT:
                // Keine Zustandsänderung für diese Entität
                break;
        }
        
        // Bereinigung toter Entitäten
        unitList.removeIf(u -> u.leben <= 0);
        checkTerminationCriteria();
    }

    private void checkTerminationCriteria() {
        long team1Count = unitList.stream().filter(u -> u.team == 1).count();
        long team2Count = unitList.stream().filter(u -> u.team == 2).count();

        if (team1Count == 0 || team2Count == 0) {
            ende = true;
        }
        zeitSchritt++;
    }
}

