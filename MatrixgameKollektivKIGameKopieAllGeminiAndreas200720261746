package ordner1;
import java.util.List;

public class Unit extends KreisObjekt {
    // ... bestehende Variablen ...
    
    private DecisionStrategy strategy;

    public void setStrategy(DecisionStrategy strategy) {
        this.strategy = strategy;
    }

    public void updateVelocity(List<Unit> allUnits) {
        if (this.strategy != null) {
            double[] targetVector = this.strategy.calculateMovement(this, allUnits);
            this.vx = targetVector[0];
            this.vy = targetVector[1];
        } else {
            // Fallback auf deinen Standard-Reaktiv-Ansatz
            Unit gegner = nextGegner(allUnits);
            if (gegner != null) {
                moveTo(gegner);
            }
        }
    }
    
    // Korrigierte Next-Gegner Logik
    public Unit nextGegner(List<Unit> allUnits) {
        Unit besterGegner = null;
        double minDistance = Double.MAX_VALUE;
        for (Unit unit : allUnits) {
            if (unit.team != this.team && unit.leben > 0) {
                double dist = getDistance(unit);
                if (dist < minDistance) {
                    minDistance = dist;
                    besterGegner = unit;
                }
            }
        }
        return besterGegner;
    }
}

