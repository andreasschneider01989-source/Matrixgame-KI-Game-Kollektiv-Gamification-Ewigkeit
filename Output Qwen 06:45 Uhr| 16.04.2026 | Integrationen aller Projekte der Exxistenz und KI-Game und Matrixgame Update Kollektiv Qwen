package matrixgame.physics;

public class PeriodicTableCore {
    // Elektronenschalen als Basis für Unit-Attributes
    public static class Element {
        int atomicNumber;      // Ordnungszahl → Unit-Level
        String symbol;         // Element-Symbol → Unit-Typ
        int[] electronShells;  // Schalen → HP/Attack/Defense
        
        public Element(int number, String sym, int[] shells) {
            this.atomicNumber = number;
            this.symbol = sym;
            this.electronShells = shells;
        }
        
        // Elektronenkonfiguration → Unit-Stats
        public int calculateHP() {
            return electronShells[0] * 10; // K-Schale → Basis-HP
