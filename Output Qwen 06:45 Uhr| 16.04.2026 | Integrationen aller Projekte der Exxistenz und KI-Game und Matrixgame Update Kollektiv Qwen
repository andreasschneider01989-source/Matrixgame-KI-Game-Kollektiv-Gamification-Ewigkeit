package matrixgame.combat;

import matrixgame.physics.PeriodicTableCore.Element;

public class UnitFightEngine_v31 {
    
    public static class BattleUnit {
        Element element;
        String team;
        int hp;
        int attack;
        int defense;
        int positionX;
        int positionY;
        
        public BattleUnit(Element elem, String team, int x, int y) {
            this.element = elem;
            this.team = team;
            this.hp = elem.calculateHP();
            this.attack = elem.calculateAttack();
            this.defense = elem.electronShells[1] * 3; // L-Schale → Defense
            this.positionX = x;
            this.positionY = y;
        }
        
        // Kampf-Berechnung mit Elektronenkonfiguration
        public int calculateDamage(BattleUnit target) {
            // Valenzelektronen (äußere Schale) bestimmen Crit-Chance
            int valenceElectrons = element.electronShells[element.electronShells.length - 1];
            double critChance = valenceElectrons * 0.05; // Max 40% bei 8 Elektronen
            
            double baseDamage = this.attack * 1.5 - target.defense * 0.5;
            
            if (Math.random() < critChance) {
                System.out.println("⚡ KRITISCHER TREFFER! (Element: " + element.symbol + ")");
                return (int)(baseDamage * 2.0);
            }
            
            return (int)baseDamage;
        }
    }
    
    // Simulation: Germanium (Ge) vs. Selen (Se)
    public static void main(String[] args) {
        Element germanium = new Element(32, "Ge", new int[]{2, 8, 18, 4});
        Element selenium = new Element(34, "Se", new int[]{2, 8, 18, 6});
        
        BattleUnit unit1 = new BattleUnit(germanium, "black", 3, 3);
        BattleUnit unit2 = new BattleUnit(selenium, "white", 4, 4);
        
        System.out.println("⚔️ KAMPF BEGINNT:");
        System.out.println("Schwarz: " + unit1.element.symbol + " (HP: " + unit1.hp + ")");
        System.out.println("Weiß: " + unit2.element.symbol + " (HP: " + unit2.hp + ")");
        
        int damage = unit1.calculateDamage(unit2);
        System.out.println("💥 Schaden: " + damage);
    }
}
