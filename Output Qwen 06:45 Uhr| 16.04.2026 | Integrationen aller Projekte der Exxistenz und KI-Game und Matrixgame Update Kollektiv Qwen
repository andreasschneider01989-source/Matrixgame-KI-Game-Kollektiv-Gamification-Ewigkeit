// SpielDerEwigkeit_Physics_v31.java
package matrixgame.eternity;

import matrixgame.physics.PeriodicTableCore.Element;

public class SpielDerEwigkeit_Physics_v31 {
    
    public static class CelestialBody {
        Element composition; // Hauptelement des Himmelskörpers
        double mass;         // Masse in kg
        double x, y, z;      // 3D-Position
        double vx, vy, vz;   // Geschwindigkeit
        double radius;       // Radius in Metern
        
        public CelestialBody(Element elem, double mass, double x, double y, double z) {
            this.composition = elem;
            this.mass = mass;
            this.x = x;
            this.y = y;
            this.z = z;
            this.vx = 0;
            this.vy = 0;
            this.vz = 0;
            this.radius = calculateRadius(mass, elem);
        }
        
        private double calculateRadius(double mass, Element elem) {
            // Dichte basierend auf Element (g/cm³)
            double density = getDensity(elem);
            // Radius = (3M/4πρ)^(1/3)
            return Math.pow((3 * mass) / (4 * Math.PI * density), 1.0/3.0);
        }
        
        private double getDensity(Element elem) {
            // Beispiel-Dichten (kg/m³)
            switch (elem.symbol) {
                case "H": return 70;      // Wasserstoff (Sonne)
                case "Fe": return 7874;   // Eisen (Erdkern)
                case "Si": return 2330;   // Silizium (Erdmantel)
                case "Ge": return 5323;   // Germanium
                default: return 3000;     // Durchschnitt
            }
        }
    }
    
    // N-Body-Simulation mit Element-basierten Himmelskörpern
    public static void simulateGravity(List<CelestialBody> bodies, double deltaTime) {
        for (CelestialBody body : bodies) {
            for (CelestialBody other : bodies) {
                if (body != other) {
                    applyGravity(body, other, deltaTime);
                }
            }
        }
    }
    
    private static void applyGravity(CelestialBody body, CelestialBody other, double dt) {
        double dx = other.x - body.x;
        double dy = other.y - body.y;
        double dz = other.z - body.z;
        double distance = Math.sqrt(dx*dx + dy*dy + dz*dz);
        
        double force = (6.674e-11 * body.mass * other.mass) / (distance * distance);
        
        double ax = (force * dx / distance) / body.mass;
        double ay = (force * dy / distance) / body.mass;
        double az = (force * dz / distance) / body.mass;
        
        body.vx += ax * dt;
        body.vy += ay * dt;
        body.vz += az * dt;
        
        body.x += body.vx * dt;
        body.y += body.vy * dt;
        body.z += body.vz * dt;
    }
}
