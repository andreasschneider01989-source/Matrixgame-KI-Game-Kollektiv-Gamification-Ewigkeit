### 7.2 Core Java-Implementierung: Unit-Aktions-Kopplung

Der folgende optimierte und streng typisierte Java-Code demonstriert die Vektor-Berechnung von Einheiten-Interaktionen innerhalb des Simulators:

java
package com.matrixgame.engine.simulation;

import java.util.List;

/**
 * Repräsentiert eine funktionale Entität innerhalb des Kausalitätssimulators.
 * Fokus: Rigide Vektoraktualisierung und mathematische Präzision.
 */
public class SimulationUnit {
    private String unitId;
    private double posX, posY, posZ;
    private double vx, vy, vz;
    private double health, maxHealth;
    private double baseDamage;
    private double operationalRange;
    private double movementSpeed;

    public SimulationUnit(String unitId, double x, double y, double z, double health, double damage, double range, double speed) {
        this.unitId = unitId;
        this.posX = x;
        this.posY = y;
        this.posZ = z;
        this.health = health;
        this.maxHealth = health;
        this.baseDamage = damage;
        this.operationalRange = range;
        this.movementSpeed = speed;
    }

    public double calculateDistance(SimulationUnit target) {
        double dx = this.posX - target.posX;
        double dy = this.posY - target.posY;
        double dz = this.posZ - target.posZ;
        return Math.sqrt(dx * dx + dy * dy + dz * dz);
    }

    public void executeTacticalStep(List<SimulationUnit> opponents) {
        if (opponents == null || opponents.isEmpty()) return;

        // Target Acquisition: Suche die nächstgelegene feindliche Entität
        SimulationUnit closestTarget = null;
        double minDistance = Double.MAX_VALUE;

        for (SimulationUnit opponent : opponents) {
            double dist = calculateDistance(opponent);
            if (dist < minDistance) {
                minDistance = dist;
                closestTarget = opponent;
            }
        }

        if (closestTarget == null) return;

        // Kausale Verzweigung: Angriff oder translationale Bewegung
        if (minDistance <= this.operationalRange) {
            executeAttack(closestTarget);
        } else {
            moveTowardsTarget(closestTarget, minDistance);
        }
    }

    private void moveTowardsTarget(SimulationUnit target, double currentDistance) {
        if (currentDistance == 0) return;

        double dx = target.posX - this.posX;
        double dy = target.posY - this.posY;
        double dz = target.posZ - this.posZ;

        // Vektor-Normierung und Skalierung mit der Bewegungsgeschwindigkeit
        double step = Math.min(this.movementSpeed, currentDistance - this.operationalRange);
        
        this.vx = (dx / currentDistance) * step;
        this.vy = (dy / currentDistance) * step;
        this.vz = (dz / currentDistance) * step;

        this.posX += this.vx;
        this.posY += this.vy;
        this.posZ += this.vz;
    }

    private void executeAttack(SimulationUnit target) {
        target.applyDamage(this.baseDamage);
    }

    public synchronized void applyDamage(double damage) {
        this.health -= damage;
        if (this.health < 0) {
            this.health = 0;
        }
    }

    public boolean isOperational() {
        return this.health > 0;
    }
}



