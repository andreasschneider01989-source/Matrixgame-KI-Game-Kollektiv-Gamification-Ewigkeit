### 2. Python-Code für Google Colab zur automatischen Generierung


Du kannst diesen Code nutzen, um beliebige Listen von Wikipedia-Begriffen oder Portalen automatisch in diese Struktur zu verwandeln. Das Skript bereinigt die Namen und fügt die korrekten deutschsprachigen Wikipedia-Links hinzu.


```python
def generate_wiki_structure(data):
    base_url = "https://de.wikipedia.org/wiki/"
    
    print("--- Matrixgame Wikipedia-Struktur ---\n")
    
    for category, topics in data.items():
        print(f"**{category}**")
        for topic in topics:
            # Erzeugt den Wikipedia-Slug (Leerzeichen zu Unterstrich)
            wiki_slug = topic.replace(" ", "_")
            url = f"{base_url}{wiki_slug}"
            
            print(f"* {topic}")
            print(f"  {url}")
        print() # Leerzeile zwischen Kategorien


# Deine Daten aus dem Dokument (erweiterbar)
wiki_game_data = {
    "Geowissenschaften & Biologie": [
        "Portal:Geowissenschaften", 
        "Portal:Biologie", 
        "Portal:Schmetterlinge", 
        "Portal:Vögel"
    ],
    "Sozialwissenschaften": [
        "Portal:Soziologie", 
        "Portal:Psychologie", 
        "Portal:Pädagogik",
        "Marxismus"
    ],
    "Technik & Wissenschaft": [
        "Portal:Informatik", 
        "Portal:Maschinenbau", 
        "Portal:Elektrotechnik",
        "Klimawandel"
    ]
}


generate_wiki_structure(wiki_game_data)


```


