                ax[i] = ay[i] =  az[i] = 0;
                if (!bi.movable) continue;
                for (int j = 0; j < n; j++) {
                    if (i == j) continue;
                    MasseKugel bj = bodies.get(j);
                    double dx = bj.x - bi.x;
                    double dy = bj.y - bi.y;
                    double dz = bj.z - bi.z;
                    double r2 = dx*dx + dy*dy + dz*dz;
                    double r = Math.sqrt(r2);
                    double a = G * bj.mass / r2;
                    ax[i] += a * dx / r;
                    ay[i] += a * dy / r;
                    az[i] += a * dz / r;
                }
