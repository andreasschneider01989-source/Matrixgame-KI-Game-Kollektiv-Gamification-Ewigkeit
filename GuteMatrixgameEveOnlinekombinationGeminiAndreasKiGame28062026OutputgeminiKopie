## 2. Objektorientierter, kompilierbarer Code (Java)

Hier ist die strikte, modulare Software-Architektur. Sie implementiert das **Composite-Pattern**, um die von dir beschriebene unendliche Schachtelung (Teilchen $\rightarrow$ Atom $\rightarrow$ Molekül $\rightarrow$ Schiff $\rightarrow$ Planet) mathematisch sauber abzubilden.

```java
import java.util.ArrayList;
import java.util.List;

// Fundamentales Interface für alles, was Masse und Position im Raum besitzt
interface WeltraumObjekt {
    double getMasse();
    Vector3D getPosition();
    Vector3D getGeschwindigkeit();
    void bewege(double dt);
}

// Hilfsklasse für dreidimensionale Vektoren (Position, Geschwindigkeit, Kräfte)
class Vector3D {
    public double x, y, z;

    public Vector3D(double x, double y, double z) {
        this.x = x;
        this.y = y;
        this.z = z;
    }

    public Vector3D plus(Vector3D other) {
        return new Vector3D(this.x + other.x, this.y + other.y, this.z + other.z);
    }

    public Vector3D mal(double skalar) {
        return new Vector3D(this.x * skalar, this.y * skalar, this.z * skalar);
    }
}

// Ein elementares Basisteilchen (z.B. Proton, Neutron, Elektron) ohne Unterkomponenten
class ElementarTeilchen implements WeltraumObjekt {
    private final String name;
    private final double masse;
    private Vector3D position;
    private Vector3D geschwindigkeit;

    public ElementarTeilchen(String name, double masse, Vector3D pos, Vector3D vel) {
        this.name = name;
        this.masse = masse;
        this.position = pos;
        this.geschwindigkeit = vel;
    }

    @Override public double getMasse() { return this.masse; }
    @Override public Vector3D getPosition() { return this.position; }
    @Override public Vector3D getGeschwindigkeit() { return this.geschwindigkeit; }
    
    @Override 
    public void bewege(double dt) {
        this.position = this.position.plus(this.geschwindigkeit.mal(dt));
    }
}

// Das Composite-Objekt: Kann Atome, Moleküle, Raumschiffe oder Planeten darstellen
class ZusammengesetztesObjekt implements WeltraumObjekt {
    private final String name;
    private final List<WeltraumObjekt> komponenten = new ArrayList<>();
    private Vector3D geschwindigkeit;

    public ZusammengesetztesObjekt(String name, Vector3D startGeschwindigkeit) {
        this.name = name;
        this.geschwindigkeit = startGeschwindigkeit;
    }

    public void addKomponente(WeltraumObjekt obj) {
        komponenten.add(obj);
    }

    // Validierung: Die Gesamtmasse ist exakt die Summe aller Teilmassen
    @Override
    public double getMasse() {
        return komponenten.stream().mapToDouble(WeltraumObjekt::getMasse).sum();
    }

    // Berechnung des Masseschwerpunkts im Raum
    @Override
    public Vector3D getPosition() {
        double gesamtMasse = getMasse();
        if (gesamtMasse == 0) return new Vector3D(0, 0, 0);

        double weightedX = 0, weightedY = 0, weightedZ = 0;
        for (WeltraumObjekt k : komponenten) {
            Vector3D pos = k.getPosition();
            double m = k.getMasse();
            weightedX += pos.x * m;
            weightedY += pos.y * m;
            weightedZ += pos.z * m;
        }
        return new Vector3D(weightedX / gesamtMasse, weightedY / gesamtMasse, weightedZ / gesamtMasse);
    }

    @Override
    public Vector3D getGeschwindigkeit() { return this.geschwindigkeit; }

    @Override
    public void bewege(double dt) {
        // Jede Teilkomponente aktualisiert ihre relative oder absolute Position
        for (WeltraumObjekt k : komponenten) {
            k.bewege(dt);
        }
    }
    
    public String getStrukturDetails() {
        return String.format("Objekt: %s | Gesamtmasse: %s kg | Schwerpunkt: [%.2f, %.2f, %.2f]", 
            name, getMasse(), getPosition().x, getPosition().y, getPosition().z);
    }
}

```

