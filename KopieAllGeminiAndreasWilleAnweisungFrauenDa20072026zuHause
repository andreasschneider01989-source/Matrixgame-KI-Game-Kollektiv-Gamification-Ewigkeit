    public double calculateEpistemicUCB(double cPuct, double cEpistemic, double flowResistance) {
        if (this.visits == 0) return Double.MAX_VALUE;

        int parentVisits = (this.parent != null) ? this.parent.visits : 1;

        // 1. Standard-Exploitation & Exploration
        double exploitation = this.valueSum / this.visits;
        double exploration = cPuct * Math.sqrt(Math.log(parentVisits) / this.visits);

        // 2. Epistemischer Bonus (Kompensation von rho / Angst-Widerstand)
        // Belohnt Pfade, die die stochastische Sicherheit maximieren
        double epistemicBonus = cEpistemic * (this.palConfidence * (1.0 - flowResistance));

        return exploitation + exploration + epistemicBonus;
    }

