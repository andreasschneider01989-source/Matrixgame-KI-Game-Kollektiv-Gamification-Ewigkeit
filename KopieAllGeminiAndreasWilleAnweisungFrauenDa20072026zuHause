import java.util.ArrayList;
import java.util.List;

public class CollectiveConsensusManager {
    private final List<AgentNode> activeAgents;
    private final double structuralUncertainty;
    private static final double CRITICAL_DIVERGENCE = 0.35;

    public CollectiveConsensusManager(double structuralUncertainty) {
        this.activeAgents = new ArrayList<>();
        this.structuralUncertainty = structuralUncertainty;
    }

    public void registerAgent(AgentNode agent) {
        if (agent != null && agent.isValidated()) {
            this.activeAgents.add(agent);
        }
    }

    public double calculateGlobalConsensus() {
        double weightedStateSum = 0.0;
        double totalWeight = 0.0;

        for (AgentNode agent : activeAgents) {
            weightedStateSum += agent.getPalWeight() * agent.getCurrentStateValue();
            totalWeight += agent.getPalWeight();
        }

        if (totalWeight == 0.0) return 0.0;

        double rawConsensus = weightedStateSum / totalWeight;
        return rawConsensus * (1.0 - structuralUncertainty);
    }

    public void verifySystemStability() {
        double globalConsensus = calculateGlobalConsensus();
        for (AgentNode agent : activeAgents) {
            double divergence = Math.abs(agent.getCurrentStateValue() - globalConsensus);
            if (divergence > CRITICAL_DIVERGENCE) {
                System.out.println("⚠️ [GUARDIAN] Kritische Divergenz an Knoten " + agent.getId() + " detektiert! Initiiere lokalen Reset.");
                agent.triggerOriginReset();
            }
        }
    }
}

