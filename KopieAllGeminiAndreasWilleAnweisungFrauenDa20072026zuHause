     * Berechnet das UCB-Gewicht unter Einbezug der Retter-Perspektive.
     */
    public double calculateEpistemicUCB(double cPuct, double cEpistemic, double flowResistance) {
        if (this.visits == 0) {
            return Double.MAX_VALUE;
        }

        int parentVisits = (this.parent != null) ? this.parent.visits : 1;
        
        double exploitation = this.valueSum / this.visits;
        double exploration = cPuct * Math.sqrt(Math.log(parentVisits) / this.visits);
        
        // Epistemischer Bonusfaktor zur Reduktion des Perfektionismus-Widerstands (rho)
        double epistemicBonus = cEpistemic * (this.palConfidence * (1.0 - flowResistance));

        return exploitation + exploration + epistemicBonus;
    }

    /**
     * Führt die Backpropagation des modifizierten z_matrix Loss durch.
     */
    public void backpropagateMatrixLoss(double deltaPal, double flowResistance, boolean contradiction) {
        this.visits++;
        
        double beta = 0.3;
        double gamma = 1.0;
        double contradictionPenalty = contradiction ? 1.0 : 0.0;
        
        // Berechnung des Netto-Erkenntnisgewinns
        double zMatrix = deltaPal + beta * (1.0 - flowResistance) - gamma * contradictionPenalty;
        
        this.valueSum += zMatrix;
        this.palConfidence = Math.min(1.0, Math.max(0.0, this.palConfidence + deltaPal));

        if (this.parent != null) {
            this.parent.backpropagateMatrixLoss(deltaPal, flowResistance, contradiction);
        }
    }

    public MatrixSystemState getState() { return state; }
    public List<EpistemicMCTSNode> getChildren() { return children; }
