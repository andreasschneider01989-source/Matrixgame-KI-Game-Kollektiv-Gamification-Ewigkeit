    private void moveTo(BioEntity self, BioEntity target, double speed) {
        double dx = target.x - self.x;
        double dy = target.y - self.y;
        double length = Math.sqrt(dx*dx + dy*dy);
        if (length > 0) { self.vx = (dx/length) * speed; self.vy = (dy/length) * speed; }
    }

