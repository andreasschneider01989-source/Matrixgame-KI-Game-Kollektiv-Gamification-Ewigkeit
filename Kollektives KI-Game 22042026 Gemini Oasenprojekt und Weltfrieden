package matrixgame;

import javax.swing.*;
import java.awt.*;
import java.awt.event.ActionEvent;
import java.awt.event.ActionListener;
import java.util.ArrayList;
import java.util.Iterator;
import java.util.List;
import java.util.Random;

/**
 * Matrixgame v50.0 - Immune System Simulation
 * Fokus: Logische Strukturierung der zellulären Abwehr.
 * Didaktik: Visualisierung von Entropie vs. Ordnung.
 */
public class MatrixgameImmuneSystemv50 extends JPanel implements ActionListener {

    private static final int WIDTH = 1200;
    private static final int HEIGHT = 800;
    private Timer timer;
    private List<Entity> entities;
    private Random rand = new Random();

    // Statistiken für die Prognose
    private int pathogenCount = 0;
    private int immuneCellCount = 0;
    private double survivalProbability = 1.0;

    public MatrixgameImmuneSystemv50() {
        setPreferredSize(new Dimension(WIDTH, HEIGHT));
        setBackground(new Color(5, 10, 15));
        entities = new ArrayList<>();
        initializeSystem();
        timer = new Timer(30, this);
        timer.start();
    }

    private void initializeSystem() {
        // Initialer Befall
        for (int i = 0; i < 15; i++) {
            entities.add(new Entity(rand.nextInt(WIDTH), rand.nextInt(HEIGHT), "PATHOGEN"));
        }
        // Wächter-Einheiten (Innate)
        for (int i = 0; i < 5; i++) {
            entities.add(new Entity(rand.nextInt(WIDTH), rand.nextInt(HEIGHT), "GUARDIAN"));
        }
    }

    @Override
    protected void paintComponent(Graphics g) {
        super.paintComponent(g);
        Graphics2D g2 = (Graphics2D) g;
        g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);

        for (Entity e : entities) {
            e.draw(g2);
        }

        drawOverlay(g2);
    }

    private void drawOverlay(Graphics2D g2) {
        g2.setColor(Color.WHITE);
        g2.setFont(new Font("Monospaced", Font.BOLD, 14));
        g2.drawString("MATRIXGAME IMMUNE_OS v50.0", 20, 30);
        g2.drawString("SURVIVAL PROBABILITY: " + String.format("%.2f", survivalProbability * 100) + "%", 20, 50);
        g2.drawString("PATHOGEN LOAD: " + pathogenCount, 20, 70);
    }

    @Override
    public void actionPerformed(ActionEvent e) {
        updateLogic();
        repaint();
    }

    private void updateLogic() {
        pathogenCount = 0;
        immuneCellCount = 0;

        List<Entity> nextGeneration = new ArrayList<>();
        Iterator<Entity> it = entities.iterator();

        while (it.hasNext()) {
            Entity current = it.next();
            current.move();

            if (current.type.equals("PATHOGEN")) {
                pathogenCount++;
                if (rand.nextDouble() < 0.005) { // Mutation / Replikation
                    nextGeneration.add(new Entity(current.x, current.y, "PATHOGEN"));
                }
            } else {
                immuneCellCount++;
                // Suche und Zerstöre
                for (Entity other : entities) {
                    if (other.type.equals("PATHOGEN") && current.distanceTo(other) < 30) {
                        other.isDead = true;
                    }
                }
            }
        }

        entities.removeIf(en -> en.isDead);
        entities.addAll(nextGeneration);

        // Prognose-Berechnung (Vereinfachtes Modell)
        survivalProbability = Math.max(0, 1.0 - (double) pathogenCount / 200.0);
        
        // Log für Eclipse
        if (System.currentTimeMillis() % 1000 < 35) {
            System.out.println("[COMPILER_OUTPUT] Pathogens: " + pathogenCount + 
                               " | Guardians: " + immuneCellCount + 
                               " | Probability: " + String.format("%.4f", survivalProbability));
        }
    }

    class Entity {
        double x, y, vx, vy;
        String type;
        boolean isDead = false;

        Entity(double x, double y, String type) {
            this.x = x; this.y = y; this.type = type;
            this.vx = (rand.nextDouble() - 0.5) * 4;
            this.vy = (rand.nextDouble() - 0.5) * 4;
        }

        void move() {
            x += vx; y += vy;
            if (x < 0 || x > WIDTH) vx *= -1;
            if (y < 0 || y > HEIGHT) vy *= -1;
        }

        double distanceTo(Entity other) {
            return Math.sqrt(Math.pow(x - other.x, 2) + Math.pow(y - other.y, 2));
        }

        void draw(Graphics2D g2) {
            if (type.equals("PATHOGEN")) {
                g2.setColor(new Color(255, 50, 50, 180));
                g2.fillOval((int)x, (int)y, 8, 8);
            } else {
                g2.setColor(new Color(50, 255, 100, 200));
                g2.drawRect((int)x, (int)y, 12, 12);
            }
        }
    }

    public static void main(String[] args) {
        JFrame frame = new JFrame("Matrixgame - Human Immune System Simulation");
        MatrixgameImmuneSystemv50 sim = new MatrixgameImmuneSystemv50();
        frame.add(sim);
        frame.pack();
        frame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        frame.setLocationRelativeTo(null);
        frame.setVisible(true);
    }
}

