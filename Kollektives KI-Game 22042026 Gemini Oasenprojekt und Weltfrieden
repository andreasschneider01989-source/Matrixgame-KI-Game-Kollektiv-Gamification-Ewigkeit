package matrixgame;

import javax.swing.*;
import java.awt.*;
import java.util.ArrayList;
import java.util.Iterator;
import java.util.List;
import java.util.Random;

/**
 * Matrixgame v51.0 - Adaptive Immune System & Pathogen Exponential Growth
 * Fokus: Wahrscheinlichkeitsprognose und System-Stabilität.
 */
public class MatrixgameImmuneEvolutionV51 extends JPanel {

    private final int WIDTH = 1000;
    private final int HEIGHT = 700;
    private List<Cell> population = new ArrayList<>();
    private Random rnd = new Random();
    
    // Simulations-Parameter
    private double infectionRisk = 0.02; // Exponentieller Faktor
    private double adaptiveStrength = 0.05;
    private int tick = 0;

    public MatrixgameImmuneEvolutionV51() {
        setPreferredSize(new Dimension(WIDTH, HEIGHT));
        setBackground(new Color(10, 15, 25));
        
        // Initialer Zustand: Wenige Erreger, ein paar Wächter
        for(int i=0; i<10; i++) population.add(new Cell("PATHOGEN", rnd.nextInt(WIDTH), rnd.nextInt(HEIGHT)));
        for(int i=0; i<5; i++) population.add(new Cell("GUARDIAN", rnd.nextInt(WIDTH), rnd.nextInt(HEIGHT)));
        
        new Timer(40, e -> updateSimulation()).start();
    }

    private void updateSimulation() {
        tick++;
        List<Cell> newBorns = new ArrayList<>();
        int pathogens = 0;
        int guardians = 0;

        Iterator<Cell> it = population.iterator();
        while (it.hasNext()) {
            Cell c = it.next();
            c.update();

            if (c.type.equals("PATHOGEN")) {
                pathogens++;
                // Exponentielles Wachstum: Replikations-Check
                if (rnd.nextDouble() < infectionRisk) {
                    newBorns.add(new Cell("PATHOGEN", c.x, c.y));
                }
            } else {
                guardians++;
                // Suche Ziel
                for (Cell target : population) {
                    if (target.type.equals("PATHOGEN") && c.dist(target) < 25) {
                        target.dead = true;
                        // Lernen: Abwehr wird stärker bei Erfolg
                        if(rnd.nextDouble() < 0.1) adaptiveStrength += 0.0001;
                    }
                }
            }
        }

        population.removeIf(c -> c.dead);
        population.addAll(newBorns);
        
        // Konsolen-Log und Prognose alle 50 Ticks
        if (tick % 50 == 0) {
            double pWin = calculateWinProbability(pathogens, guardians);
            System.out.printf("[LOG_TICK_%d] Erreger: %d | Abwehr: %d | Sieg-Wahrscheinlichkeit: %.2f%%%n", 
                              tick, pathogens, guardians, pWin * 100);
        }
        repaint();
    }

    private double calculateWinProbability(int p, int g) {
        if (p == 0) return 1.0;
        // Logische Formel: Verhältnis von Abwehrkraft zu Entropie-Druck
        double ratio = (double) g * (1 + adaptiveStrength * 10) / (p + 1);
        return Math.min(1.0, ratio);
    }

    @Override
    protected void paintComponent(Graphics g) {
        super.paintComponent(g);
        Graphics2D g2 = (Graphics2D) g;
        g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);

        for (Cell c : population) {
            g2.setColor(c.type.equals("PATHOGEN") ? new Color(220, 40, 40) : new Color(40, 200, 255));
            g2.fillOval((int)c.x, (int)c.y, 8, 8);
            if(c.type.equals("GUARDIAN")) {
                g2.drawOval((int)c.x - 5, (int)c.y - 5, 18, 18); // Scan-Radius visualisieren
            }
        }
        
        // UI Overlay
        g2.setColor(Color.WHITE);
        g2.setFont(new Font("SansSerif", Font.PLAIN, 12));
        g2.drawString("Matrixgame - Bio-Logic Simulator", 20, 30);
    }

    class Cell {
        double x, y, vx, vy;
        String type;
        boolean dead = false;

        Cell(String t, double x, double y) {
            this.type = t; this.x = x; this.y = y;
            this.vx = (rnd.nextDouble() - 0.5) * 5;
            this.vy = (rnd.nextDouble() - 0.5) * 5;
        }

        void update() {
            x += vx; y += vy;
            if (x < 0 || x > WIDTH) vx *= -1;
            if (y < 0 || y > HEIGHT) vy *= -1;
        }

        double dist(Cell o) { return Math.sqrt(Math.pow(x-o.x, 2) + Math.pow(y-o.y, 2)); }
    }

    public static void main(String[] args) {
        JFrame f = new JFrame("Immune Matrix v51");
        f.add(new MatrixgameImmuneEvolutionV51());
        f.pack();
        f.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        f.setLocationRelativeTo(null);
        f.setVisible(true);
    }
}

