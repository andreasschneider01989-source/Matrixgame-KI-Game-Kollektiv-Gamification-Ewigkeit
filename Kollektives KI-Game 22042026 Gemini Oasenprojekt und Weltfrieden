package matrixgame;

import javax.swing.*;
import java.awt.*;
import java.awt.event.*;
import java.util.ArrayList;
import java.util.List;
import java.util.Random;

/**
 * Matrixgame v53.0 - 3D Raumzeit-Raster & Projektion
 * Fokus: Fundamentale Physik, Zentralprojektion, Massepunkte im Raster.
 */
public class Matrixgame3DSpaceV53 extends JPanel implements ActionListener, MouseMotionListener {

    private final int WIDTH = 1200;
    private final int HEIGHT = 800;
    
    // Kamera- und Projektions-Parameter
    private double fov = 500; 
    private double cameraZ = -1000;
    private double angleX = 0;
    private double angleY = 0;

    private List<MassPoint> points = new ArrayList<>();
    private Random rand = new Random();
    private int tick = 0;

    // Maus-Steuerung für Rotation
    private int lastMouseX, lastMouseY;

    public Matrixgame3DSpaceV53() {
        setPreferredSize(new Dimension(WIDTH, HEIGHT));
        setBackground(new Color(5, 5, 10));
        addMouseMotionListener(this);
        
        initialize3DGrid();
        
        Timer timer = new Timer(30, this);
        timer.start();
    }

    private void initialize3DGrid() {
        // Generiere ein logisches 3D-Raster von Massepunkten
        int gridSize = 4;
        int spacing = 200;
        int offset = (gridSize * spacing) / 2;

        for (int x = 0; x < gridSize; x++) {
            for (int y = 0; y < gridSize; y++) {
                for (int z = 0; z < gridSize; z++) {
                    double px = x * spacing - offset;
                    double py = y * spacing - offset;
                    double pz = z * spacing - offset;
                    points.add(new MassPoint(px, py, pz));
                }
            }
        }
    }

    @Override
    public void actionPerformed(ActionEvent e) {
        tick++;
        applyPhysics();
        repaint();
    }

    private void applyPhysics() {
        // Diskrete Zeitschritte: Simulation von minimaler Entropie
        for (MassPoint p : points) {
            // Leichte stochastische Schwankung (Zufall)
            p.x += (rand.nextDouble() - 0.5) * 2;
            p.y += (rand.nextDouble() - 0.5) * 2;
            p.z += (rand.nextDouble() - 0.5) * 2;
            
            // Zentripetale Tendenz (primitive Gravitation zum Ursprung)
            p.x -= p.x * 0.001;
            p.y -= p.y * 0.001;
            p.z -= p.z * 0.001;
        }

        if (tick % 60 == 0) {
            System.out.printf("[RAUMZEIT_TICK_%d] System-Entropie stabilisiert. Berechne Vektoren...%n", tick);
        }
    }

    @Override
    protected void paintComponent(Graphics g) {
        super.paintComponent(g);
        Graphics2D g2 = (Graphics2D) g;
        g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
        g2.translate(WIDTH / 2, HEIGHT / 2); // Ursprung in die Mitte verschieben

        // Verbindungen zeichnen (Drahtgitter)
        g2.setColor(new Color(40, 80, 150, 100));
        for (int i = 0; i < points.size(); i++) {
            for (int j = i + 1; j < points.size(); j++) {
                MassPoint p1 = points.get(i);
                MassPoint p2 = points.get(j);
                // Zeichne Linie nur, wenn sie im logischen Raster benachbart sind
                if (distance3D(p1, p2) < 250) {
                    Point2D proj1 = project(p1);
                    Point2D proj2 = project(p2);
                    if (proj1 != null && proj2 != null) {
                        g2.drawLine((int)proj1.x, (int)proj1.y, (int)proj2.x, (int)proj2.y);
                    }
                }
            }
        }

        // Massepunkte zeichnen
        for (MassPoint p : points) {
            Point2D proj = project(p);
            if (proj != null) {
                // Skalierung basierend auf Z-Tiefe (Perspektive)
                int size = (int) Math.max(2, (fov / (fov + p.rotatedZ(angleX, angleY) - cameraZ)) * 8);
                
                // Farbe basierend auf Z-Tiefe (Tiefenunschärfe)
                int alpha = (int) Math.max(50, Math.min(255, 255 - (p.rotatedZ(angleX, angleY) / 5)));
                g2.setColor(new Color(100, 200, 255, alpha));
                g2.fillOval((int)proj.x - size/2, (int)proj.y - size/2, size, size);
            }
        }
        
        g2.translate(-WIDTH / 2, -HEIGHT / 2); // Reset
        drawOverlay(g2);
    }

    private void drawOverlay(Graphics2D g2) {
        g2.setColor(Color.WHITE);
        g2.setFont(new Font("Monospaced", Font.BOLD, 14));
        g2.drawString("MATRIXGAME 3D-KERNEL V53", 20, 30);
        g2.drawString(String.format("CAMERA: RotX: %.2f | RotY: %.2f", angleX, angleY), 20, 50);
        g2.drawString("Massepunkte: " + points.size(), 20, 70);
    }

    // Mathematische 3D zu 2D Projektion
    private Point2D project(MassPoint p) {
        // Rotation anwenden
        double rotX = p.x * Math.cos(angleY) - p.z * Math.sin(angleY);
        double rotZ = p.x * Math.sin(angleY) + p.z * Math.cos(angleY);
        
        double rotY = p.y * Math.cos(angleX) - rotZ * Math.sin(angleX);
        rotZ = p.y * Math.sin(angleX) + rotZ * Math.cos(angleX);

        // Z-Clipping (Verhindern von Division durch Null oder Punkten hinter der Kamera)
        double zDistance = rotZ - cameraZ;
        if (zDistance <= 0) return null;

        // Projektions-Formel: x_proj = x * (fov / z)
        double xProj = rotX * (fov / zDistance);
        double yProj = rotY * (fov / zDistance);
        
        return new Point2D(xProj, yProj);
    }

    private double distance3D(MassPoint p1, MassPoint p2) {
        return Math.sqrt(Math.pow(p1.x - p2.x, 2) + Math.pow(p1.y - p2.y, 2) + Math.pow(p1.z - p2.z, 2));
    }

    // --- Maus-Steuerung ---
    @Override
    public void mouseDragged(MouseEvent e) {
        int dx = e.getX() - lastMouseX;
        int dy = e.getY() - lastMouseY;
        angleY += dx * 0.01;
        angleX += dy * 0.01;
        lastMouseX = e.getX();
        lastMouseY = e.getY();
    }

    @Override
    public void mouseMoved(MouseEvent e) {
        lastMouseX = e.getX();
        lastMouseY = e.getY();
    }

    // Innere Klassen
    class MassPoint {
        double x, y, z;
        MassPoint(double x, double y, double z) { this.x = x; this.y = y; this.z = z; }
        
        double rotatedZ(double ax, double ay) {
            double rz = x * Math.sin(ay) + z * Math.cos(ay);
            return y * Math.sin(ax) + rz * Math.cos(ax);
        }
    }

    class Point2D {
        double x, y;
        Point2D(double x, double y) { this.x = x; this.y = y; }
    }

    public static void main(String[] args) {
        JFrame frame = new JFrame("Matrixgame - 3D Raumzeit-Raster");
        frame.add(new Matrixgame3DSpaceV53());
        frame.pack();
        frame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        frame.setLocationRelativeTo(null);
        frame.setVisible(true);
    }
}

