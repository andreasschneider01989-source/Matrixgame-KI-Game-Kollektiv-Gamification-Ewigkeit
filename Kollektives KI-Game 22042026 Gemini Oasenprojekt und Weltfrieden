package matrixgame;

import javax.swing.*;
import java.awt.*;
import java.awt.event.ActionEvent;
import java.awt.event.ActionListener;
import java.util.ArrayList;
import java.util.Iterator;
import java.util.List;
import java.util.Random;

/**
 * Matrixgame v52.0 - Full GameLoop & IOO Architecture
 * Fokus: Reinforcement Learning, Symbiose, Input-Operation-Output Zyklus.
 */
public class MatrixgameGameLoopV52 extends JPanel implements ActionListener {

    private static final int WIDTH = 1200;
    private static final int HEIGHT = 800;
    private Timer gameLoop;
    private List<BioEntity> entities = new ArrayList<>();
    private Random rand = new Random();

    // Globale KI-Gewichte (Reinforcement Learning State)
    private double weightAggression = 1.0;
    private double weightSynergy = 1.0;
    private double weightSurvival = 1.0;

    private int tickCount = 0;
    private int successfulKills = 0;
    private int synergeticHeals = 0;

    public MatrixgameGameLoopV52() {
        setPreferredSize(new Dimension(WIDTH, HEIGHT));
        setBackground(new Color(5, 8, 12));
        initMatrix();
        // Der Herzschlag des Systems (GameLoop)
        gameLoop = new Timer(30, this);
        gameLoop.start();
    }

    private void initMatrix() {
        for (int i = 0; i < 20; i++) entities.add(new BioEntity(BioType.PATHOGEN));
        for (int i = 0; i < 15; i++) entities.add(new BioEntity(BioType.SYMBIONT));
        for (int i = 0; i < 8; i++) entities.add(new BioEntity(BioType.GUARDIAN));
    }

    @Override
    public void actionPerformed(ActionEvent e) {
        tickCount++;
        processIOOLoop();
        evaluateGlobalLearning();
        repaint();
    }

    /**
     * CORE ARCHITECTURE: Der IOO-Zyklus (Input -> Operation -> Output)
     */
    private void processIOOLoop() {
        List<BioEntity> newborns = new ArrayList<>();
        Iterator<BioEntity> it = entities.iterator();

        while (it.hasNext()) {
            BioEntity e = it.next();
            
            // 1. INPUT: Umgebung scannen
            BioEntity nearestEnemy = findNearest(e, BioType.PATHOGEN);
            BioEntity nearestAlly = findNearest(e, BioType.SYMBIONT);

            // 2. OPERATION: Entscheidung treffen basierend auf State & Global Weights
            e.vx = (rand.nextDouble() - 0.5) * 2; // Default drift
            e.vy = (rand.nextDouble() - 0.5) * 2;

            if (e.type == BioType.GUARDIAN) {
                e.energy -= 0.1; // Energieverlust über Zeit

                // Prio 1: Survival (Wenn Energie kritisch, suche Symbiont zur Heilung)
                if (e.energy < 40 && nearestAlly != null && weightSurvival > 0.8) {
                    moveTo(e, nearestAlly, 3.0);
                    if (distance(e, nearestAlly) < 15) {
                        e.energy += 50; // Heilung
                        synergeticHeals++;
                    }
                } 
                // Prio 2: Threat (Feindbekämpfung)
                else if (nearestEnemy != null && distance(e, nearestEnemy) < 150 * weightAggression) {
                    moveTo(e, nearestEnemy, 4.0);
                    if (distance(e, nearestEnemy) < 15) {
                        nearestEnemy.hp -= 50;
                        if (nearestEnemy.hp <= 0) successfulKills++;
                    }
                }
            } else if (e.type == BioType.PATHOGEN) {
                // Pathogen Logik: Replikation (Entropie)
                if (rand.nextDouble() < 0.01) newborns.add(new BioEntity(BioType.PATHOGEN));
            }
            
            // 3. OUTPUT: Bewegung und Zustandsaktualisierung anwenden
            e.x += e.vx; e.y += e.vy;
            e.bounceOffWalls();
            
            if (e.hp <= 0 || e.energy <= 0) it.remove();
        }
        entities.addAll(newborns);
    }

    /**
     * VERBESSERUNG (Verzögerte Bewertung): System bewertet sich selbst
     */
    private void evaluateGlobalLearning() {
        if (tickCount % 100 == 0) {
            System.out.println("\n--- [NODE EXECUTION: AI_EVALUATION_TICK_" + tickCount + "] ---");
            
            if (successfulKills > 5) {
                weightAggression += 0.05;
                System.out.println("[LEARN] SUCCESS: MG-PHY-001 (Aggression) -> weight=" + String.format("%.2f", weightAggression));
            } else {
                weightAggression = Math.max(0.5, weightAggression - 0.02);
                System.out.println("[LEARN] FAIL: MG-PHY-001 (Aggression) -> weight=" + String.format("%.2f", weightAggression));
            }

            if (synergeticHeals > 2) {
                weightSynergy += 0.1;
                weightSurvival += 0.05;
                System.out.println("[LEARN] SUCCESS: MG-SYM-001 (Synergy) -> weight=" + String.format("%.2f", weightSynergy));
            }

            successfulKills = 0;
            synergeticHeals = 0;
            
            long pathogenCount = entities.stream().filter(e -> e.type == BioType.PATHOGEN).count();
