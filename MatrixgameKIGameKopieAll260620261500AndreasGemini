    def __init__(self, num_nodes: int):
        self.N = num_nodes
        # Initialisiere das Kollektivfeld (Zustand zwischen 0.0 und 1.0)
        self.collective_field = np.random.uniform(0.4, 0.6, size=(num_nodes,))
