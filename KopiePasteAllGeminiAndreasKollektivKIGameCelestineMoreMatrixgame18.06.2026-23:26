/**
 * Repräsentiert die mathematische Basisstruktur eines Massepunkts (Zelle/Teilchen)
 * innerhalb des kollektiven Simulators unter Berücksichtigung der Naturkonstanten.
 * * Nach Regel 1 (Optimum-Filter): Fokus auf syntaktische Korrektheit und Kompiliersicherheit.
 */
public class MatrixNode {

    // Fundamentale Naturkonstanten (Präzise Festlegung nach Standard-SI-Einheiten)
    public static final double PLANCK_CONSTANT = 6.62607015E-34; // h in J*s
    public static final double ELEMENTARY_CHARGE = 1.602176634E-19; // e in C
    public static final double EPSILON_0 = 8.854187817E-12; // elektrische Feldkonstante in C/(V*m)
    
    // Zustandsparameter des Massepunkts
    private double positionX;
    private double positionY;
    private double lokaleEntropie; // E_lokal
    private boolean istStabil;

    /**
     * Konstruktor initialisiert den Knoten im Zustand der Existenz.
     */
    public MatrixNode(double x, double y, double startEntropie) {
        this.positionX = x;
        this.positionY = y;
        this.lokaleEntropie = startEntropie;
        this.istStabil = true;
    }

    /**
     * Berechnet den Coulomb-Faktor k_C basierend auf den Systemkonstanten.
     * k_C = 1 / (4 * PI * epsilon_0)
     */
    public static double getCoulombConstant() {
        return 1.0 / (4.0 * Math.PI * EPSILON_0);
    }

    /**
     * Wendet den Steuer-Operator an, um die lokale Entropie mathematisch zu senken.
     * Simuliert die Guardian-Filter-Bedingung auf physikalischer Ebene.
     */
    public void anwendenSteuerOperator(double deltaEnergie, double widerstand) {
        // Kausale Berechnung der Entropieveränderung
        if (widerstand >= 0) {
            double dS = (deltaEnergie) / (this.lokaleEntropie + widerstand);
            this.lokaleEntropie += dS;
        }
        
        // Stabilisierungs-Invariante
        if (this.lokaleEntropie < 0) {
            this.lokaleEntropie = 0;
        }
    }

    // Getter und Setter für die fehlerfreie Verknüpfung in Eclipse
    public double getPositionX() { return positionX; }
    public double getPositionY() { return positionY; }
    public double getLokaleEntropie() { return lokaleEntropie; }
    public boolean isIstStabil() { return istStabil; }
    
    public void setPosition(double x, double y) {
        this.positionX = x;
        this.positionY = y;
    }
