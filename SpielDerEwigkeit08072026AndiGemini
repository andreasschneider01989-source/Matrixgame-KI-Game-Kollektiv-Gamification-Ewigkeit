	public void doppelsternBasis() {
		// --- Doppelsternsystem (Zirkumbinäres System) ---
		// Eine Simulation von zwei Sternen, die einander umkreisen (Baryzentrum), 
		// mit inneren Planeten und einem äußeren "Matrix-Wächter"-Planeten.

		double massSternA = 380000;  // Etwas massereicher als unsere Sonne
		double massSternB = 220000;  // Etwas masseärmer (z.B. Roter Zwerg)
		double gesamtMasseSterne = massSternA + massSternB;
		
		double abstandSterne = 80.0; // Distanz der Sterne zueinander

		// 1. Berechnung des gemeinsamen Schwerpunktes (Baryzentrum)
		double rA = abstandSterne * (massSternB / gesamtMasseSterne);
		double rB = abstandSterne * (massSternA / gesamtMasseSterne);

		// 2. Berechnung der Orbitalgeschwindigkeiten der Sterne
		// Basierend auf Newtons Gravitationsgesetz
		double vOrbitalSterne = Math.sqrt(G * gesamtMasseSterne / abstandSterne);
		double vA = vOrbitalSterne * (rA / abstandSterne);
		double vB = vOrbitalSterne * (rB / abstandSterne);

		// --- Himmelskörper definieren ---
		
		// Stern A (Zentrum links)
		MasseKugel sternA = new MasseKugel(-rA, 0, 0, 0, -vA, 0, massSternA, 12, new Color(255, 220, 50));
		
		// Stern B (Zentrum rechts)
		MasseKugel sternB = new MasseKugel(rB, 0, 0, 0, vB, 0, massSternB, 9, new Color(255, 80, 50));

		// Planet 1: Erdähnlicher Planet, der NUR Stern A umkreist
		double distPlanet1 = 12.0; 
		double vPlanet1 = Math.sqrt(G * massSternA / distPlanet1);
		// Geschwindigkeit addiert sich zur Eigenbewegung von Stern A
		MasseKugel planet1 = new MasseKugel(-rA - distPlanet1, 0, 0, 0, -vA - vPlanet1, 0, 1.0, 5, Color.GREEN);

		// Planet 2: Heißer Gasriese, der NUR Stern B umkreist
		double distPlanet2 = 18.0;
		double vPlanet2 = Math.sqrt(G * massSternB / distPlanet2);
		MasseKugel planet2 = new MasseKugel(rB + distPlanet2, 0, 0, 0, vB + vPlanet2, 0, 250.0, 7, new Color(150, 100, 255));

		// Planet 3: Zirkumbinärer Planet (Umkreist BEIDE Sterne weit außen)
		// Masseschwerpunkt für ihn ist näherungsweise die Gesamtmasse beider Sterne
		double distPlanet3 = 250.0;
		double vPlanet3 = Math.sqrt(G * gesamtMasseSterne / distPlanet3);
		MasseKugel planet3 = new MasseKugel(0, distPlanet3, 0, -vPlanet3, 0, 0, 8.5, 6, new Color(100, 255, 200));

		// Alle Körper zur Simulation hinzufügen
		bodies.add(sternA);
		bodies.add(sternB);
		bodies.add(planet1);
		bodies.add(planet2);
		bodies.add(planet3);
	}

