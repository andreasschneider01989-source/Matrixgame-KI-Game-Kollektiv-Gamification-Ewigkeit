	public void elementarBausteinBasis() {
		// --- Der logisch optimale Elementar-Baustein (Das Gravitations-Oktett) ---
		// Repräsentiert die perfekte Symmetrie, die aus unendlicher Entropie-Angleichung entsteht.

		// 1. Das Zentrum (Analogie zum Atomkern oder supermassiven Attraktor)
		double massZentrum = 1000000;
		MasseKugel zentrum = new MasseKugel(0, 0, 0, 0, 0, 0, massZentrum, 18, Color.WHITE);
		bodies.add(zentrum);

		// 2. Die innere Schale (Analogie zum s-Orbital: 2 Massenpunkte)
		// Perfekt ausbalanciert, 180 Grad zueinander versetzt.
		double distInner = 25.0;
		double massInner = 10.0;
		// Bahngeschwindigkeit: v = sqrt(G * M / r)
		double vInner = Math.sqrt(G * massZentrum / distInner);
		
		for (int i = 0; i < 2; i++) {
			double angle = i * Math.PI; // 0 und 180 Grad
			double x = Math.cos(angle) * distInner;
			double y = Math.sin(angle) * distInner;
			double vx = -Math.sin(angle) * vInner;
			double vy = Math.cos(angle) * vInner;
			bodies.add(new MasseKugel(x, y, 0, vx, vy, 0, massInner, 5, new Color(255, 100, 100)));
		}

		// 3. Die äußere Schale (Analogie zu den 6 Entropieverknüpfungen / p-Orbitalen)
		// 6 Massenpunkte bilden ein perfektes Hexagon, das das Zentrum umkreist.
		double distOuter = 70.0;
		double massOuter = 15.0;
		
		// Korrektur der Orbitalgeschwindigkeit durch die Masse der inneren Schale
		// (Die äußeren Planeten spüren die Gravitation des Zentrums PLUS die der inneren Planeten)
		double effektiveZentrumsMasse = massZentrum + (2 * massInner);
		double vOuter = Math.sqrt(G * effektiveZentrumsMasse / distOuter);
		
		for (int i = 0; i < 6; i++) {
			double angle = i * (Math.PI / 3.0); // 60 Grad Abstand (360° / 6)
			double x = Math.cos(angle) * distOuter;
			double y = Math.sin(angle) * distOuter;
			double vx = -Math.sin(angle) * vOuter;
			double vy = Math.cos(angle) * vOuter;
			bodies.add(new MasseKugel(x, y, 0, vx, vy, 0, massOuter, 7, new Color(100, 200, 255)));
		}
	}

