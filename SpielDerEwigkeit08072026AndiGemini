	public void galaktischesZentrumBasis() {
		// --- Das Galaktische Zentrum ---
		// Eine Simulation des supermassereichen Schwarzen Lochs (Sagittarius A*) 
		// und extremen stellaren Orbits. 

		// Skalierte Masse für Sagittarius A* (Real ca. 4 Millionen Sonnenmassen)
		// Die Masse wird hier so skaliert, dass sie in die bestehende G-Konstante 
		// und die Timesteps der Simulation passt, ohne Floating-Point-Overflows zu erzeugen.
		double massSgrA = 1.5e9; 
		
		// Das Schwarze Loch ruht (näherungsweise) im Zentrum
		MasseKugel sgrA = new MasseKugel(0, 0, 0, 0, 0, 0, massSgrA, 15, Color.BLACK);

		// --- S-Sterne (Extrem elliptische Orbits) ---
		// Um elliptische Bahnen zu erzeugen, geben wir den Sternen an ihrem fernsten Punkt (Apoapsis)
		// eine Geschwindigkeit, die deutlich UNTER der perfekten Kreisbahngeschwindigkeit liegt.

		// Stern S2 (ein realer Stern, der Sgr A* umkreist)
		double distS2 = 350.0;
		double vKreisS2 = Math.sqrt(G * massSgrA / distS2);
		double vElliptischS2 = vKreisS2 * 0.45; // Nur 45% Speed -> starke Exzentrizität
		MasseKugel sternS2 = new MasseKugel(-distS2, 0, 0, 0, -vElliptischS2, 0, 250000.0, 9, Color.CYAN);

		// Stern S62 (kommt extrem nah an das Schwarze Loch heran)
		double distS62 = 200.0;
		double vKreisS62 = Math.sqrt(G * massSgrA / distS62);
		double vElliptischS62 = vKreisS62 * 0.30; // Nur 30% Speed -> stürzt fast hinein
		MasseKugel sternS62 = new MasseKugel(0, distS62, 0, -vElliptischS62, 0, 0, 180000.0, 8, Color.MAGENTA);


		// --- Das "Retter-System" (Hypothetische Habitable Randzone) ---
		// Ein stabiles Sternensystem weit genug entfernt vom chaotischen Zentrum, 
		// um intern Leben zu ermöglichen, während es das Zentrum umkreist.
		double distArcheSonne = 1200.0;
		double vArcheSonne = Math.sqrt(G * massSgrA / distArcheSonne);
		MasseKugel archeSonne = new MasseKugel(distArcheSonne, 0, 0, 0, -vArcheSonne, 0, 333030.0, 7, Color.YELLOW);

		// Ein erdähnlicher, habitabler Planet innerhalb dieses rettenden Sternensystems
		double distArchePlanet = 15.0;
		// Die Orbitalgeschwindigkeit des Planeten um seine Sonne
		double vArchePlanet = Math.sqrt(G * archeSonne.mass / distArchePlanet);
		// Der Planet erbt die Bewegungsrichtung der Sonne und addiert seine eigene Orbitalgeschwindigkeit
		MasseKugel archePlanet = new MasseKugel(distArcheSonne + distArchePlanet, 0, 0, 0, -vArcheSonne - vArchePlanet, 0, 1.0, 4, Color.GREEN);

		// Hinzufügen der Objekte zur Render-Engine
		bodies.add(sgrA);
		bodies.add(sternS2);
		bodies.add(sternS62);
		bodies.add(archeSonne);
		bodies.add(archePlanet);
	}

