    <span class="hljs-comment">// Fundamentale Konstanten (SI-definiert)</span>
    <span class="hljs-keyword">public</span> <span class="hljs-keyword">static</span> <span class="hljs-keyword">final</span> <span class="hljs-class"><span class="hljs-keyword">class</span> <span class="hljs-title">Constants</span> </span>{
        <span class="hljs-keyword">public</span> <span class="hljs-keyword">static</span> <span class="hljs-keyword">final</span> BigDecimal C = <span class="hljs-keyword">new</span> BigDecimal(<span class="hljs-string">"299792458"</span>); <span class="hljs-comment">// m/s</span>
        <span class="hljs-keyword">public</span> <span class="hljs-keyword">static</span> <span class="hljs-keyword">final</span> BigDecimal H = <span class="hljs-keyword">new</span> BigDecimal(<span class="hljs-string">"6.62607015E-34"</span>); <span class="hljs-comment">// J·s</span>
        <span class="hljs-keyword">public</span> <span class="hljs-keyword">static</span> <span class="hljs-keyword">final</span> BigDecimal G = <span class="hljs-keyword">new</span> BigDecimal(<span class="hljs-string">"6.67430E-11"</span>); <span class="hljs-comment">// m³/(kg·s²)</span>
        <span class="hljs-keyword">public</span> <span class="hljs-keyword">static</span> <span class="hljs-keyword">final</span> PALMetadata G_PAL = <span class="hljs-keyword">new</span> PALMetadata(<span class="hljs-number">0.99998</span>, <span class="hljs-string">"CODATA 2026"</span>, <span class="hljs-string">"Klassischer Limes"</span>);
    }

    <span class="hljs-comment">// Element-Struktur für die chemische Simulationsebene</span>
    <span class="hljs-keyword">public</span> <span class="hljs-keyword">static</span> <span class="hljs-class"><span class="hljs-keyword">class</span> <span class="hljs-title">Element</span> </span>{
