 */</span>
<span class="hljs-keyword">public</span> <span class="hljs-class"><span class="hljs-keyword">class</span> <span class="hljs-title">MatrixEngine</span> </span>{
    <span class="hljs-keyword">private</span> <span class="hljs-keyword">static</span> <span class="hljs-keyword">final</span> MathContext MC = <span class="hljs-keyword">new</span> MathContext(<span class="hljs-number">64</span>, RoundingMode.HALF_UP);

    <span class="hljs-comment">// PAL-Metadaten Struktur</span>
    <span class="hljs-keyword">public</span> <span class="hljs-keyword">static</span> <span class="hljs-class"><span class="hljs-keyword">class</span> <span class="hljs-title">PALMetadata</span> </span>{
