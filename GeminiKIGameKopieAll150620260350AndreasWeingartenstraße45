         * Schützt vor Singularitäten mittels Planck-Längen-Cutoff (Guardian-Modus).
         */</span>
        <span class="hljs-keyword">public</span> BigDecimal[] calculateForce(MassPoint other, BigDecimal lPlanck) {
            <span class="hljs-keyword">int</span> dims = <span class="hljs-keyword">this</span>.position.length;
            BigDecimal[] force = <span class="hljs-keyword">new</span> BigDecimal[dims];
            BigDecimal deltaSquare = BigDecimal.ZERO;
            BigDecimal[] delta = <span class="hljs-keyword">new</span> BigDecimal[dims];

            <span class="hljs-keyword">for</span> (<span class="hljs-keyword">int</span> i = <span class="hljs-number">0</span>; i &lt; dims; i++) {
                delta[i] = other.position[i].subtract(<span class="hljs-keyword">this</span>.position[i]);
                deltaSquare = deltaSquare.add(delta[i].multiply(delta[i]));
            }

            <span class="hljs-comment">// Guardian-Modus: Modellbruch bei r &lt; l_Planck verhindern</span>
            BigDecimal minDistanceSquare = lPlanck.multiply(lPlanck);
            <span class="hljs-keyword">if</span> (deltaSquare.compareTo(minDistanceSquare) &lt; <span class="hljs-number">0</span>) {
                deltaSquare = minDistanceSquare; <span class="hljs-comment">// Singularitäts-Filter</span>
            }

            BigDecimal distance = deltaSquare.sqrt(MC);
            <span class="hljs-comment">// F = G * (m1 * m2) / r²</span>
            BigDecimal magnitude = Constants.G.multiply(<span class="hljs-keyword">this</span>.mass).multiply(other.mass)
                    .divide(deltaSquare, MC);

            <span class="hljs-keyword">for</span> (<span class="hljs-keyword">int</span> i = <span class="hljs-number">0</span>; i &lt; dims; i++) {
                force[i] = magnitude.multiply(delta[i].divide(distance, MC));
            }
            <span class="hljs-keyword">return</span> force;
        }
    }
}
