# Hilfsfunktion zum Anzeigen einer Matrix aus Farbnamen oder RGB-Tupeln


def zeige_bild(pixelmatrix, zoom=9):


    h = len(pixelmatrix)


    w = len(pixelmatrix[0])


    bild = Image.new("RGB", (w, h))


    pixels = bild.load()


    for y in range(h):


        for x in range(w):


            farbe = pixelmatrix[y][x]


            pixels[x, y] = farbe


    bild = bild.resize((w * zoom, h * zoom), Image.NEAREST)


    display(bild)






# Definition der Grundformen als 3x3-Muster aus "1" (Vordergrund) und "0" (Hintergrund)


formen = {


    "punkt": [


        [0, 0, 0],


        [0, 1, 0],


        [0, 0, 0]


    ],


    "vertikal": [


        [0, 1, 0],


        [0, 1, 0],


        [0, 1, 0]


    ],


    "horizontal": [


        [0, 0, 0],


        [1, 1, 1],


        [0, 0, 0]


    ],


    "plus": [


        [0, 1, 0],


        [1, 1, 1],


        [0, 1, 0]


    ]


}






# Neue Hauptfunktion


def zeige_zeichen(typ, farbe_vordergrund, farbe_hintergrund, zoom=9):


    if typ not in formen:


        raise ValueError(f"Unbekannter Typ '{typ}'. Verfügbare Typen: {list(formen.keys())}")


    muster = formen[typ]


    pixelmatrix = [


        [farbe_vordergrund if zelle == 1 else farbe_hintergrund for zelle in reihe]


        for reihe in muster


    ]


    zeige_bild(pixelmatrix, zoom=zoom)






