public class LuminiFramework {
    private static final Map<String, Double> weltbild = new HashMap<>();

    public static void main(String[] args) {
        String[] inputs = {"a=4", "7=b", "a*b=28", "ab=a*b", "b*a=a*b"};
        boolean[] output = run(inputs);
        System.out.println("Output: " + Arrays.toString(output));
    }

    public static boolean[] run(String[] inputs) {
        weltbild.clear();
        boolean[] output = new boolean[inputs.length];
        for (int i = 0; i < inputs.length; i++) {
            output[i] = process(inputs[i]);
        }
        return output;
    }

    private static boolean process(String input) {
        try {
            String[] parts = input.split("=");
            String left = parts[0].trim();
            String right = parts[1].trim();

            // LOGIK-UPDATE: Wir behandeln die linke Seite als Zuweisung, 
            // wenn sie einen Variablennamen darstellt.
            if (left.matches("[a-zA-Z]+")) {
                double val = evaluate(right);
                if (weltbild.containsKey(left) && Math.abs(weltbild.get(left) - val) > 1e-9) return false;
                weltbild.put(left, val);
                return true;
            }
            
            // Sonst: Mathematische Prüfung
            return Math.abs(evaluate(left) - evaluate(right)) < 1e-9;
        } catch (Exception e) { return false; }
    }

    private static double evaluate(String expression) {
        // Schritt 1: Variablen aus Weltbild ersetzen (außer es ist die Zuweisung selbst)
        for (Map.Entry<String, Double> e : weltbild.entrySet()) {
            expression = expression.replaceAll("\\b" + e.getKey() + "\\b", e.getValue().toString());
        }
        // Schritt 2: Rekursiver Parser
        return new Parser(expression).parse();
    }

    private static class Parser {
        private final String exp;
        private int pos = -1, ch;
        public Parser(String exp) { this.exp = exp; }
        private void nextChar() { ch = (++pos < exp.length()) ? exp.charAt(pos) : -1; }
        private boolean eat(int charToEat) {
            while (ch == ' ') nextChar();
            if (ch == charToEat) { nextChar(); return true; }
            return false;
        }
        public double parse() { nextChar(); return parseExpression(); }
        private double parseExpression() {
            double x = parseTerm();
            for (;;) {
                if (eat('+')) x += parseTerm(); else if (eat('-')) x -= parseTerm(); else return x;
            }
        }
        private double parseTerm() {
            double x = parseFactor();
            for (;;) {
                if (eat('*')) x *= parseFactor(); else if (eat('/')) x /= parseFactor(); else return x;
            }
        }
        private double parseFactor() {
            if (eat('+')) return parseFactor(); if (eat('-')) return -parseFactor();
            double x; int startPos = this.pos;
            if (eat('(')) { x = parseExpression(); eat(')'); }
            else if (ch >= '0' && ch <= '9' || ch == '.') {
                while (ch >= '0' && ch <= '9' || ch == '.') nextChar();
                x = Double.parseDouble(exp.substring(startPos, this.pos));
            } else throw new RuntimeException();
            return x;
        }
    }
