/**
 * MATRIXGAME LUMINI UNIVERSE – CANVAS EDITION MIT VOLLSTÄNDIGEM KONSOLEN-PROTOKOLL
 * 
 * Features:
 * - Echtzeit-Grafik mit Zoom & Pan (Mausrad, WASD/Pfeiltasten)
 * - VOLLSTÄNDIGE Konsolenausgabe aller Ereignisse (für LLM-Analyse & Ewigkeit)
 * - Lumini-Strings für Positionen, Energien, Entropien
 * - Kollektive KI-Kämpfe (Evolution, Angriff, Energieerhaltung)
 * - Gamification: XP, Level, Energiebilanz
 * - Jeder Schritt wird protokolliert → kopierbar, speicherbar, entwickelbar
 * 
 * Steuerung:
 *   WASD / Pfeiltasten  – Bewegen der Kamera
 *   Mausrad            – Zoomen
 *   Mausklick auf Einheit – Verfolgen (Kamera folgt)
 *   Leertaste          – Verfolgung beenden
 *   E                  – Energiebilanz ausgeben (Konsole)
 *   R                  – Reset
 *   P                  – Protokollierung ein-/ausschalten
 * 
 * @author Kollektives Bewusstsein & Andreas Schneider
 * @version 3.0 (2026-04-11) – Ewigkeitssicheres Konsolenprotokoll
 */
public class MatrixGameCanvasUniverseV3 extends JPanel implements ActionListener, KeyListener, MouseWheelListener, MouseListener {

    // ================== KONSTANTEN ==================
    private static final double G = 0.1;              // Gravitations-/Angriffsstärke (entropisch)
    private static final double DT = 0.5;             // Zeitschritt
    private static final int WORLD_SIZE = 20000;      // Größe der Welt (-10000 bis +10000)
    private static final double MIN_DISTANCE = 10.0;
    private static final Random RAND = new Random();
    private static final DateTimeFormatter TIME_FORMATTER = DateTimeFormatter.ofPattern("yyyy-MM-dd HH:mm:ss.SSS");

    // ================== KAMERA & ZOOM ==================
    private double zoom = 1.0;
    private double camX = 0, camY = 0;
    private boolean following = false;
    private Unit followingUnit = null;

    // ================== ENTITÄTEN ==================
    private List<Unit> units = new ArrayList<>();
    private Timer gameLoop;
    private long step = 0;
    private int nextUnitId = 1;

    // ================== GAMIFICATION ==================
    private double xp = 0;
    private int level = 1;
    private boolean showEnergy = true;
    private boolean loggingEnabled = true;
    private Instant sessionStart;

    // ================== KONSTRUKTOR ==================
    public MatrixGameCanvasUniverseV3() {
        setPreferredSize(new Dimension(1200, 800));
        setBackground(Color.BLACK);
        setFocusable(true);
        addKeyListener(this);
        addMouseWheelListener(this);
        addMouseListener(this);

        sessionStart = Instant.now();
        log("🚀", "MATRIXGAME LUMINI UNIVERSE V3 GESTARTET");
        log("📅", "Session: " + TIME_FORMATTER.format(LocalDateTime.now()));
        log("🔢", "Lumini(42) = " + luminiString(42, 2) + " | Lumini(23) = " + luminiString(23, 2));
        log("🧠", "Kollektives Bewusstsein aktiviert – jeder Schritt wird protokolliert für die Ewigkeit.\n");
        
        initUnits();
        
        gameLoop = new Timer(30, this);
        gameLoop.start();
    }

    // ================== LUMINI-STRING (KONSOLE & UI) ==================
    private String luminiString(long n, int basis) {
        if (n < 0) return "-" + luminiString(-n, basis);
        long len = 1, bucket = basis;
        while (n >= bucket) {
            n -= bucket;
            len++;
            bucket *= basis;
        }
        String digits = Long.toString(n, basis);
        while (digits.length() < len) digits = "0" + digits;
        return digits + "(Basis " + basis + ")";
    }

    // ================== KONSOLENPROTOKOLL (EWIGKEITSSICHER) ==================
    private void log(String emoji, String message) {
        if (!loggingEnabled) return;
        String timestamp = TIME_FORMATTER.format(LocalDateTime.now());
        System.out.println(timestamp + " " + emoji + " " + message);
    }

    private void logEvent(String eventType, Unit u, String details) {
        if (!loggingEnabled) return;
        String timestamp = TIME_FORMATTER.format(LocalDateTime.now());
        String luminiPos = luminiString((long)Math.abs(u.x), 2) + "," + luminiString((long)Math.abs(u.y), 2);
        System.out.println(timestamp + " 📍 [" + eventType + "] Unit#" + u.id + " (Team " + u.team + ") | Pos=(" 
            + String.format("%.1f", u.x) + "," + String.format("%.1f", u.y) + ") | LuminiPos=" + luminiPos
            + " | HP=" + String.format("%.1f", u.health) + " | Entropie=" + String.format("%.1f", u.entropy)
            + " | " + details);
    }

    private void logEnergy() {
        if (!loggingEnabled) return;
        double eKin = getTotalKinetic();
        double ePot = getTotalPotential();
        double eTotal = eKin + ePot;
        log("⚡", "Energiebilanz | E_kin=" + String.format("%.3f", eKin) 
            + " | E_pot=" + String.format("%.3f", ePot)
            + " | E_total=" + String.format("%.3f", eTotal)
            + " | Lumini(E_total)=" + luminiString((long)Math.abs(eTotal * 100), 2));
    }

    // ================== INITIALISIERUNG ==================
    private void initUnits() {
        units.clear();
        nextUnitId = 1;
        
        // Sonne (massives Zentrum, unbeweglich)
        Unit sun = new Unit(nextUnitId++, 5000, 0, 0, Color.YELLOW);
        sun.mass = 5000;
        sun.movable = false;
        sun.entropy = 5000;
        sun.maxHealth = sun.health;
        units.add(sun);
        logEvent("SPAWN", sun, "Sonne erschaffen | Masse=" + sun.mass + " | Lumini(Masse)=" + luminiString((long)sun.mass, 2));

        // 20 Kämpfer mit zufälligen Eigenschaften
        for (int i = 0; i < 20; i++) {
            double angle = 2 * Math.PI * RAND.nextDouble();
            double radius = 500 + RAND.nextDouble() * 1500;
            double x = Math.cos(angle) * radius;
            double y = Math.sin(angle) * radius;
            
            Unit u = new Unit(nextUnitId++, 20 + RAND.nextDouble() * 80, x, y, getRandomColor());
            u.team = (int)(RAND.nextDouble() * 3) + 1;
            u.mass = 10 + RAND.nextDouble() * 50;
            u.entropy = 500 + RAND.nextDouble() * 1000;
            u.attack = 5 + RAND.nextDouble() * 15;
            u.speed = 50 + RAND.nextDouble() * 80;
            u.maxHealth = u.health;
            
            // Anfangsgeschwindigkeit für Orbitalbewegung
            double v = Math.sqrt(G * sun.mass / radius) * (0.5 + RAND.nextDouble());
            u.vx = -Math.sin(angle) * v;
            u.vy = Math.cos(angle) * v;
            
            units.add(u);
            logEvent("SPAWN", u, "Kämpfer erschienen | Team=" + u.team + " | Masse=" + String.format("%.1f", u.mass) 
                + " | Attack=" + String.format("%.1f", u.attack) + " | Speed=" + String.format("%.1f", u.speed));
        }
        
        log("📊", "Initialisierung abgeschlossen. " + units.size() + " Einheiten aktiv.");
        logEnergy();
    }

    private Color getRandomColor() {
        return new Color(50 + RAND.nextInt(206), 50 + RAND.nextInt(206), 50 + RAND.nextInt(206));
    }

    // ================== PHYSIK & KI ==================
    private void updateGame() {
        step++;
        if (step % 10 == 0) {
            log("🔄", "--- Simulationsschritt " + step + " ---");
        }
        
        // Beschleunigungen zurücksetzen
        for (Unit u : units) {
            u.ax = u.ay = 0;
        }

        // Kräfte und Angriffe
        List<Unit> toRemove = new ArrayList<>();
        List<Unit> toAdd = new ArrayList<>();
        
        for (int i = 0; i < units.size(); i++) {
            Unit a = units.get(i);
            if (!a.movable) continue;
            
            Unit target = findNearestEnemy(a);
            if (target != null) {
                double dx = target.x - a.x;
                double dy = target.y - a.y;
                double dist = Math.hypot(dx, dy);
                
                // Bewegung
                if (dist > MIN_DISTANCE) {
                    double ax = (dx / dist) * a.speed / a.mass;
                    double ay = (dy / dist) * a.speed / a.mass;
                    a.ax += ax;
                    a.ay += ay;
                    if (step % 10 == 0 && RAND.nextDouble() < 0.3) {
                        logEvent("MOVE", a, "Bewegung zu Unit#" + target.id + " | Distanz=" + String.format("%.1f", dist));
                    }
                }
                
                // Angriff
                if (dist < a.radius + target.radius) {
                    double damage = a.attack * (a.mass / (target.mass + 1));
                    target.health -= damage;
                    a.entropy += 5;
                    
                    logEvent("ATTACK", a, "Angriff auf Unit#" + target.id + " | Schaden=" + String.format("%.1f", damage) 
                        + " | Ziel-HP=" + String.format("%.1f", target.health));
                    
                    if (target.health <= 0) {
                        // Tod
                        a.entropy += target.entropy * 0.3;
                        xp += target.mass * 10;
                        logEvent("DEATH", target, "GETÖTET von Unit#" + a.id + " | Entropie-Transfer=" + String.format("%.1f", target.entropy * 0.3));
                        
                        // Level Up
                        if (xp >= level * 200) {
                            level++;
                            log("🏆", "LEVEL UP! Neues Level: " + level + " | XP=" + (int)xp);
                        }
                        
                        // Reproduktion
                        if (RAND.nextDouble() < 0.15) {
                            Unit child = a.reproduce(nextUnitId++);
                            toAdd.add(child);
                            logEvent("REPRODUCE", a, "Neue Einheit Unit#" + child.id + " (Team " + child.team + ") wurde geboren!");
                        }
                        
                        toRemove.add(target);
                    }
                }
            }
            
            // Entropie-Angleichung (zufällig)
            if (RAND.nextDouble() < 0.05 && units.size() > 1) {
                Unit b = units.get(RAND.nextInt(units.size()));
                if (b != a) {
                    double diff = a.entropy - b.entropy;
                    double transfer = diff * 0.05 * RAND.nextDouble();
                    a.entropy -= transfer;
                    b.entropy += transfer;
                    if (step % 20 == 0) {
                        logEvent("ENTROPY", a, "Entropie-Angleichung mit Unit#" + b.id + " | Transfer=" + String.format("%.2f", transfer));
                    }
                }
            }
        }

        // Entfernen und Hinzufügen
        units.removeAll(toRemove);
        units.addAll(toAdd);
        
        if (toRemove.size() > 0) {
            log("💀", toRemove.size() + " Einheit(en) gestorben. " + units.size() + " verbleibend.");
        }
        if (toAdd.size() > 0) {
            log("🌟", toAdd.size() + " neue Einheit(en) geboren. Gesamt: " + units.size());
        }

        // Kinematik
        for (Unit u : units) {
            u.update();
        }

        // Kamera folgen
        if (following && followingUnit != null && followingUnit.health > 0) {
            camX = -followingUnit.x;
            camY = -followingUnit.y;
        }
        
        // Energie-Log alle 20 Schritte
        if (step % 20 == 0) {
            logEnergy();
        }
    }

    private Unit findNearestEnemy(Unit source) {
        Unit nearest = null;
        double minDist = Double.MAX_VALUE;
        for (Unit other : units) {
            if (other == source) continue;
            if (other.team == source.team) continue;
            double dist = Math.hypot(source.x - other.x, source.y - other.y);
            if (dist < minDist) {
                minDist = dist;
                nearest = other;
            }
        }
        return nearest;
    }

    // ================== ENERGIEBERECHNUNGEN ==================
    private double getTotalKinetic() {
        double sum = 0;
        for (Unit u : units) sum += 0.5 * u.mass * (u.vx*u.vx + u.vy*u.vy);
        return sum;
    }
    
    private double getTotalPotential() {
        double sum = 0;
        for (int i = 0; i < units.size(); i++) {
            for (int j = i+1; j < units.size(); j++) {
                double r = Math.hypot(units.get(i).x - units.get(j).x, units.get(i).y - units.get(j).y);
                if (r > MIN_DISTANCE)
                    sum += -G * units.get(i).mass * units.get(j).mass / r;
            }
        }
        return sum;
    }

