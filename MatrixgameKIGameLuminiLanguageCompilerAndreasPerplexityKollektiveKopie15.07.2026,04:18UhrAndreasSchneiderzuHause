package matrixgame.lumini;

public class LuminiNumber {
    private final int basis;
    private final String digits; // Ziffern 0..basis-1, keine führenden Nullen verloren
    private final long decimalValue; // zugeordneter Index N
    
    public LuminiNumber(long n, int basis) {
        if (basis < 2) throw new IllegalArgumentException("Basis ≥ 2");
        this.basis = basis;
        // Konvertiere n in Lumini-String (längen-erhaltend)
        long remaining = n;
        int len = 1;
        long bucketSize = basis;
        long offset = 0;
        while (remaining >= bucketSize) {
            remaining -= bucketSize;
            len++;
            bucketSize *= basis;
        }
        // remaining ist D (0 .. bucketSize-1)
        String d = Long.toString(remaining, basis);
        while (d.length() < len) d = "0" + d;
        this.digits = d;
        this.decimalValue = n;
    }
    
    public LuminiNumber(String luminiStr, int basis) {
        this.basis = basis;
        this.digits = luminiStr;
        int len = luminiStr.length();
        long offset = 0;
        for (int i = 1; i < len; i++) offset += Math.pow(basis, i);
        long value = Long.parseLong(luminiStr, basis);
        this.decimalValue = offset + value;
    }
    
    public int getBasis() { return basis; }
    public String getDigits() { return digits; }
    public long toDecimal() { return decimalValue; }
    
    // Lumini-Multiplikation: dominantes Vorzeichen
    public static double luminiMul(double a, double b) {
        double abs = Math.abs(a * b);
        return (a < 0 || b < 0) ? -abs : abs;
    }
    
    @Override
    public String toString() { return digits + "(Basis " + basis + ")"; }
}
