        level = 1;
        specialCooldown = 0;
        frameCount = 0;
        running = true;
        following = false;
        zoom = 1.0;
        panX = 0;
        panY = 0;

        // Spieler (blau)
        Body player = new Body(0, 0, 0, 0, 30, 15, Color.BLUE);
        player.name = "Held";
        player.team = 1;
        player.health = 100;
        player.maxHealth = 100;
        bodies.add(player);
        playerUnits.add(player);
        selectedUnit = player;

        // Basis (gold) – jetzt näher
        Body base = new Body(800, 800, 0, 0, 50, 25, new Color(255, 215, 0));
        base.name = "Lumini-Basis";
        base.team = 0;
        base.movable = false;
        bodies.add(base);

        // Kristalle in Reichweite (200–600)
        Random rand = new Random();
        for (int i = 0; i < 8; i++) {
            double angle = 2 * Math.PI * rand.nextDouble();
            double radius = 200 + rand.nextDouble() * 400;
            double x = Math.cos(angle) * radius;
            double y = Math.sin(angle) * radius;
            Body crystal = new Body(x, y, 0, 0, 5, 8, Color.YELLOW);
            crystal.name = "Kristall_" + i;
            crystal.team = 0;
            crystal.isCollectable = true;
            bodies.add(crystal);
        }

        // Feinde (weit weg)
        for (int i = 0; i < 4; i++) {
            double x = (rand.nextDouble() - 0.5) * 3000;
            double y = (rand.nextDouble() - 0.5) * 3000;
            Body enemy = new Body(x, y, 0, 0, 20, 14, Color.RED);
            enemy.name = "Feind_" + i;
            enemy.team = 2;
            enemy.health = 60;
            enemy.maxHealth = 60;
            bodies.add(enemy);
        }
    }

    private void log(String emoji, String msg) {
        System.out.println(TIME_FORMATTER.format(LocalDateTime.now()) + " " + emoji + " " + msg);
    }

    private void logUpdate() {
        System.out.printf("[Frame %d] | Kristalle: %d/%d (getragen %d) | XP: %d Lv.%d | Auswahl: %s%n",
                frameCount, crystalsDelivered, CRYSTALS_NEEDED, crystalsCollected, xp, level,
                selectedUnit != null ? selectedUnit.name : "keine");
    }

    @Override
    public void actionPerformed(ActionEvent e) {
        if (!running || gameWon) {
            repaint();
            return;
        }
        frameCount++;
        updatePhysics();
        updateAI();
        updateQuests();
        if (following && selectedUnit != null) {
            panX = selectedUnit.x;
            panY = selectedUnit.y;
        }
        if (specialCooldown > 0) specialCooldown--;
        logUpdate();
        repaint();
    }

    private void updatePhysics() {
        int n = bodies.size();
        if (n == 0) return;
        double[] ax = new double[n];
        double[] ay = new double[n];
        for (int i = 0; i < n; i++) {
            Body bi = bodies.get(i);
            if (!bi.movable) continue;
            for (int j = i + 1; j < n; j++) {
                Body bj = bodies.get(j);
                double dx = bj.x - bi.x;
                double dy = bj.y - bi.y;
                double distSq = dx * dx + dy * dy;
                double dist = Math.sqrt(distSq);
                if (dist < 5.0) dist = 5.0;
                double force = G * bi.mass * bj.mass / distSq;
                double fx = force * dx / dist;
                double fy = force * dy / dist;
                ax[i] += fx / bi.mass;
                ay[i] += fy / bi.mass;
                ax[j] -= fx / bj.mass;
                ay[j] -= fy / bj.mass;
            }
        }
        for (int i = 0; i < n; i++) {
            Body b = bodies.get(i);
            if (!b.movable) continue;
            b.vx += ax[i] * DT;
            b.vy += ay[i] * DT;
            b.x += b.vx * DT;
            b.y += b.vy * DT;
            b.x = Math.max(-WORLD_SIZE, Math.min(WORLD_SIZE, b.x));
            b.y = Math.max(-WORLD_SIZE, Math.min(WORLD_SIZE, b.y));
        }
    }

    private void updateAI() {
        java.util.List<Body> players = bodies.stream().filter(b -> b.team == 1 && b.health > 0).toList();
        if (players.isEmpty()) return;
        for (Body enemy : bodies) {
            if (enemy.team != 2) continue;
            Body target = findClosest(enemy, players);
            if (target == null) continue;
            double dx = target.x - enemy.x;
            double dy = target.y - enemy.y;
            double dist = Math.hypot(dx, dy);
            if (dist > 0.1) {
                double speed = 30.0 / enemy.mass;
                enemy.vx += (dx / dist) * speed * DT;
                enemy.vy += (dy / dist) * speed * DT;
            }
            for (Body player : players) {
                if (Math.hypot(enemy.x - player.x, enemy.y - player.y) < enemy.radius + player.radius) {
                    player.health -= 0.5;
                    if (player.health <= 0) {
                        log("💀", player.name + " wurde zerstört!");
                        bodies.remove(player);
                        playerUnits.remove(player);
                        if (selectedUnit == player) selectedUnit = playerUnits.isEmpty() ? null : playerUnits.get(0);
                    }
                }
            }
        }
    }

    private Body findClosest(Body from, java.util.List<Body> targets) {
        Body closest = null;
        double bestDist = Double.MAX_VALUE;
        for (Body t : targets) {
            double d = Math.hypot(from.x - t.x, from.y - t.y);
            if (d < bestDist) {
                bestDist = d;
                closest = t;
            }
        }
        return closest;
    }

    private void updateQuests() {
        Iterator<Body> it = bodies.iterator();
        while (it.hasNext()) {
            Body b = it.next();
            if (b.isCollectable && b.team == 0) {
                for (Body player : playerUnits) {
                    if (Math.hypot(player.x - b.x, player.y - b.y) < player.radius + b.radius) {
                        crystalsCollected++;
                        xp += 20;
                        log("💎", player.name + " sammelte " + b.name);
                        it.remove();
                        break;
                    }
                }
            }
        }

        Body base = null;
        for (Body b : bodies) {
            if ("Lumini-Basis".equals(b.name)) {
                base = b;
                break;
            }
        }
        if (base != null && crystalsCollected > 0) {
            for (Body player : playerUnits) {
                if (Math.hypot(player.x - base.x, player.y - base.y) < player.radius + base.radius) {
                    int toDeliver = Math.min(crystalsCollected, 1);
                    crystalsCollected -= toDeliver;
                    crystalsDelivered += toDeliver;
                    xp += 30;
                    log("🏛️", player.name + " lieferte Kristall ab. Abgegeben: " + crystalsDelivered + "/" + CRYSTALS_NEEDED);
                    if (crystalsDelivered >= CRYSTALS_NEEDED && !towerBuilt) {
                        Body tower = new Body(base.x + 80, base.y + 80, 0, 0, 60, 20, new Color(100, 255, 100));
                        tower.name = "Lumini-Turm";
                        tower.team = 1;
                        tower.movable = false;
                        bodies.add(tower);
                        towerBuilt = true;
                        log("🏗️", "TURM GEBaut! +200 XP");
                        xp += 200;
                        if (level >= 3) {
                            gameWon = true;
                            log("🏆🏆🏆", "SIEG!");
                        }
                    }
                    break;
                }
            }
        }

        if (xp >= level * 100) {
            level++;
            log("⭐", "LEVEL UP! Jetzt Level " + level);
            for (Body p : playerUnits) {
                p.maxHealth += 20;
                p.health = p.maxHealth;
            }
        }
    }

    private void moveSelectedUnit(double dx, double dy) {
        if (selectedUnit != null && selectedUnit.movable && selectedUnit.team == 1) {
            selectedUnit.x += dx;
            selectedUnit.y += dy;
            selectedUnit.x = Math.max(-WORLD_SIZE, Math.min(WORLD_SIZE, selectedUnit.x));
            selectedUnit.y = Math.max(-WORLD_SIZE, Math.min(WORLD_SIZE, selectedUnit.y));
            selectedUnit.vx += dx * 0.1;
            selectedUnit.vy += dy * 0.1;
        }
    }

    private void useSpecial() {
        if (specialCooldown > 0) {
            log("⏳", "Spezial noch nicht bereit (" + specialCooldown + " Frames)");
            return;
        }
        if (selectedUnit == null) return;
        log("💥", selectedUnit.name + " nutzt Gravitationswelle!");
        for (Body b : bodies) {
            if (b.team == 2) {
                double dx = b.x - selectedUnit.x;
                double dy = b.y - selectedUnit.y;
                double dist = Math.hypot(dx, dy);
                if (dist < 200) {
                    double push = 300 / (dist + 10);
                    b.x += dx * push;
                    b.y += dy * push;
                }
            }
        }
        specialCooldown = 100;
    }

    @Override
    protected void paintComponent(Graphics g) {
        super.paintComponent(g);
        Graphics2D g2 = (Graphics2D) g;
        g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
        g2.setColor(Color.BLACK);
        g2.fillRect(0, 0, getWidth(), getHeight());

        AffineTransform at = new AffineTransform();
        at.translate(getWidth() / 2.0, getHeight() / 2.0);
        at.scale(zoom, zoom);
        at.translate(-panX, -panY);
        g2.setTransform(at);

        g2.setColor(new Color(60, 60, 80));
        for (int x = -WORLD_SIZE; x <= WORLD_SIZE; x += 400) {
            g2.drawLine(x, -WORLD_SIZE, x, WORLD_SIZE);
            g2.drawLine(-WORLD_SIZE, x, WORLD_SIZE, x);
        }

        for (Body b : bodies) {
            int radius = (int) (b.radius * zoom);
            if (radius < 2) radius = 2;
            g2.setColor(b.color);
            g2.fillOval((int) (b.x - radius), (int) (b.y - radius), radius * 2, radius * 2);
            if (b.health > 0 && b.health < b.maxHealth) {
                g2.setColor(Color.RED);
                g2.fillRect((int) (b.x - radius), (int) (b.y - radius - 8), radius * 2, 4);
                g2.setColor(Color.GREEN);
                g2.fillRect((int) (b.x - radius), (int) (b.y - radius - 8), (int) (radius * 2 * (b.health / b.maxHealth)), 4);
            }
            if (b == selectedUnit) {
                g2.setColor(Color.CYAN);
                g2.drawOval((int) (b.x - radius - 3), (int) (b.y - radius - 3), (radius + 3) * 2, (radius + 3) * 2);
            }
            g2.setColor(Color.WHITE);
            g2.setFont(new Font("Arial", Font.PLAIN, 12));
            g2.drawString(b.name, (int) (b.x - 20), (int) (b.y - radius - 5));
        }

        g2.setTransform(new AffineTransform());
        g2.setColor(Color.WHITE);
        g2.setFont(new Font("Monospaced", Font.BOLD, 14));
        g2.drawString("🎮 GRAVITATION + QUESTS", 20, 25);
        g2.drawString("💎 Kristalle: " + crystalsCollected + " getragen | " + crystalsDelivered + "/" + CRYSTALS_NEEDED + " abgegeben", 20, 50);
        g2.drawString("⭐ XP: " + xp + " | Level: " + level, 20, 70);
        g2.drawString("🎯 Ausgewählt: " + (selectedUnit != null ? selectedUnit.name : "keine"), 20, 90);
        g2.drawString("💥 Spezial: " + (specialCooldown > 0 ? "Cooldown" : "bereit (Leertaste)"), 20, 110);
        g2.drawString(running ? "▶️ LÄUFT (P=Pause)" : "⏸️ PAUSIERT (P)", 20, 130);
        g2.drawString("WASD bewegt ausgewählte Einheit | Mausrad Zoom | R Reset", 20, 150);
        if (gameWon) {
            g2.setFont(new Font("Monospaced", Font.BOLD, 40));
            g2.setColor(Color.YELLOW);
            g2.drawString("✨ SIEG! ✨", getWidth() / 2 - 100, getHeight() / 2);
        }
    }

    @Override
    public void mousePressed(MouseEvent e) {
        if (e.getButton() == MouseEvent.BUTTON1) {
            Point world = screenToWorld(e.getX(), e.getY());
            Body clicked = null;
            for (Body b : bodies) {
                if (Math.hypot(b.x - world.x, b.y - world.y) < b.radius) {
                    clicked = b;
                    break;
                }
            }
            if (clicked != null && clicked.team == 1) {
                selectedUnit = clicked;
                log("🖱️", "Ausgewählt: " + clicked.name);
            } else if (clicked == null) {
                Body newBody = new Body(world.x, world.y, 0, 0, 10, 8, Color.GRAY);
                newBody.name = "Neutral";
                newBody.team = 0;
                bodies.add(newBody);
                log("✨", "Neuer neutraler Punkt bei " + world.x + "," + world.y);
            }
        } else if (e.getButton() == MouseEvent.BUTTON3) {
            dragging = true;
            dragStartX = e.getX();
            dragStartY = e.getY();
        }
    }

    @Override
    public void mouseDragged(MouseEvent e) {
        if (dragging) {
            int dx = e.getX() - dragStartX;
            int dy = e.getY() - dragStartY;
            panX -= dx / zoom;
            panY -= dy / zoom;
            dragStartX = e.getX();
            dragStartY = e.getY();
            repaint();
        }
    }

    @Override
    public void mouseReleased(MouseEvent e) { dragging = false; }

    @Override
    public void mouseWheelMoved(MouseWheelEvent e) {
        double delta = -e.getPreciseWheelRotation() * 0.1;
        zoom *= (1 + delta);
        zoom = Math.max(0.2, Math.min(zoom, 8.0));
        repaint();
    }

    @Override
    public void keyPressed(KeyEvent e) {
        double step = 25.0 / zoom;
        switch (e.getKeyCode()) {
            case KeyEvent.VK_W: case KeyEvent.VK_UP: moveSelectedUnit(0, -step); break;
            case KeyEvent.VK_S: case KeyEvent.VK_DOWN: moveSelectedUnit(0, step); break;
            case KeyEvent.VK_A: case KeyEvent.VK_LEFT: moveSelectedUnit(-step, 0); break;
            case KeyEvent.VK_D: case KeyEvent.VK_RIGHT: moveSelectedUnit(step, 0); break;
            case KeyEvent.VK_SPACE: useSpecial(); break;
            case KeyEvent.VK_P: running = !running; log("⏸️", running ? "Fortgesetzt" : "Pausiert"); break;
            case KeyEvent.VK_F: following = !following; log("🎥", following ? "Kamera folgt Auswahl" : "Kamera frei"); break;
            case KeyEvent.VK_R: initGame(); log("🔄", "Neustart"); break;
            case KeyEvent.VK_G:
                if (selectedUnit != null)
                    log("🗺️", "GPS: " + (selectedUnit.x / 100 + 49.8) + ", " + (selectedUnit.y / 100 + 8.6));
                break;
        }
    }

    private Point screenToWorld(int screenX, int screenY) {
        int centerX = getWidth() / 2;
        int centerY = getHeight() / 2;
        double worldX = (screenX - centerX) / zoom + panX;
        double worldY = (screenY - centerY) / zoom + panY;
        return new Point((int) worldX, (int) worldY);
    }

    @Override public void mouseClicked(MouseEvent e) {}
    @Override public void mouseEntered(MouseEvent e) {}
    @Override public void mouseExited(MouseEvent e) {}
    @Override public void mouseMoved(MouseEvent e) {}
    @Override public void keyReleased(KeyEvent e) {}
    @Override public void keyTyped(KeyEvent e) {}

    static class Body {
        String name;
        double x, y, vx, vy, mass, radius, health, maxHealth;
        int team;
        boolean movable, isCollectable;
        Color color;
        Body(double x, double y, double vx, double vy, double mass, double radius, Color color) {
            this.x = x; this.y = y; this.vx = vx; this.vy = vy;
            this.mass = mass; this.radius = radius; this.color = color;
            this.movable = true;
            this.health = 100;
            this.maxHealth = 100;
            this.team = 0;
            this.isCollectable = false;
            this.name = "Körper";
        }
    }

