            this.team = 1;
        }
        
        void update() {
            if (!movable) return;
            vx += ax * DT;
            vy += ay * DT;
            x += vx * DT;
            y += vy * DT;
            if (entropy > 100 && health < maxHealth) {
                health += 0.1;
            }
            x = Math.max(-WORLD_SIZE, Math.min(WORLD_SIZE, x));
            y = Math.max(-WORLD_SIZE, Math.min(WORLD_SIZE, y));
        }
        
        Unit reproduce(int newId) {
            Unit child = new Unit(newId, this.mass * (0.7 + RAND.nextDouble() * 0.6), 
                                  this.x + (RAND.nextDouble() - 0.5) * 200,
                                  this.y + (RAND.nextDouble() - 0.5) * 200, 
                                  Color.WHITE);
            child.team = this.team;
            child.entropy = this.entropy * 0.6;
            child.attack = this.attack * (0.8 + RAND.nextDouble() * 0.4);
            child.speed = this.speed * (0.8 + RAND.nextDouble() * 0.4);
            child.mass = this.mass * 0.6;
            child.health = this.health * 0.5;
            child.maxHealth = child.health;
