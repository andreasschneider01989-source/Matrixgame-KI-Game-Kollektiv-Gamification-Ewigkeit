import java.util.List;

public class MatrixSurvivalGame extends JFrame implements KeyListener {

    private Entity player;
    private List<Entity> enemies = new ArrayList<>();
    private double zoom = 1.0;
    private int score = 0;
    private boolean gameOver = false;

    public MatrixSurvivalGame() {
        // Spieler: Team 1 (Grün), hohe Geschwindigkeit
        player = new Entity(400, 300, 20, Color.GREEN, 1);
        player.speed = 5.0;

        setupWindow();
        
        // Game Loop Thread (Die Zeitachse der Matrix)
        new Thread(() -> {
            while (!gameOver) {
                updateLogic();
                repaint();
                try { Thread.sleep(20); } catch (InterruptedException e) {}
            }
        }).start();
    }

    private void updateLogic() {
        // 1. Zufälliges Spawning (Entropie-Zunahme)
        if (Math.random() < 0.05) { // 5% Chance pro Frame
            spawnEnemy();
        }

        // 2. Gegner-KI (Pythagoras-Anwendung)
        for (Entity e : enemies) {
            double dx = player.x - e.x;
            double dy = player.y - e.y;
            double distance = Math.sqrt(dx*dx + dy*dy); // PYTHAGORAS am Ursprung

            if (distance > 1) {
                // Einheiten bewegen sich auf den Spieler zu
                e.x += (dx / distance) * e.speed;
                e.y += (dy / distance) * e.speed;
            }

            // Kollisionsprüfung (Schaden machen)
            if (distance < (player.r + e.r)) {
                player.health -= 0.5;
                if (player.health <= 0) gameOver = true;
            }
        }
    }

    private void spawnEnemy() {
        // Gegner spawnen außerhalb der Sicht, um den "Überraschungsmoment" zu wahren
        double angle = Math.random() * Math.PI * 2;
        double dist = 400 + Math.random() * 200;
        double ex = player.x + Math.cos(angle) * dist;
        double ey = player.y + Math.sin(angle) * dist;

        // Verschiedene Typen: Zombie (langsam), Jäger (schneller), Elefant (groß)
        double type = Math.random();
        if (type > 0.9) { // Elefant
            enemies.add(new Entity(ex, ey, 50, Color.GRAY, 2).setStats(0.5, 500));
        } else if (type > 0.7) { // Jäger
            enemies.add(new Entity(ex, ey, 15, Color.RED, 2).setStats(2.5, 50));
        } else { // Standard Zombie
            enemies.add(new Entity(ex, ey, 25, Color.ORANGE, 2).setStats(1.2, 100));
        }
    }

    private void render(Graphics g) {
        Graphics2D g2 = (Graphics2D) g;
        g2.setColor(Color.BLACK);
        g2.fillRect(0, 0, getWidth(), getHeight());

        // Kamera-Follow & Zoom
        g2.translate(getWidth()/2 - player.x * zoom, getHeight()/2 - player.y * zoom);
        g2.scale(zoom, zoom);

        // Grid
        g2.setColor(new Color(30, 30, 30));
        for(int i = -2000; i < 4000; i+=100) {
            g2.drawLine(i, -2000, i, 4000);
            g2.drawLine(-2000, i, 4000, i);
        }

        // Zeichne Gegner
        for (Entity e : enemies) {
            g2.setColor(e.color);
            g2.fillOval((int)e.x - e.r, (int)e.y - e.r, e.r * 2, e.r * 2);
        }

        // Zeichne Spieler
        g2.setColor(player.color);
        g2.fillOval((int)player.x - player.r, (int)player.y - player.r, player.r * 2, player.r * 2);

        // UI (Statisch)
        g2.setTransform(new java.awt.geom.AffineTransform()); // Reset für UI
        g2.setColor(Color.WHITE);
        g2.setFont(new Font("Arial", Font.BOLD, 20));
        g2.drawString("Health: " + (int)player.health, 20, 40);
        if (gameOver) g2.drawString("SYSTEM-HALT: MATRIX INFILTRIERT", 300, 300);
    }

    @Override
    public void keyPressed(KeyEvent e) {
        switch (Character.toLowerCase(e.getKeyChar())) {
            case 'w': player.y -= player.speed; break;
            case 's': player.y += player.speed; break;
            case 'a': player.x -= player.speed; break;
            case 'd': player.x += player.speed; break;
            case '+': zoom *= 1.1; break;
            case '-': zoom /= 1.1; break;
        }
    }

    private void setupWindow() {
        this.setSize(1000, 700);
        this.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        this.addKeyListener(this);
        this.add(new JPanel() { @Override protected void paintComponent(Graphics g) { render(g); } });
        this.setVisible(true);
    }

    static class Entity {
        double x, y, speed = 1.0, health = 100;
        int r, team; Color color;
        Entity(double x, double y, int r, Color c, int team) {
            this.x = x; this.y = y; this.r = r; this.color = c; this.team = team;
        }
        Entity setStats(double s, double h) { this.speed = s; this.health = h; return this; }
    }

    public static void main(String[] args) { SwingUtilities.invokeLater(() -> new MatrixSurvivalGame()); }
    @Override public void keyTyped(KeyEvent e) {}
    @Override public void keyReleased(KeyEvent e) {}
