```java
package matrixgame.core;

import java.awt.Color;
import java.util.Random;

public class MassPoint {
    private static final Random RAND = new Random();
    
    // Basis-Entropie (ähnlich wie basisEntroDouble)
    private double entropyBase;
    
    // Physikalische Größen
    private double mass;
    private SpaceTimeCoordinate position;
    private double vx, vy, vz;   // Geschwindigkeit
    private double ax, ay, az;   // Beschleunigung
    private double kineticEnergy; // E_kin
    
    // Visuelle Eigenschaften
    private Color color;
    private int radius;
    private boolean movable;
    
    // Zeitstempel für letzte Änderung
    private long lastUpdateTime;
    
    public MassPoint(double mass, double x, double y, double z, Color color, int radius) {
        this.mass = mass;
        this.position = new SpaceTimeCoordinate(x, y, z);
        this.vx = this.vy = this.vz = 0;
        this.ax = this.ay = this.az = 0;
        this.kineticEnergy = 0;
        this.color = color;
        this.radius = radius;
        this.movable = true;
        this.entropyBase = 1000.0; // Startwert
        this.lastUpdateTime = System.currentTimeMillis();
    }
    
    // Kinematik
    public void updateKinematics(double dt) {
        vx += ax * dt;
        vy += ay * dt;
        vz += az * dt;
        double oldX = position.getX();
        double oldY = position.getY();
        double oldZ = position.getZ();
        position.set(oldX + vx*dt, oldY + vy*dt, oldZ + vz*dt);
        // Kinetische Energie
        double v2 = vx*vx + vy*vy + vz*vz;
        kineticEnergy = 0.5 * mass * v2;
        lastUpdateTime = System.currentTimeMillis();
    }
    
    // Gravitation zu einem anderen MassPoint (Newtonsches Gesetz)
    public void applyGravityFrom(MassPoint other, double dt) {
        double dx = other.position.getX() - this.position.getX();
        double dy = other.position.getY() - this.position.getY();
        double dz = other.position.getZ() - this.position.getZ();
        double r2 = dx*dx + dy*dy + dz*dz;
        if (r2 < PhysicsConstants.MIN_DISTANCE) r2 = PhysicsConstants.MIN_DISTANCE;
        double r = Math.sqrt(r2);
        double forceMag = PhysicsConstants.G * this.mass * other.mass / r2;
        double axThis = forceMag / this.mass * dx / r;
        double ayThis = forceMag / this.mass * dy / r;
        double azThis = forceMag / this.mass * dz / r;
        this.ax += axThis;
        this.ay += ayThis;
        this.az += azThis;
        // Gegenkraft (für other, wird separat aufgerufen)
    }
    
    // Entropie-Angleichung zwischen zwei MassPoints (Zufall + Angleichung)
    public void entropyExchangeWith(MassPoint other, double rate) {
        double diff = this.entropyBase - other.entropyBase;
        double transfer = diff * RAND.nextDouble() * rate;
        this.entropyBase -= transfer;
        other.entropyBase += transfer;
    }
    
    // Zufällige Bewegung (Brownsche Komponente)
    public void randomWalk(double strength, double dt) {
        double rx = (RAND.nextDouble() - 0.5) * strength * dt;
        double ry = (RAND.nextDouble() - 0.5) * strength * dt;
        double rz = (RAND.nextDouble() - 0.5) * strength * dt;
        position.set(position.getX() + rx, position.getY() + ry, position.getZ() + rz);
        lastUpdateTime = System.currentTimeMillis();
    }
    
    // Getter/Setter
    public double getMass() { return mass; }
    public SpaceTimeCoordinate getPosition() { return position; }
    public double getVx() { return vx; }
    public double getVy() { return vy; }
    public double getVz() { return vz; }
    public double getKineticEnergy() { return kineticEnergy; }
    public double getEntropyBase() { return entropyBase; }
    public Color getColor() { return color; }
    public int getRadius() { return radius; }
    public boolean isMovable() { return movable; }
    public void setMovable(boolean movable) { this.movable = movable; }
    public long getLastUpdateTime() { return lastUpdateTime; }
    
    // Optional: Farbe aus Entropie berechnen
    public void updateColorFromEntropy() {
        int r = (int)(Math.abs(entropyBase) % 256);
        int g = (int)(Math.abs(entropyBase * 2) % 256);
        int b = (int)(Math.abs(entropyBase * 3) % 256);
        this.color = new Color(r, g, b);
    }
}
