package matrixgame.single;

import java.awt.Color;
import java.time.Instant;
import java.util.ArrayList;
import java.util.List;
import java.util.Random;

/**
 * MATRIXGAME LUMINI UNIVERSE – SINGLE FILE
 * 
 * Enthält:
 * - Lumini-Zahlen (Basis n, längen-erhaltend)
 * - Raumzeitkoordinaten mit Betrag (absX, absY, absZ) und Zeitstempel
 * - Massenpunkte mit Entropie, kinetischer Energie, stochastischer Bewegung
 * - Gamification: XP, Level, Erfolge
 * - LLM-freundliche Konsolenausgabe (JSON-ähnlich)
 * 
 * @author Kollektives Bewusstsein & Andreas Schneider
 * @version 1.0 (2026-04-11)
 */
public class MatrixGameLuminiUniverse {

    // ================== KONSTANTEN ==================
    private static final double GRAVITY_STRENGTH = 0.01;   // Entropische "Anziehung"
    private static final double ENTROPY_MIX_RATE = 0.1;   // Austauschrate
    private static final double DEFAULT_DT = 1.0;         // Zeitschritt (Sekunden)
    private static final double MIN_DISTANCE = 1e-5;      // Vermeidung von Singularitäten
    private static final Random RAND = new Random();

    // ================== LUMINI-ZAHL (Basis n) ==================
    static class LuminiNumber {
        final int basis;
        final String digits;
        final long decimalValue;

        /** Erzeugt Lumini-Zahl aus Dezimalzahl n (0-basiert) */
        LuminiNumber(long n, int basis) {
            if (basis < 2) throw new IllegalArgumentException("Basis ≥ 2");
            this.basis = basis;
            long remaining = n;
            int len = 1;
            long bucketSize = basis;
            while (remaining >= bucketSize) {
                remaining -= bucketSize;
                len++;
                bucketSize *= basis;
            }
            String d = Long.toString(remaining, basis);
            while (d.length() < len) d = "0" + d;
            this.digits = d;
            this.decimalValue = n;
        }

        /** Erzeugt Lumini-Zahl aus String (z.B. "010") und Basis */
        LuminiNumber(String luminiStr, int basis) {
            this.basis = basis;
            this.digits = luminiStr;
            int len = luminiStr.length();
            long offset = 0;
            for (int i = 1; i < len; i++) offset += Math.pow(basis, i);
            long value = Long.parseLong(luminiStr, basis);
            this.decimalValue = offset + value;
        }

        @Override
        public String toString() {
            return digits + "(Basis " + basis + ")";
        }

        /** Lumini-Multiplikation: dominantes Vorzeichen (negativ wenn mind. ein Faktor negativ) */
        static double mul(double a, double b) {
            double abs = Math.abs(a * b);
            return (a < 0 || b < 0) ? -abs : abs;
        }
    }

    // ================== RAUMZEIT-KOORDINATE (mit Betrag) ==================
    static class SpaceTimeCoordinate {
        private double x, y, z;
        private double absX, absY, absZ;
        private final Instant creationTime;
        private Instant lastUpdate;

        SpaceTimeCoordinate(double x, double y, double z) {
            this.x = x;
            this.y = y;
            this.z = z;
            updateAbsolutes();
            this.creationTime = Instant.now();
            this.lastUpdate = creationTime;
        }

        private void updateAbsolutes() {
            this.absX = Math.abs(x);
            this.absY = Math.abs(y);
            this.absZ = Math.abs(z);
        }

        void set(double x, double y, double z) {
            this.x = x;
            this.y = y;
            this.z = z;
            updateAbsolutes();
            this.lastUpdate = Instant.now();
        }

        double distanceTo(SpaceTimeCoordinate other) {
            double dx = this.x - other.x;
            double dy = this.y - other.y;
            double dz = this.z - other.z;
            return Math.sqrt(dx*dx + dy*dy + dz*dz);
        }

        double distanceFromOrigin() {
            return Math.sqrt(absX*absX + absY*absY + absZ*absZ);
        }

        double getX() { return x; }
        double getY() { return y; }
        double getZ() { return z; }
        double getAbsX() { return absX; }
        double getAbsY() { return absY; }
        double getAbsZ() { return absZ; }
        Instant getCreationTime() { return creationTime; }
        Instant getLastUpdate() { return lastUpdate; }
    }

    // ================== MASSEPUNKT (MIT ENTROPIE & ENERGIE) ==================
    static class MassPoint {
        double mass;
        SpaceTimeCoordinate pos;
        double vx, vy, vz;
        double ax, ay, az;
        double kineticEnergy;
        double entropyBase;        // Äquivalent zu basisEntroDouble
        Color color;
        int radius;
        boolean movable;
        long lastUpdateTime;
        int kills;                 // Gamification

        MassPoint(double mass, double x, double y, double z, Color color, int radius) {
            this.mass = mass;
            this.pos = new SpaceTimeCoordinate(x, y, z);
            this.vx = this.vy = this.vz = 0;
            this.ax = this.ay = this.az = 0;
            this.kineticEnergy = 0;
            this.entropyBase = 1000.0;
            this.color = color;
            this.radius = radius;
            this.movable = true;
            this.lastUpdateTime = System.currentTimeMillis();
            this.kills = 0;
        }

        void updateKinematics(double dt) {
            vx += ax * dt;
            vy += ay * dt;
            vz += az * dt;
            double newX = pos.getX() + vx * dt;
            double newY = pos.getY() + vy * dt;
            double newZ = pos.getZ() + vz * dt;
            pos.set(newX, newY, newZ);
            double v2 = vx*vx + vy*vy + vz*vz;
            kineticEnergy = 0.5 * mass * v2;
            lastUpdateTime = System.currentTimeMillis();
        }

        /** Entropische Gravitation (stochastisch, wie von dir gefordert) */
        void applyStochasticGravityFrom(MassPoint other, double dt) {
            double dx = other.pos.getX() - this.pos.getX();
            double dy = other.pos.getY() - this.pos.getY();
            double dz = other.pos.getZ() - this.pos.getZ();
            double r2 = dx*dx + dy*dy + dz*dz;
            if (r2 < MIN_DISTANCE) r2 = MIN_DISTANCE;
            double r = Math.sqrt(r2);
            // Entropischer Drang: Je näher, desto höher die Wahrscheinlichkeit einer Annäherung
            double entropyBias = (other.entropyBase - this.entropyBase) / (r2 + 1);
            double randFactor = RAND.nextDouble() * 0.1;
            double forceMag = GRAVITY_STRENGTH * this.mass * other.mass / r2;
            forceMag += entropyBias * randFactor;  // Zufallsfluktuation
            double axThis = forceMag / this.mass * dx / r;
            double ayThis = forceMag / this.mass * dy / r;
            double azThis = forceMag / this.mass * dz / r;
            this.ax += axThis;
            this.ay += ayThis;
            this.az += azThis;
        }

        /** Entropie-Austausch (Angleichung) */
        void entropyExchangeWith(MassPoint other, double rate) {
            double diff = this.entropyBase - other.entropyBase;
            double transfer = diff * RAND.nextDouble() * rate;
            this.entropyBase -= transfer;
            other.entropyBase += transfer;
        }

        /** Brownsche Zufallsbewegung (Modell für unendlich kleine Schritte) */
        void randomWalk(double strength, double dt) {
            double rx = (RAND.nextDouble() - 0.5) * strength * dt;
            double ry = (RAND.nextDouble() - 0.5) * strength * dt;
            double rz = (RAND.nextDouble() - 0.5) * strength * dt;
            pos.set(pos.getX() + rx, pos.getY() + ry, pos.getZ() + rz);
            lastUpdateTime = System.currentTimeMillis();
        }

        void updateColorFromEntropy() {
            int r = (int)(Math.abs(entropyBase) % 256);
            int g = (int)(Math.abs(entropyBase * 2) % 256);
            int b = (int)(Math.abs(entropyBase * 3) % 256);
            this.color = new Color(r, g, b);
            // Radius skaliert mit Masse (Wurzel für Sichtbarkeit)
            this.radius = (int)(Math.sqrt(mass) * 2 + 3);
        }
    }

    // ================== LUMINI-ENGINE (SIMULATION) ==================
    static class LuminiEngine {
        private final List<MassPoint> bodies = new ArrayList<>();
        private double dt = DEFAULT_DT;
        private double entropyMixRate = ENTROPY_MIX_RATE;
        private long stepCount = 0;

        // Gamification
        private double xp = 0;
        private int level = 1;
        private boolean achievementEntropy = false;
        private boolean achievementGravity = false;

        void addBody(MassPoint b) { bodies.add(b); }

        void setDt(double dt) { this.dt = dt; }

        void step() {
            // 1. Beschleunigungen zurücksetzen
            for (MassPoint b : bodies) {
                if (!b.movable) continue;
                b.ax = b.ay = b.az = 0;
            }

            // 2. Stochastische Gravitation (alle Paare)
            for (int i = 0; i < bodies.size(); i++) {
                MassPoint bi = bodies.get(i);
                if (!bi.movable) continue;
                for (int j = i+1; j < bodies.size(); j++) {
                    MassPoint bj = bodies.get(j);
                    if (!bj.movable) continue;
                    bi.applyStochasticGravityFrom(bj, dt);
                    bj.applyStochasticGravityFrom(bi, dt);
                }
            }

            // 3. Kinematik aktualisieren
            for (MassPoint b : bodies) {
                if (!b.movable) continue;
                b.updateKinematics(dt);
                b.randomWalk(0.5, dt);   // Brownsche Bewegung = unendlich kleine Schritte
            }

            // 4. Entropie-Angleichung (zufällige Paare)
            int n = bodies.size();
            for (int k = 0; k < n * entropyMixRate; k++) {
                int i = RAND.nextInt(n);
                int j = RAND.nextInt(n);
                if (i != j) bodies.get(i).entropyExchangeWith(bodies.get(j), 0.5);
            }

            // 5. Farben aktualisieren
            for (MassPoint b : bodies) b.updateColorFromEntropy();

            // 6. Gamification: XP basierend auf Energieänderung
            double totalEnergy = getTotalEnergy();
            xp += Math.abs(totalEnergy) * 0.01;
            if (xp >= level * 100) {
                level++;
                System.out.println("🏆 LEVEL UP! Neues Level: " + level);
            }
            if (!achievementEntropy && totalEnergy > 500) {
                achievementEntropy = true;
                System.out.println("🏅 Erfolg freigeschaltet: ENTROPIE-MEISTER");
            }
            if (!achievementGravity && bodies.size() > 10) {
                achievementGravity = true;
                System.out.println("🏅 Erfolg freigeschaltet: GRAVITATIONS-KOLLEKTIV");
            }

            stepCount++;
        }

        double getTotalKineticEnergy() {
            double sum = 0;
            for (MassPoint b : bodies) sum += b.kineticEnergy;
            return sum;
        }

        double getTotalPotentialEnergy() {
            double sum = 0;
            for (int i = 0; i < bodies.size(); i++) {
                MassPoint bi = bodies.get(i);
                for (int j = i+1; j < bodies.size(); j++) {
                    MassPoint bj = bodies.get(j);
                    double r = bi.pos.distanceTo(bj.pos);
                    if (r < MIN_DISTANCE) r = MIN_DISTANCE;
                    sum += -GRAVITY_STRENGTH * bi.mass * bj.mass / r;
                }
            }
            return sum;
        }

        double getTotalEnergy() {
            return getTotalKineticEnergy() + getTotalPotentialEnergy();
        }

        void printStatus() {
            System.out.println("========================================");
            System.out.println("STEP " + stepCount);
            System.out.println("  E_kin = " + String.format("%.3f", getTotalKineticEnergy()));
            System.out.println("  E_pot = " + String.format("%.3f", getTotalPotentialEnergy()));
            System.out.println("  E_total = " + String.format("%.3f", getTotalEnergy()));
            System.out.println("  XP = " + (int)xp + " | Level = " + level);
            System.out.println("  Körperanzahl = " + bodies.size());
            if (bodies.size() > 0) {
                MassPoint first = bodies.get(0);
                System.out.println("  Beispiel-Körper: pos=(" + String.format("%.2f", first.pos.getX()) + ","
                        + String.format("%.2f", first.pos.getY()) + ") | Entropie=" + String.format("%.2f", first.entropyBase));
                System.out.println("  Lumini(42) = " + new LuminiNumber(42, 2));
                System.out.println("  Lumini(23) = " + new LuminiNumber(23, 2));
            }
            System.out.println("========================================\n");
        }
    }

    // ================== MAIN (AUSFÜHRBAR) ==================
    public static void main(String[] args) throws InterruptedException {
