import java.awt.geom.AffineTransform;
import java.util.ArrayList;
import java.util.Iterator;
import java.util.List;

public class MatrixgameSurvivalZoom extends JPanel implements KeyListener, ActionListener {

    // --- Raumzeit-Variablen ---
    private double zoom = 1.0;
    private double playerX = 0, playerY = 0;
    private double playerSpeed = 10.0;
    private double health = 100.0;
    private long score = 0;
    private boolean gameOver = false;

    // --- Entitäten (Die Entropie) ---
    private List<Zombie> swarm = new ArrayList<>();
    private Timer gameLoop;
    private long frameCount = 0;

    public MatrixgameSurvivalZoom() {
        setBackground(new Color(15, 15, 25)); // Tiefes Universum
        setFocusable(true);
        addKeyListener(this);
        
        // Gameloop: 60 FPS
        gameLoop = new Timer(16, this);
        gameLoop.start();
    }

    
    double speedUp=0.1;
    double damageUp=0.1;
    double spawnUp=1.38;
    private void spawnEntropy() {
    speedUp+=Math.random();
    speedUp-=Math.random();
        damageUp+=10*Math.random();
         spawnUp+=10*Math.random();
    	for(int i=0; i<10+spawnUp; i++) {
        // Erschaffe neue Feinde am Rand der aktuellen Wahrnehmung (Zoom-abhängig)
        double angle = Math.random() * Math.PI * 2;
        double distance = (800 / zoom) + Math.random() * 500;
        double zx = playerX + Math.cos(angle) * distance*Math.random()/Math.random()/Math.random();
        double zy = playerY + Math.sin(angle) * distance*Math.random()/Math.random()/Math.random();;
    
        
        
        // Verschiedene Feind-Typen
        double type = Math.random();
        if (type > 0.8) {
            swarm.add(new Zombie(zx, zy, 25, new Color((int) (255*Math.random()), (int) (255*Math.random()), (int) (255*Math.random())), 2.5)); // Schneller Jäger
        } else if (type > 0.5) {
            swarm.add(new Zombie(zx, zy, 40, new Color((int) (255*Math.random()),(int) (255*Math.random()),(int) (255*Math.random())), 1.0)); // Tank
        } else {
            swarm.add(new Zombie(zx, zy, 15, new Color((int) (255*Math.random()), (int) (255*Math.random()), (int) (255*Math.random())), 1.0)); // Flinker Schwarm
        }}
    }

    @Override
    protected void paintComponent(Graphics g) {
        super.paintComponent(g);
        Graphics2D g2 = (Graphics2D) g;
        
        // Visuelle Glättung für schöne Didaktik
        g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);

        // --- DER SCHÖNE ZOOM & KAMERA-FOKUS ---
        AffineTransform at = new AffineTransform();
        at.translate(getWidth() / 2.0, getHeight() / 2.0); // Ursprung in die Mitte
        at.scale(zoom, zoom);                              // Skalierung der Raumzeit
        at.translate(-playerX, -playerY);                  // Fokus immer exakt auf dem Spieler
        g2.setTransform(at);

        // --- HINTERGRUND-GITTER (Struktur der Matrix) ---
        g2.setColor(new Color(40, 50, 70, 150));
        for (int i = -10000; i <= 10000; i += 200) {
            g2.drawLine(i, -10000, i, 10000);
            g2.drawLine(-10000, i, 10000, i);
        }

        // --- ENTITÄTEN ZEICHNEN ---
        for (Zombie z : swarm) {
            g2.setColor(z.color);
            g2.fillOval((int)z.x - z.r, (int)z.y - z.r, z.r * 2, z.r * 2);
        }

        // --- SPIELER ZEICHNEN (Zentrum der Ordnung) ---
        g2.setColor(new Color(0, 255, 150)); // Lumini-Grün
        g2.fillOval((int)playerX - 20, (int)playerY - 20, 40, 40);
        g2.setColor(Color.WHITE);
        g2.drawOval((int)playerX - 25, (int)playerY - 25, 50, 50); // Aura

        // --- UI & GAMIFICATION (Statisch über der Raumzeit) ---
        g2.setTransform(new AffineTransform()); // Reset der Transformation
        g2.setColor(Color.WHITE);
        g2.setFont(new Font("Monospaced", Font.BOLD, 18));
        g2.drawString("INTEGRITÄT: " + (int)health + "%", 20, 30);
        g2.drawString("PUNKTE: " + score, 20, 55);
        g2.drawString("ZOOM (O/P): " + String.format("%.2f", zoom), 20, 80);
        g2.drawString("ENTROPIE-EINHEITEN: " + swarm.size(), 20, 105);

        if (gameOver) {
            g2.setFont(new Font("Monospaced", Font.BOLD, 50));
            g2.setColor(Color.RED);
            g2.drawString("SYSTEM KORRUMPIERT", getWidth()/2 - 250, getHeight()/2);
            g2.setFont(new Font("Monospaced", Font.PLAIN, 20));
            g2.drawString("Erreichte Struktur-Punkte: " + score, getWidth()/2 - 150, getHeight()/2 + 40);
        }
    }

    @Override
    public void actionPerformed(ActionEvent e) {
        if (gameOver) return;
        frameCount++;

        // Dynamisches Spawnen: Je länger du überlebst, desto schneller steigt die Entropie
        int spawnRate = Math.max(10, 100 - (int)(frameCount / 100)); 
        if (frameCount % spawnRate == 0) {
            spawnEntropy();
        }

        score++; // Überleben generiert konstant Punkte

        // KI-Verfolgung mit Pythagoras
        Iterator<Zombie> it = swarm.iterator();
        while (it.hasNext()) {
            Zombie z = it.next();
            double dx = playerX - z.x;
            double dy = playerY - z.y;
            double dist = Math.sqrt(dx * dx + dy * dy);

            // Bewegung auf den Spieler zu
            if (dist > 0) {
                z.x += (dx / dist) * z.speed;
                z.y += (dy / dist) * z.speed;
            }

            // Kollisionsabfrage
            if (dist < (20 + z.r)) {
                health -= 0.5;
                if (health <= 0) {
                    gameOver = true;
                }
            }
        }
        repaint();
    }

    // --- STEUERUNG ---
    @Override
    public void keyPressed(KeyEvent e) {
        if (gameOver) return;
        
        int key = e.getKeyCode();
        
        // WASD für flüssige Bewegung in der Raumzeit
        if (key == KeyEvent.VK_W) playerY -= playerSpeed;
        if (key == KeyEvent.VK_S) playerY += playerSpeed;
        if (key == KeyEvent.VK_A) playerX -= playerSpeed;
        if (key == KeyEvent.VK_D) playerX += playerSpeed;
        
        // Die unendliche Skalierung (Zoom)
        if (key == KeyEvent.VK_O) zoom *= 1.1; // Hineinzoomen
        if (key == KeyEvent.VK_P) zoom /= 1.1; // Herauszoomen
    }

    @Override public void keyReleased(KeyEvent e) {}
    @Override public void keyTyped(KeyEvent e) {}

    // --- DATENSTRUKTUR ---
    static class Zombie {
        double x, y, speed;
        int r;
        Color color;
        Zombie(double x, double y, int r, Color c, double speed) {
            this.x = x; this.y = y; this.r = r; this.color = c; this.speed = speed;
        }
    }

    // --- STARTPUNKT ---
    public static void main(String[] args) {
        JFrame frame = new JFrame("Matrixgame: Kollektives Survival");
        frame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        frame.setSize(1200, 800);
        frame.add(new MatrixgameSurvivalZoom());
        frame.setLocationRelativeTo(null);
        frame.setVisible(true);
    }
}
