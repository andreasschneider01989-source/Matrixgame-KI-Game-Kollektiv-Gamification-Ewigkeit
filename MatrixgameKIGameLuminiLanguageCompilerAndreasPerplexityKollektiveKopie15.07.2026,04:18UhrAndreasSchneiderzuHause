    public static byte[] byteToToken(byte b, int basis) {
        byte[] output = new byte[210];
        int counter = 0;
        while (b != 0) {
            counter++;
            int rest = b % basis;
            if (rest < 0) {
                rest = -rest;
            }
            if (b > 0) {
                b = (byte) (b - rest);
            }
            if (b < 0) {
                b = (byte) (b + rest);
            }
            b = (byte) (b / basis);
            output[output.length - counter] = (byte) rest;
        }
        return output;
    }


