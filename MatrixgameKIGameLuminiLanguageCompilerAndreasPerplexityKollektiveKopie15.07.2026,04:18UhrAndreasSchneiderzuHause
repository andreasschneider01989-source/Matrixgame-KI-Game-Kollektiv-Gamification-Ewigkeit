## 🧠 5. LUMINI-ENGINE (Simulationskern)

```java
package matrixgame.engine;

import matrixgame.core.MassPoint;
import matrixgame.core.PhysicsConstants;
import java.util.ArrayList;
import java.util.List;

public class LuminiEngine {
    private final List<MassPoint> bodies = new ArrayList<>();
    private double timeStep = PhysicsConstants.DEFAULT_DT;
    private boolean useStochasticGravity = false;
    private double entropyMixRate = PhysicsConstants.ENTROPY_MIX_RATE;
    private long stepCount = 0;
    
    public void addBody(MassPoint body) {
        bodies.add(body);
    }
    
    public void setTimeStep(double dt) { this.timeStep = dt; }
    public void setStochasticGravity(boolean enable) { this.useStochasticGravity = enable; }
    
    // Einzelner Simulationsschritt
    public void step() {
        // 1. Beschleunigungen zurücksetzen
        for (MassPoint b : bodies) {
            if (!b.isMovable()) continue;
            b.ax = b.ay = b.az = 0;
        }
        
        // 2. Gravitationskräfte berechnen (deterministisch oder stochastisch)
        for (int i = 0; i < bodies.size(); i++) {
            MassPoint bi = bodies.get(i);
            if (!bi.isMovable()) continue;
            for (int j = i+1; j < bodies.size(); j++) {
                MassPoint bj = bodies.get(j);
                if (!bj.isMovable()) continue;
                bi.applyGravityFrom(bj, timeStep);
                bj.applyGravityFrom(bi, timeStep);
            }
        }
        
        // 3. Optional: stochastische Komponente (zufällige Beschleunigung)
        if (useStochasticGravity) {
            for (MassPoint b : bodies) {
                if (!b.isMovable()) continue;
                double noise = 0.1 * Math.random();
                b.ax += noise * (Math.random() - 0.5);
                b.ay += noise * (Math.random() - 0.5);
                b.az += noise * (Math.random() - 0.5);
            }
        }
        
        // 4. Kinematik aktualisieren
        for (MassPoint b : bodies) {
            if (!b.isMovable()) continue;
            b.updateKinematics(timeStep);
        }
        
        // 5. Entropie-Angleichung (zufällige Paare)
        int n = bodies.size();
        for (int k = 0; k < n * entropyMixRate; k++) {
            int i = (int)(Math.random() * n);
            int j = (int)(Math.random() * n);
            if (i != j) {
                bodies.get(i).entropyExchangeWith(bodies.get(j), 0.5);
            }
        }
        
        // 6. Zufällige Brownsche Bewegung (Option)
        for (MassPoint b : bodies) {
            if (!b.isMovable()) continue;
            // kleine zufällige Bewegung, z.B. 1% der Geschwindigkeit
            b.randomWalk(0.01, timeStep);
        }
        
        stepCount++;
    }
    
    // Energiebilanz (Gesamtenergie = kinetisch + potentiell)
    public double getTotalKineticEnergy() {
        double sum = 0;
        for (MassPoint b : bodies) sum += b.getKineticEnergy();
        return sum;
    }
    
    public double getTotalPotentialEnergy() {
        double sum = 0;
        for (int i = 0; i < bodies.size(); i++) {
            MassPoint bi = bodies.get(i);
            for (int j = i+1; j < bodies.size(); j++) {
                MassPoint bj = bodies.get(j);
                double r = bi.getPosition().distanceTo(bj.getPosition());
                if (r < PhysicsConstants.MIN_DISTANCE) r = PhysicsConstants.MIN_DISTANCE;
                sum += -PhysicsConstants.G * bi.getMass() * bj.getMass() / r;
            }
        }
        return sum;
    }
    
    public double getTotalEnergy() {
        return getTotalKineticEnergy() + getTotalPotentialEnergy();
    }
    
    public List<MassPoint> getBodies() { return bodies; }
    public long getStepCount() { return stepCount; }
    
    // Beispiel: Konsolenausgabe im Matrixgame-Stil
    public void printStatus() {
        System.out.printf("Step %d | E_kin=%.3f | E_pot=%.3f | E_total=%.3f%n",
                stepCount, getTotalKineticEnergy(), getTotalPotentialEnergy(), getTotalEnergy());
    }
}
