package matrixgame.core;

import java.time.Instant;

public class SpaceTimeCoordinate {
    private double x, y, z;          // können negativ sein
    private double absX, absY, absZ;  // immer ≥ 0, Abstand zum Ursprung
    private final Instant creationTime;
    private Instant lastUpdate;
    
    public SpaceTimeCoordinate(double x, double y, double z) {
        this.x = x;
        this.y = y;
        this.z = z;
        updateAbsolutes();
        this.creationTime = Instant.now();
        this.lastUpdate = creationTime;
    }
    
    private void updateAbsolutes() {
        this.absX = Math.abs(x);
        this.absY = Math.abs(y);
        this.absZ = Math.abs(z);
    }
    
    public void set(double x, double y, double z) {
        this.x = x;
        this.y = y;
        this.z = z;
        updateAbsolutes();
        this.lastUpdate = Instant.now();
    }
    
    // Abstand zu einem anderen Punkt (immer positiv)
    public double distanceTo(SpaceTimeCoordinate other) {
        double dx = this.x - other.x;
        double dy = this.y - other.y;
        double dz = this.z - other.z;
        return Math.sqrt(dx*dx + dy*dy + dz*dz);
    }
    
    // Pythagoras: Strecke vom Ursprung
    public double distanceFromOrigin() {
