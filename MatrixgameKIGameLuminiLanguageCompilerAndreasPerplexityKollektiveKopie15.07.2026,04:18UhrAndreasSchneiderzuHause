package matrixgame.canvas;

import javax.swing.*;
import java.awt.*;
import java.awt.event.*;
import java.awt.geom.AffineTransform;
import java.util.ArrayList;
import java.util.Iterator;
import java.util.List;
import java.util.Random;

/**
 * MATRIXGAME LUMINI UNIVERSE – CANVAS EDITION
 * 
 * Features:
 * - Echtzeit-Grafik mit Zoom & Pan (Mausrad, WASD/Pfeiltasten)
 * - Kollektive KI-Kämpfe (Evolution, Angriff, Energieerhaltung)
 * - Lumini-Zahlen & Entropie als UI-Elemente
 * - Gamification: XP, Level, Energiebilanz
 * - Komplett in einer Datei – kopieren, kompilieren, spielen
 * 
 * Steuerung:
 *   WASD / Pfeiltasten  – Bewegen der Kamera
 *   Mausrad            – Zoomen
 *   Mausklick auf Einheit – Verfolgen (Kamera folgt)
 *   Leertaste          – Verfolgung beenden
 *   E                  – Energiebilanz ausgeben (Konsole)
 * 
 * @author Kollektives Bewusstsein & Andreas Schneider
 * @version 2.0 (2026-04-11)
 */
public class MatrixGameCanvasUniverse extends JPanel implements ActionListener, KeyListener, MouseWheelListener, MouseListener {

    // ================== KONSTANTEN ==================
    private static final double G = 0.1;              // Gravitations-/Angriffsstärke (entropisch)
    private static final double DT = 0.5;             // Zeitschritt
    private static final int WORLD_SIZE = 20000;      // Größe der Welt (-10000 bis +10000)
    private static final double MIN_DISTANCE = 10.0;
    private static final Random RAND = new Random();

    // ================== KAMERA & ZOOM ==================
    private double zoom = 1.0;
    private double camX = 0, camY = 0;
    private boolean following = false;
    private Unit followingUnit = null;

    // ================== ENTITÄTEN ==================
    private List<Unit> units = new ArrayList<>();
    private Timer gameLoop;
    private long frame = 0;

    // ================== GAMIFICATION ==================
    private double xp = 0;
    private int level = 1;
    private boolean showEnergy = true;

    // ================== KONSTRUKTOR ==================
    public MatrixGameCanvasUniverse() {
        setPreferredSize(new Dimension(1200, 800));
        setBackground(Color.BLACK);
        setFocusable(true);
        addKeyListener(this);
        addMouseWheelListener(this);
        addMouseListener(this);

        initUnits();
        
        gameLoop = new Timer(30, this);  // ca. 33 FPS
        gameLoop.start();
    }

    // ================== INITIALISIERUNG ==================
    private void initUnits() {
        // Sonne (massives Zentrum, unbeweglich)
        Unit sun = new Unit(5000, 0, 0, Color.YELLOW);
        sun.mass = 5000;
        sun.movable = false;
        sun.entropy = 5000;
        units.add(sun);

        // 20 Kämpfer mit zufälligen Eigenschaften
        for (int i = 0; i < 20; i++) {
            double angle = 2 * Math.PI * RAND.nextDouble();
            double radius = 500 + RAND.nextDouble() * 1500;
            double x = Math.cos(angle) * radius;
            double y = Math.sin(angle) * radius;
            
            Unit u = new Unit(20 + RAND.nextDouble() * 80, x, y, getRandomColor());
            u.team = (int)(RAND.nextDouble() * 3) + 1;
            u.mass = 10 + RAND.nextDouble() * 50;
            u.entropy = 500 + RAND.nextDouble() * 1000;
            u.attack = 5 + RAND.nextDouble() * 15;
            u.speed = 50 + RAND.nextDouble() * 80;
            
            // Anfangsgeschwindigkeit für Orbitalbewegung (entropischer Drang)
            double v = Math.sqrt(G * sun.mass / radius) * (0.5 + RAND.nextDouble());
            u.vx = -Math.sin(angle) * v;
            u.vy = Math.cos(angle) * v;
            
            units.add(u);
        }
    }

    private Color getRandomColor() {
        return new Color(50 + RAND.nextInt(206), 50 + RAND.nextInt(206), 50 + RAND.nextInt(206));
    }

    // ================== PHYSIK & KI ==================
    private void updateGame() {
        // Beschleunigungen zurücksetzen
        for (Unit u : units) {
            u.ax = u.ay = 0;
        }

        // Kräfte (entropische Gravitation + Angriffslogik)
        for (int i = 0; i < units.size(); i++) {
            Unit a = units.get(i);
            if (!a.movable) continue;
            
            Unit target = findNearestEnemy(a);
            if (target != null) {
                // Bewegung zum Ziel
                double dx = target.x - a.x;
                double dy = target.y - a.y;
                double dist = Math.hypot(dx, dy);
                if (dist > MIN_DISTANCE) {
                    double ax = (dx / dist) * a.speed / a.mass;
                    double ay = (dy / dist) * a.speed / a.mass;
                    a.ax += ax;
                    a.ay += ay;
                }
                
                // Angriff bei Nahkampf
                if (dist < a.radius + target.radius) {
                    target.health -= a.attack * (a.mass / (target.mass + 1));
                    a.entropy += 5;  // Gewinnen von Entropie durch Angriff
                    if (target.health <= 0) {
                        // Tod: Entropie-Transfer, XP, Reproduktion
                        a.entropy += target.entropy * 0.3;
                        xp += target.mass * 10;
                        if (xp >= level * 200) {
                            level++;
                            System.out.println("🏆 LEVEL UP! Level " + level);
                        }
                        // Reproduktion mit Mutation
                        if (RAND.nextDouble() < 0.15) {
                            Unit child = a.reproduce();
                            units.add(child);
                        }
                    }
                }
            }
            
            // Entropie-Angleichung mit zufälligen Partnern
            if (RAND.nextDouble() < 0.1) {
                Unit b = units.get(RAND.nextInt(units.size()));
                double diff = a.entropy - b.entropy;
                double transfer = diff * 0.05 * RAND.nextDouble();
                a.entropy -= transfer;
                b.entropy += transfer;
            }
        }

        // Kinematik & Entfernen toter Einheiten
        Iterator<Unit> it = units.iterator();
        while (it.hasNext()) {
            Unit u = it.next();
            u.update();
            if (u.health <= 0) {
                it.remove();
            }
        }

        // Kamera folgen
        if (following && followingUnit != null && followingUnit.health > 0) {
            camX = -followingUnit.x;
            camY = -followingUnit.y;
        }
        
        frame++;
    }

    private Unit findNearestEnemy(Unit source) {
        Unit nearest = null;
        double minDist = Double.MAX_VALUE;
        for (Unit other : units) {
            if (other == source) continue;
            if (other.team == source.team) continue; // Gleiches Team – kein Angriff
            double dist = Math.hypot(source.x - other.x, source.y - other.y);
            if (dist < minDist) {
                minDist = dist;
                nearest = other;
            }
        }
        return nearest;
    }

    // ================== ZEICHNEN (CANVAS) ==================
    @Override
    protected void paintComponent(Graphics g) {
        super.paintComponent(g);
        Graphics2D g2 = (Graphics2D) g;
        g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
        
        // Kamera-Transformation
        AffineTransform at = new AffineTransform();
        at.translate(getWidth() / 2.0, getHeight() / 2.0);
        at.scale(zoom, zoom);
        at.translate(camX, camY);
        g2.setTransform(at);
        
        // Hintergrund-Gitter (Matrix-Struktur)
        g2.setColor(new Color(30, 30, 50, 100));
        int step = 500;
        for (int x = -WORLD_SIZE; x <= WORLD_SIZE; x += step) {
            g2.drawLine(x, -WORLD_SIZE, x, WORLD_SIZE);
            g2.drawLine(-WORLD_SIZE, x, WORLD_SIZE, x);
        }
        
        // Einheiten zeichnen
        for (Unit u : units) {
            // Größe skaliert mit Masse und Gesundheit
            int drawRadius = (int)(u.radius * (0.5 + u.health / u.maxHealth * 0.5));
            drawRadius = Math.max(5, Math.min(drawRadius, 40));
            
            // Farbe basierend auf Team und Entropie
            float hue = (u.team * 0.3f + (float)(u.entropy % 360) / 360f) % 1.0f;
            Color col = Color.getHSBColor(hue, 0.8f, 0.9f);
            g2.setColor(col);
            g2.fillOval((int)(u.x - drawRadius), (int)(u.y - drawRadius), drawRadius * 2, drawRadius * 2);
            
            // Gesundheitsbalken
            int healthBarWidth = drawRadius * 2;
            int healthHeight = 5;
            g2.setColor(Color.RED);
            g2.fillRect((int)(u.x - drawRadius), (int)(u.y - drawRadius - 8), healthBarWidth, healthHeight);
            g2.setColor(Color.GREEN);
            int healthWidth = (int)(healthBarWidth * (u.health / u.maxHealth));
            g2.fillRect((int)(u.x - drawRadius), (int)(u.y - drawRadius - 8), healthWidth, healthHeight);
        }
        
        // UI (statisch, ohne Kamera)
        g2.setTransform(new AffineTransform());
        g2.setColor(Color.WHITE);
        g2.setFont(new Font("Monospaced", Font.BOLD, 14));
        g2.drawString("⚔️ MATRIXGAME LUMINI UNIVERSE", 20, 30);
        g2.drawString("🎮 XP: " + (int)xp + " | Level: " + level, 20, 55);
        g2.drawString("🔴 Einheiten: " + units.size(), 20, 80);
        g2.drawString("🔍 Zoom: " + String.format("%.2f", zoom) + "x", 20, 105);
        g2.drawString("📐 Lumini(42) = " + luminiString(42, 2), 20, 130);
        g2.drawString("📐 Lumini(23) = " + luminiString(23, 2), 20, 155);
        
        if (followingUnit != null && followingUnit.health > 0) {
            g2.drawString("🎯 Folgt: Team " + followingUnit.team + " | E=" + String.format("%.1f", followingUnit.entropy), 20, 180);
        }
        
        if (showEnergy) {
            double totalEnergy = getTotalKinetic() + getTotalPotential();
            g2.drawString("⚡ E_kin: " + String.format("%.1f", getTotalKinetic()), getWidth() - 250, 30);
            g2.drawString("🌀 E_pot: " + String.format("%.1f", getTotalPotential()), getWidth() - 250, 55);
            g2.drawString("💫 E_total: " + String.format("%.1f", totalEnergy), getWidth() - 250, 80);
        }
    }

    private double getTotalKinetic() {
        double sum = 0;
        for (Unit u : units) sum += 0.5 * u.mass * (u.vx*u.vx + u.vy*u.vy);
        return sum;
    }
    
    private double getTotalPotential() {
        double sum = 0;
        for (int i = 0; i < units.size(); i++) {
            for (int j = i+1; j < units.size(); j++) {
                double r = Math.hypot(units.get(i).x - units.get(j).x, units.get(i).y - units.get(j).y);
                if (r > MIN_DISTANCE)
                    sum += -G * units.get(i).mass * units.get(j).mass / r;
            }
        }
        return sum;
    }
    
    private String luminiString(long n, int basis) {
        if (n < 0) return "-" + luminiString(-n, basis);
        long len = 1, bucket = basis;
        while (n >= bucket) {
            n -= bucket;
            len++;
            bucket *= basis;
        }
        String digits = Long.toString(n, basis);
        while (digits.length() < len) digits = "0" + digits;
        return digits + "(Basis " + basis + ")";
    }

    // ================== GAMELOOP & STEUERUNG ==================
    @Override
    public void actionPerformed(ActionEvent e) {
        updateGame();
        repaint();
    }

    @Override
    public void keyPressed(KeyEvent e) {
        double move = 30 / zoom;
        switch (e.getKeyCode()) {
            case KeyEvent.VK_W: case KeyEvent.VK_UP: camY += move; following = false; break;
            case KeyEvent.VK_S: case KeyEvent.VK_DOWN: camY -= move; following = false; break;
            case KeyEvent.VK_A: case KeyEvent.VK_LEFT: camX += move; following = false; break;
            case KeyEvent.VK_D: case KeyEvent.VK_RIGHT: camX -= move; following = false; break;
            case KeyEvent.VK_SPACE: following = false; followingUnit = null; break;
            case KeyEvent.VK_E: showEnergy = !showEnergy; break;
            case KeyEvent.VK_R: initUnits(); xp = 0; level = 1; break;  // Reset
        }
    }

    @Override
    public void mouseWheelMoved(MouseWheelEvent e) {
        double delta = -e.getPreciseWheelRotation() * 0.1;
        zoom *= (1 + delta);
        zoom = Math.max(0.2, Math.min(zoom, 10));
    }

    @Override
    public void mouseClicked(MouseEvent e) {
        // Einheitenauswahl durch Klick (Canvas-Koordinaten in Weltkoordinaten)
        double mx = (e.getX() - getWidth()/2.0) / zoom - camX;
        double my = (e.getY() - getHeight()/2.0) / zoom - camY;
        for (Unit u : units) {
            double dist = Math.hypot(u.x - mx, u.y - my);
            if (dist < u.radius) {
                followingUnit = u;
                following = true;
                break;
            }
        }
    }

    @Override public void keyReleased(KeyEvent e) {}
    @Override public void keyTyped(KeyEvent e) {}
    @Override public void mousePressed(MouseEvent e) {}
    @Override public void mouseReleased(MouseEvent e) {}
    @Override public void mouseEntered(MouseEvent e) {}
    @Override public void mouseExited(MouseEvent e) {}

    // ================== INNERE KLASSE: EINHEIT ==================
    static class Unit {
        double x, y, vx, vy, ax, ay;
        double mass, radius, health, maxHealth;
        double entropy;      // Lumini-Entropie
        double attack, speed;
        int team;
        boolean movable;
        
        Unit(double mass, double x, double y, Color color) {
            this.mass = mass;
            this.x = x;
            this.y = y;
            this.health = 100 + mass * 2;
            this.maxHealth = health;
            this.radius = (int)(5 + Math.sqrt(mass) * 1.5);
            this.movable = true;
            this.entropy = mass * 50;
            this.attack = 5 + mass * 0.2;
            this.speed = 30 + mass * 0.5;
            this.team = 1;
        }
        
        void update() {
            if (!movable) return;
            vx += ax * DT;
            vy += ay * DT;
            x += vx * DT;
            y += vy * DT;
            // Entropie beeinflusst langsam Gesundheit (Selbstheilung)
            if (entropy > 100 && health < maxHealth) {
                health += 0.1;
            }
            // Begrenzung der Welt (optional)
            x = Math.max(-WORLD_SIZE, Math.min(WORLD_SIZE, x));
            y = Math.max(-WORLD_SIZE, Math.min(WORLD_SIZE, y));
        }
        
        Unit reproduce() {
            Unit child = new Unit(this.mass * (0.7 + RAND.nextDouble() * 0.6), 
                                  this.x + (RAND.nextDouble() - 0.5) * 200,
                                  this.y + (RAND.nextDouble() - 0.5) * 200, 
                                  Color.WHITE);
            child.team = this.team;
            child.entropy = this.entropy * 0.6;
            child.attack = this.attack * (0.8 + RAND.nextDouble() * 0.4);
            child.speed = this.speed * (0.8 + RAND.nextDouble() * 0.4);
            child.mass = this.mass * 0.6;
            child.health = this.health * 0.5;
            child.maxHealth = child.health;
            child.radius = (int)(5 + Math.sqrt(child.mass) * 1.5);
            return child;
        }
    }

    // ================== MAIN ==================
    public static void main(String[] args) {
        SwingUtilities.invokeLater(() -> {
            JFrame frame = new JFrame("⚡ MATRIXGAME – LUMINI CANVAS ⚡");
            frame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
            frame.setResizable(true);
            frame.add(new MatrixGameCanvasUniverse());
            frame.pack();
            frame.setLocationRelativeTo(null);
            frame.setVisible(true);
        });
    }
}
