class Node {

    String id;
    String type;

    double weight = 1.0;
    int success = 0;
    int fail = 0;

    public Node(String id, String type) {
        this.id = id;
        this.type = type;
    }

    public double score(double match) {
        return match * weight;
    }

    public void success() {
        success++;
        weight += 0.1;
    }

    public void fail() {
        fail++;
        weight -= 0.05;
        if(weight < 0.1) weight = 0.1;
    }
}

🧠 2. NODE MANAGER

class NodeManager {

    List<Node> nodes = new ArrayList<>();

    public void addNode(Node n) {
        nodes.add(n);
    }

    public Node selectBest(double match) {

        Node best = null;
        double bestScore = 0;

        for(Node n : nodes) {
            double s = n.score(match);
            if(s > bestScore) {
                bestScore = s;
                best = n;
            }
        }
        return best;
    }
}

