    public void applyImpulseTowardsStar() {

        if (bodies.size() > 1) {

            MasseKugel planet = bodies.get(1); // Xylos I ist der zweite Körper in der Liste (Index 1)

            MasseKugel star = bodies.get(0); // Sonne1 (Index 0)


            planet.color = Color.CYAN; // Planet hervorheben


            double dx = star.x - planet.x;

            double dy = star.y - planet.y;

            double distance = Math.sqrt(dx * dx + dy * dy);


            if (distance > 0) {

                double normalX = dx / distance;

                double normalY = dy / distance;


                planet.vx += normalX * currentImpulseMagnitude;

                planet.vy += normalY * currentImpulseMagnitude;

                System.out.println("Impuls auf Xylos I: Zum Stern hin (Stärke: " + currentImpulseMagnitude + ")");

            }

        }

        repaint();

    }


    public void applyImpulseAwayFromStar() {

        if (bodies.size() > 1) {

            MasseKugel planet = bodies.get(1); // Xylos I

            MasseKugel star = bodies.get(0); // Sonne1


            planet.color = Color.CYAN; // Planet hervorheben


            double dx = planet.x - star.x; // Vektor vom Stern zum Planet

            double dy = planet.y - star.y;

            double distance = Math.sqrt(dx * dx + dy * dy);


            if (distance > 0) {

                double normalX = dx / distance;

                double normalY = dy / distance;


                planet.vx += normalX * currentImpulseMagnitude;

                planet.vy += normalY * currentImpulseMagnitude;

                System.out.println("Impuls auf Xylos I: Vom Stern weg (Stärke: " + currentImpulseMagnitude + ")");

            }

        }

        repaint();

    }


