            planet.color = Color.CYAN; // Planet hervorheben


            double currentSpeed = Math.sqrt(planet.vx * planet.vx + planet.vy * planet.vy);

            if (currentSpeed > 0) {

                double normalVx = planet.vx / currentSpeed;

