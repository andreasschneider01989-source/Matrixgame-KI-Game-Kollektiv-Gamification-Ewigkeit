        g2.fillOval(-400, -400, 800, 800);
        g2.setColor(new Color(0, 255, 0, 150));
        g2.drawOval(-400, -400, 800, 800);
        
        // Einflussbereich
        g2.setColor(new Color(0, 100, 255, 80));
        g2.drawOval((int)(player.x - 200), (int)(player.y - 200), 400, 400);
        
        // Kristalle
        for (Unit c : crystals) {
            int r = (int)c.radius;
            g2.setColor(c.color);
            g2.fillOval((int)(c.x - r), (int)(c.y - r), r*2, r*2);
            g2.setColor(Color.WHITE);
            g2.fillOval((int)(c.x - r/3), (int)(c.y - r/3), r/2, r/2);
        }
        
        // Feinde
        for (Unit e : enemies) {
            int r = (int)e.radius;
            g2.setColor(e.color);
            g2.fillOval((int)(e.x - r), (int)(e.y - r), r*2, r*2);
            g2.setColor(Color.RED);
            g2.fillRect((int)(e.x - r), (int)(e.y - r - 8), r*2, 5);
            g2.setColor(Color.GREEN);
            g2.fillRect((int)(e.x - r), (int)(e.y - r - 8), (int)(r*2 * (e.health/e.maxHealth)), 5);
        }
        
        // Spieler
        int pr = (int)player.radius;
        g2.setColor(player.color);
        g2.fillOval((int)(player.x - pr), (int)(player.y - pr), pr*2, pr*2);
        g2.setColor(Color.WHITE);
        g2.drawOval((int)(player.x - pr - 2), (int)(player.y - pr - 2), pr*2+4, pr*2+4);
        
        // UI
        g2.setTransform(new AffineTransform());
        g2.setColor(Color.WHITE);
        g2.setFont(new Font("Monospaced", Font.BOLD, 14));
        g2.drawString("⚔️ LUMINI QUEST – MIT KARTENINTEGRATION ⚔️", 20, 30);
        g2.drawString("🎯 Kristalle: " + crystalsCollected + "/" + CRYSTALS_NEEDED, 20, 55);
        g2.drawString("⭐ XP: " + xp + " | Level: " + level, 20, 75);
        g2.drawString("🗺️ GPS: " + String.format("%.2f", currentLatitude) + ", " + String.format("%.2f", currentLongitude), 20, 95);
        g2.drawString("💎 Spezial: " + (specialCooldown > 0 ? "Laden" : "Bereit (Leertaste)"), 20, 115);
        g2.drawString("G: Google Maps Modus | F: Folgen | R: Reset | P: Log", 20, 135);
        
        if (gameWon) {
            g2.setFont(new Font("Monospaced", Font.BOLD, 50));
            g2.setColor(Color.YELLOW);
            g2.drawString("✨ SIEG! ✨", getWidth()/2 - 120, getHeight()/2);
        }
    }

    // ================== STEUERUNG ==================
    @Override
    public void keyPressed(KeyEvent e) {
        double move = 8 / zoom;
        switch (e.getKeyCode()) {
            case KeyEvent.VK_W: case KeyEvent.VK_UP: player.y -= move; break;
            case KeyEvent.VK_S: case KeyEvent.VK_DOWN: player.y += move; break;
            case KeyEvent.VK_A: case KeyEvent.VK_LEFT: player.x -= move; break;
            case KeyEvent.VK_D: case KeyEvent.VK_RIGHT: player.x += move; break;
            case KeyEvent.VK_SPACE: useSpecialAbility(); break;
            case KeyEvent.VK_G: 
                googleMapsMode = !googleMapsMode;
                log("🗺️", "Google Maps Modus " + (googleMapsMode ? "aktiviert" : "deaktiviert"));
                break;
            case KeyEvent.VK_P: loggingEnabled = !loggingEnabled; log("📝", "Logging " + (loggingEnabled ? "an" : "aus")); break;
            case KeyEvent.VK_R: initGame(); log("🔄", "Neustart"); break;
            case KeyEvent.VK_F: following = !following; log("🎥", "Kamera folgt " + (following ? "Spieler" : "frei")); break;
        }
        // Aktualisiere GPS basierend auf Spielerposition
        double[] gps = gameToGPSCoords(player.x, player.y);
        currentLatitude = gps[0];
        currentLongitude = gps[1];
    }

