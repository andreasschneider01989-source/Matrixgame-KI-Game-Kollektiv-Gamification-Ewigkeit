    // ================== PHYSIK & KI ==================
    private void updateGame() {
        if (gameWon) return;
        
        step++;
        if (step % 30 == 0) {
            log("🔄", "--- Schritt " + step + " ---");
            if (googleMapsMode) updatePositionFromGPS();
        }
        
        // Feinde bewegen sich zum Spieler
        for (Unit e : enemies) {
            double dx = player.x - e.x;
            double dy = player.y - e.y;
            double dist = Math.hypot(dx, dy);
            if (dist > MIN_DISTANCE) {
                e.vx = (dx / dist) * e.speed / e.mass;
                e.vy = (dy / dist) * e.speed / e.mass;
            } else {
                e.vx = 0; e.vy = 0;
            }
            e.update();
            
            if (dist < e.radius + player.radius) {
                player.speed = Math.max(20, player.speed - 0.5);
                if (crystalsCollected > 0 && RAND.nextDouble() < 0.05) {
                    crystalsCollected--;
                    xp = Math.max(0, xp - 20);
                    logEvent("STEAL", e, "Kristall gestohlen! Verbleibend: " + crystalsCollected);
                }
            }
        }
        
        // Kristalle einsammeln
        Iterator<Unit> it = crystals.iterator();
        while (it.hasNext()) {
            Unit c = it.next();
            double dist = Math.hypot(player.x - c.x, player.y - c.y);
            if (dist < player.radius + c.radius) {
                crystalsCollected++;
                xp += 25;
                double[] gps = gameToGPSCoords(c.x, c.y);
                logEvent("COLLECT", player, "Kristall gesammelt an GPS (" + String.format("%.2f", gps[0]) + ", " + String.format("%.2f", gps[1]) + ") | Gesamt: " + crystalsCollected);
                it.remove();
                
                if (xp >= level * 100) {
                    level++;
                    log("🏆", "LEVEL UP! Level " + level + " | XP=" + xp);
                    player.speed += 10;
                }
                
                if (crystalsCollected >= CRYSTALS_NEEDED && level >= LEVEL_GOAL) {
                    gameWon = true;
                    log("🏆🏆🏆", "SPIEL GEWONNEN! " + crystalsCollected + " Kristalle, Level " + level);
                }
            }
        }
        
        // NEUTRAL-ZONE
        double zoneRadius = 400;
        boolean inZone = (Math.hypot(player.x, player.y) < zoneRadius);
        
        if (inZone) {
            if (!zoneControlled) {
                zoneControlled = true;
                zoneControlStart = System.currentTimeMillis();
                logEvent("ZONE", player, "NEUTRAL-ZONE betreten!");
            } else if (System.currentTimeMillis() - zoneControlStart > 10000) {
                xp += 10;
                zoneControlStart = System.currentTimeMillis();
                logEvent("ZONE", player, "+10 XP | XP=" + xp);
            }
        } else if (zoneControlled) {
            zoneControlled = false;
            logEvent("ZONE", player, "Zone verlassen");
        }
        
        if (specialCooldown > 0) specialCooldown--;
        if (following) { camX = -player.x; camY = -player.y; }
    }
    
    private void useSpecialAbility() {
        if (specialCooldown > 0) {
            log("⏳", "Spezial: Cooldown " + specialCooldown);
            return;
        }
        int crystalsInRange = 0;
        for (Unit c : crystals) {
            if (Math.hypot(player.x - c.x, player.y - c.y) < 200) crystalsInRange++;
        }
        if (crystalsInRange < 3) {
            log("⚠️", "Spezial benötigt 3 Kristalle im Umkreis (" + crystalsInRange + ")");
            return;
        }
        
        log("💥", "LUMINI-EXPLOSION!");
        for (Unit e : enemies) {
            double dx = e.x - player.x;
            double dy = e.y - player.y;
            double dist = Math.hypot(dx, dy);
            if (dist < 200) {
                double push = 300 / (dist + 10);
                e.x += (dx / dist) * push;
                e.y += (dy / dist) * push;
            }
        }
        specialCooldown = SPECIAL_COOLDOWN_MAX;
    }

