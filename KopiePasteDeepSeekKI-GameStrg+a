    // ================== INNERE KLASSE: EINHEIT ==================
    static class Unit {
        int id; String name; double x, y, vx, vy;
        double mass, radius, health, maxHealth, entropy, attack, speed;
        int team; boolean movable; Color color;
        
        Unit(int id, String name, double mass, double x, double y, Color color) {
            this.id = id; this.name = name; this.mass = mass; this.x = x; this.y = y;
            this.health = 100; this.maxHealth = 100; this.radius = 12;
            this.movable = true; this.entropy = mass * 20; this.attack = 5;
            this.speed = 50; this.team = 0; this.color = color;
        }
        
        void update() {
            if (!movable) return;
            x += vx * DT;
            y += vy * DT;
            x = Math.max(-WORLD_SIZE, Math.min(WORLD_SIZE, x));
            y = Math.max(-WORLD_SIZE, Math.min(WORLD_SIZE, y));
        }
