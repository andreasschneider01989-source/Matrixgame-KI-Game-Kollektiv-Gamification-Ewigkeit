    // ================== LUMINI-STRING ==================
    private String luminiString(long n, int basis) {
        if (n < 0) return "-" + luminiString(-n, basis);
        long len = 1, bucket = basis;
        while (n >= bucket) {
            n -= bucket;
            len++;
            bucket *= basis;
        }
        String digits = Long.toString(n, basis);
        while (digits.length() < len) digits = "0" + digits;
        return digits + "(Basis " + basis + ")";
    }

    // ================== KONSOLENPROTOKOLL ==================
    private void log(String emoji, String message) {
        if (!loggingEnabled) return;
        String timestamp = TIME_FORMATTER.format(LocalDateTime.now());
        System.out.println(timestamp + " " + emoji + " " + message);
    }

    private void logEvent(String eventType, Unit u, String details) {
        if (!loggingEnabled) return;
        String timestamp = TIME_FORMATTER.format(LocalDateTime.now());
        String luminiPos = luminiString((long)Math.abs(u.x), 2) + "," + luminiString((long)Math.abs(u.y), 2);
        System.out.println(timestamp + " 📍 [" + eventType + "] " + u.name + " | Pos=(" 
            + String.format("%.1f", u.x) + "," + String.format("%.1f", u.y) + ") | LuminiPos=" + luminiPos
            + " | " + details);
    }

    // ================== GPS-zu-Welt-Koordinaten ==================
    private void updatePositionFromGPS() {
        // Simuliere Bewegung basierend auf echten GPS-Koordinaten
        // In einer echten Implementierung würde man hier eine Google Maps API anbinden
        if (googleMapsMode) {
            // Simulierte Bewegung: Spieler folgt Maus oder Tastatur, aber GPS ändert sich
            // Hier könnte man OpenStreetMap-Daten laden
            log("🗺️", "Google Maps Modus aktiv – reale Position: " + String.format("%.4f", currentLatitude) + ", " + String.format("%.4f", currentLongitude));
        }
    }
    
    // Konvertiere GPS zu Spiel-Koordinaten
    private double[] gpsToGameCoords(double lat, double lon) {
        // Einfache Skalierung: 1 Grad ≈ 111 km → 111000 Meter
        // Skaliere auf WORLD_SIZE
        double scale = WORLD_SIZE / 360.0; // 8000 / 360 ≈ 22.22
        double x = (lon + 180) * scale - WORLD_SIZE/2;
        double y = (90 - lat) * scale - WORLD_SIZE/2;
        return new double[]{x, y};
    }
    
    private double[] gameToGPSCoords(double x, double y) {
        double scale = WORLD_SIZE / 360.0;
        double lon = (x + WORLD_SIZE/2) / scale - 180;
        double lat = 90 - (y + WORLD_SIZE/2) / scale;
        return new double[]{lat, lon};
    }

