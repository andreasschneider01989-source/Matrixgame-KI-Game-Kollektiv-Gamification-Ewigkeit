// 1. Auto-Save nach jeder richtigen Antwort
private void autoSaveProgress(double richtig, int level) {
    try {
        PrintWriter pw = new PrintWriter("lumini_progress_backup.txt");
        pw.println("timestamp:" + System.currentTimeMillis());
        pw.println("richtig:" + richtig);
        pw.println("level:" + level);
        pw.println("bestScore:" + Math.max(21.0, richtig));
        pw.close();
    } catch (Exception e) {
        // Silent fail - nicht kritisch
        System.err.println("Auto-save skipped: " + e.getMessage());
    }
}

// 2. Graceful Shutdown Handler
@Override
public void onDestroy() {
    // Wird aufgerufen wenn Fenster schließt
    autoSaveProgress(richtig, level);
    System.out.println("💾 Fortschritt gesichert: " + richtig + " Punkte");
    super.onDestroy();
}

// 3. Console Buffer Management
private void safePrint(String message) {
    // Verhindert Buffer-Overflow bei schnellen Outputs
    try {
        System.out.println(message);
        if (counter % 10 == 0) {
            System.out.flush(); // Regelmäßiges Flushen
        }
    } catch (Exception e) {
        // Fallback zu File-Logging
        logToFile(message);
    }
}

// 4. Exception-Handling im Haupt-Loop
public void run() {
    try {
        initializeGame();
        while (gameActive) {
            try {
                executeQuest();
                autoSaveProgress(richtig, level);
            } catch (Exception questError) {
                System.err.println("Quest-Fehler: " + questError.getMessage());
                continue; // Nächste Quest statt Crash
            }
        }
    } catch (Exception e) {
        System.err.println("Kritischer Fehler: " + e.getMessage());
        autoSaveProgress(richtig, level);
        showRecoveryOptions();
    } finally {
        cleanup();
    }
}
