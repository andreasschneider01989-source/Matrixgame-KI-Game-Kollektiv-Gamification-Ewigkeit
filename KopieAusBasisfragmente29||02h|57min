            println("✗ Nicht ganz. Richtig war: " + next);
            println("  Tipp: Alle sind Primzahlen!");
        }
        
        showStats();
    }
    
    // HILFSMETHODEN
    private String decimalToNewLumini(int value, int basis, int length) {
        // Konvertiert Dezimalwert zu Lumini-String mit fester Länge
        String result = "";
        int temp = value;
        
        for (int i = 0; i < length; i++) {
            result = (temp % basis) + result;
            temp /= basis;
        }
        
        return result;
    }
    
    private int calculateLuminiValue(int decimalValue, int basis, int length) {
        // N = basis^(length-2) + decimalValue
        return (int)Math.pow(basis, length - 2) + decimalValue;
    }
    
    private boolean isPrime(int n) {
        if (n < 2) return false;
        if (n == 2) return true;
        if (n % 2 == 0) return false;
        
        for (int i = 3; i * i <= n; i += 2) {
            if (n % i == 0) return false;
        }
        return true;
    }
    
    private void checkPrimeBonus(int value) {
        if (isPrime(value)) {
            println("🌟 PRIMZAHL-BONUS! +" + (value / 2) + " Lumini-Points");
            luminiPoints += value / 2;
        }
    }
    
    private void showStats() {
        println("\n╔════════════════════════════════╗");
        println("║  STATS:                        ║");
        println("║  Level: " + level);
        println("║  Richtig: " + richtig);
        println("║  Falsch: " + falsch);
        println("║  XP: " + xp);
        println("║  Lumini-Points: " + luminiPoints);
        println("╚════════════════════════════════╝\n");
        
        // Level-Up Check
        if (richtig >= 5 * level) {
            level++;
            println("🎉 LEVEL UP! Du bist jetzt Level " + level);
            println("   Schwierigkeit erhöht sich!");
        }
    }
