### **Erweiterte Definition**

```python
# LUMINI NUMBER SYSTEM v2.0
class LuminiNumber:
    """
    Grundprinzip: 0 ≠ 00 ≠ 000
    Jede Wiederholung trägt Information
    Keine Ziffer geht verloren
    """
    
    def __init__(self, digits: str, position_weight: float = 1.0):
        self.digits = digits  # "0", "00", "123", "001122"
        self.position_weight = position_weight
        self.information_content = self.calculate_info()
        self.prime_signature = self.extract_prime_patterns()
    
    def calculate_info(self) -> float:
        """
        Informationsgehalt = Länge × Positionsgewicht × Musterkomplexität
        """
        length_info = len(self.digits)
        pattern_complexity = self.count_unique_patterns()
        return length_info * self.position_weight * pattern_complexity
    
    def extract_prime_patterns(self) -> List[int]:
        """
        Extrahiere Primzahl-Muster aus der Ziffernfolge
        Kollektive Validierung durch Multi-LLM-Check
        """
        primes = []
        for i in range(len(self.digits)):
            for j in range(i+1, len(self.digits)+1):
                num = int(self.digits[i:j])
                if is_prime(num) and num not in primes:
                    primes.append(num)
        return primes
    
    def __ne__(self, other):
        """
        Lumini-Gleichheit: Nicht nur Wert, auch Struktur zählt
        """
        return (self.digits != other.digits or 
                abs(self.position_weight - other.position_weight) > 0.001)
