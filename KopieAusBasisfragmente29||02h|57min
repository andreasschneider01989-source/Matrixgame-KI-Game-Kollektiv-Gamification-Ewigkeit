	public int ggt(int n1, int n2) {
		n1 = Math.abs(n1);
		n2 = Math.abs(n2);
		while (n2 != 0) {
			if (n1 > n2)
				n1 -= n2;
			else
				n2 -= n1;
		}
		return n1;
	}

	public String bruchrechnen(int ze, int ne) {
		int zahl = 0;
		int teiler = ggt(ne, ze);
		ze /= teiler;
		ne /= teiler;
		if (ne == 0)
			return "0";
		if (ne == 1)
			return String.valueOf(ze);
		zahl = ze / ne;
		if (zahl != 0)
			return (zahl + " " + ze % ne + "/" + ne);
		return (ze + "/" + ne);
	}

