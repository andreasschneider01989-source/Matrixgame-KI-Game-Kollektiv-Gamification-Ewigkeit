public class AdaptivePointSystem {
    
    private enum Schwierigkeit {
        EINFACH(1.0),      // Normale Multiplikation
        MITTEL(2.0),       // Lumini Basis-Konvertierung
        SCHWER(3.5),       // Lumini Primzahl-Check
        EXPERT(5.0);       // Lumini Muster-Erkennung
        
        private final double multiplikator;
        Schwierigkeit(double mult) { this.multiplikator = mult; }
        public double getMultiplikator() { return multiplikator; }
    }
    
    public static int berechnePunkte(
        boolean korrekt, 
        Schwierigkeit level,
        int basisLevel,
        double zeitFaktor
    ) {
        int basisPunkte = 10;
        
        if (korrekt) {
            // Mehr Punkte für schwierigere Aufgaben
            double bonus = basisPunkte * level.getMultiplikator();
            
            // Zeit-Bonus (schnell = mehr Punkte)
            bonus *= zeitFaktor;
            
            // Level-Bonus (höhere Basis = mehr Punkte)
            bonus *= (1 + (basisLevel - 2) * 0.1);
            
            return (int) Math.round(bonus);
        } else {
            // Weniger Abzug bei schweren Aufgaben
            return -(int) Math.round(basisPunkte * 0.3 * level.getMultiplikator());
        }
    }
}
