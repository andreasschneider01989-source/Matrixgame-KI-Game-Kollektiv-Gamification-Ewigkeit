// Rechnet echtes mathematisches Modulo (Ergebnis immer positiv bei positivem Teiler)
private int trueMod(int a, int b) {
    return (a % b + b) % b;
}

// Überladene Hilfsmethode, falls x() eigentlich Ganzzahlen verarbeiten soll
private int xInt(int f1, int f2) {
    return (int) x(f1, f2); // Castet das Double sauber, falls es Ganzzahlen sind
}

