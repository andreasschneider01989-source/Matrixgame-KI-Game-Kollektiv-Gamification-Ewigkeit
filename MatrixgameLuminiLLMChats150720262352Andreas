Wenn du die Quest auf Code-Ebene implementieren willst, hier die Kernlogik:


```python

class KonsistenzDebugger:

def __init__(self):

self.axiome = {} # {Variable: Wert}

self.relationen = [] # [(A, Operator, B, Kontext)]

self.konflikte = []

def pruefe_zyklus(self, pfad):

"""Erkennt A>B>C>A Schleifen"""

produkt = 1

for A, op, B, kontext in pfad:

if op == '>':

produkt *= 1

elif op == '<':

produkt *= -1

elif op == '=':

produkt *= 0

if produkt == 1 and pfad[0][0] == pfad[-1][2]:

return "Zyklische Stabilität erkannt"

elif produkt == -1 and pfad[0][0] == pfad[-1][2]:

return "Paradoxon: Widerspruch im System"

return "Konsistent"

def kontext_trennung(self, variable):

"""Prüft ob Variable kontextabhängig ist"""

kontexte = set()

for A, op, B, K in self.relationen:

if A == variable or B == variable:

kontexte.add(K)

return len(kontexte) > 1 # True = multistabil

