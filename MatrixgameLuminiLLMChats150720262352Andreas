from typing import List, Dict, Tuple, Set
import networkx as nx
import matplotlib.pyplot as plt

class KonsistenzDebugger:
    def __init__(self):
        self.axiome: Dict[str, float] = {}  # {Variable: Wert}
        self.relationen: List[Tuple[str, str, str, str]] = []  # [(A, Operator, B, Kontext)]
        self.konflikte: List[Dict] = []
        self.graph = nx.DiGraph()

    def add_axiom(self, variable: str, wert: float, kontext: str = "global"):
        """Füge ein Axiom (unveränderliche Tatsache) hinzu."""
        self.axiome[variable] = wert
        self.graph.add_node(variable, typ="Axiom", kontext=kontext)

    def add_relation(self, A: str, operator: str, B: str, kontext: str = "global"):
        """Füge eine Relation hinzu (z. B. A > B)."""
        self.relationen.append((A, operator, B, kontext))
        self.graph.add_edge(A, B, label=f"{operator} ({kontext})")

    def pruefe_zyklus(self, pfad: List[Tuple[str, str, str, str]]) -> str:
        """Erkennt Zyklen wie A>B>C>A."""
        # Extrahiere die Variablen aus dem Pfad
        variablen = [A for A, _, _, _ in pfad] + [B for _, _, B, _ in pfad[-1:]]
        if len(set(variablen)) != len(variablen):
            return "Zyklus erkannt: Multistabiles System!"
        return "Konsistent"

    def kontext_trennung(self, variable: str) -> bool:
        """Prüft, ob eine Variable kontextabhängig ist."""
        kontexte = set()
        for A, op, B, K in self.relationen:
            if A == variable or B == variable:
                kontexte.add(K)
        return len(kontexte) > 1

    def finde_konflikte(self) -> List[Dict]:
        """Finde alle Zyklen und Widersprüche im System."""
        konflikte = []
        for i, (A, op1, B, K1) in enumerate(self.relationen):
            for j, (C, op2, D, K2) in enumerate(self.relationen):
                if B == C and A == D and op1 != op2:
                    konflikte.append({
                        "ID": f"#K{i}-{j}",
                        "Variablen": [A, B],
                        "Konflikt": f"{A} {op1} {B} (Kontext {K1}) vs. {A} {op2} {B} (Kontext {K2})",
                        "Typ": "Kontextabhängig" if K1 != K2 else "Paradoxon"
                    })
        return konflikte

    def visualisiere_graph(self):
        """Zeichnet den Relationen-Graphen."""
        pos = nx.spring_layout(self.graph)
        nx.draw(self.graph, pos, with_labels=True, node_color="lightblue", node_size=1000)
        edge_labels = nx.get_edge_attributes(self.graph, "label")
        nx.draw_networkx_edge_labels(self.graph, pos, edge_labels=edge_labels)
        plt.show()

