import java.util.Arrays;

/**
 * Matrixgame v1.9.6 - Core Engine Module
 * Focus: Kinematics, Entropy, and Probability-Annotation Layer (PAL)
 */
public class MatrixEngine {

    // Boltzmann-Konstante in J/K (definiert nach SI-Reform 2019)
    public static final double K_B = 1.380649e-23;

    public static void main(String[] args) {
        System.out.println("=== Matrixgame v1.9.6: System-Start ===");
        
        // 1. Test: Kinematik-Modul mit Vorzeichen-Überprüfung
        try {
            double distance = -147.0; // Meter (Verschiebung nach unten)
            double acceleration = -6.0; // m/s^2 (Beschleunigung nach unten)
            double time = calculateKinematicTime(distance, acceleration);
            
            System.out.printf("Kinematik-Berechnung:%n  Weg: %.2f m, Beschleunigung: %.2f m/s^2 -> Zeit t = %.4f s%n", 
                              distance, acceleration, time);
            printPalAnnotation("Kinematik-Formel", 99.999, "Klassische Mechanik (v << c)");
            
        } catch (ArithmeticException e) {
            System.err.println("Kinematik-Fehler: " + e.getMessage());
        }

        System.out.println("\n----------------------------------------\n");

        // 2. Test: Entropie-Berechnung (Zellteilung / Information)
        double[] probabilities = {0.5, 0.25, 0.25}; // Summe muss 1.0 ergeben
        try {
            double entropy = calculateShannonEntropy(probabilities);
            System.out.printf("Entropie-Berechnung (Informationsgehalt):%n  Wahrscheinlichkeiten: %s%n  S = %.4f Sh%n", 
                              Arrays.toString(probabilities), entropy);
            printPalAnnotation("Shannon-Entropie", 98.600, "Abgeschlossenes System, Sum(p_i) = 1.0");
        } catch (IllegalArgumentException e) {
            System.err.println("Entropie-Fehler: " + e.getMessage());
        }
    }

    /**
     * Berechnet die Zeit t = sqrt(2s / a) mit strikter Vorzeichen-Prüfung.
     * Verhindert komplexe Zahlen (NaN) in der klassischen Simulation.
     */
    public static double calculateKinematicTime(double s, double a) {
        if (a == 0.0) {
            throw new ArithmeticException("Division durch Null: Beschleunigung darf nicht 0 sein.");
        }
        
        double radicand = (2.0 * s) / a;
        
        if (radicand < 0.0) {
            throw new ArithmeticException(
                String.format("Ungültiger Bewegungszustand: Radikand (%s) ist negativ. Keine reelle Lösung.", radicand)
            );
        }
        
        return Math.sqrt(radicand);
    }

    /**
     * Berechnet die informationstheoretische Entropie: H = -Sum(p_i * log2(p_i))
     */
    public static double calculateShannonEntropy(double[] probabilities) {
        double sum = 0.0;
        for (double p : probabilities) {
            if (p < 0.0 || p > 1.0) {
                throw new IllegalArgumentException("Wahrscheinlichkeiten müssen im Intervall [0, 1] liegen.");
            }
            sum += p;
        }
        
        // Toleranzgrenze für Gleitkomma-Ungenauigkeiten bei der Summenprüfung
        if (Math.abs(sum - 1.0) > 1e-9) {
            throw new IllegalArgumentException("Die Summe der Wahrscheinlichkeiten muss exakt 1.0 sein.");
        }

        double entropy = 0.0;
        for (double p : probabilities) {
            if (p > 0.0) {
                entropy -= p * (Math.log(p) / Math.log(2.0)); // Logarithmus zur Basis 2
            }
        }
        return entropy;
    }

    /**
     * Gibt die PAL-Metadaten für maximale wissenschaftliche Integrität aus.
     */
    public static void printPalAnnotation(String konzept, double confidence, String bedingung) {
        System.out.printf("[PAL 1.0 Layer] %s:%n  P(Konfidenz) = %.3f%%%n  Bedingung = %s%n", 
                          konzept, confidence, bedingung);
    }
}

