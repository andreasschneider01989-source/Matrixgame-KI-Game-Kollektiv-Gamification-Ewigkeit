class GamificationEngine:
    def __init__(self):
        self.points = 0
        self.badges = set()
        self.quests = {
            "Formel-Architekt": {"target": 5, "reward": 15, "badge": "Formel-Meister"},
            "Fehler-Archäologe": {"target": 3, "reward": 20, "badge": "Debugger-Pro"},
            "System-Debugger": {"target": 1, "reward": 25, "badge": "Zyklus-Jäger"},
            "Lumini-Übersetzer": {"target": 1, "reward": 30, "badge": "Sprach-Brückenbauer"},
            "Guardian-Modus": {"target": 1, "reward": 50, "badge": "Wissens-Guardian"}
        }
        self.progress = {quest: 0 for quest in self.quests}

    def complete_task(self, task_type, details=""):
        """Vollende eine Aufgabe und erhalte Punkte/Badges."""
        if task_type in self.quests:
            self.progress[task_type] += 1
            if self.progress[task_type] >= self.quests[task_type]["target"]:
                self.points += self.quests[task_type]["reward"]
                self.badges.add(self.quests[task_type]["badge"])
                return f"✅ Quest '{task_type}' abgeschlossen! +{self.quests[task_type]['reward']} Punkte. Badge: {self.quests[task_type]['badge']} | Details: {details}"
        return f"➡️ Fortschritt: {self.progress[task_type]}/{self.quests[task_type]['target']}"

    def get_status(self):
        return {
            "Punkte": self.points,
            "Badges": list(self.badges),
            "Fortschritt": self.progress
        }

