class GamificationEngine:
    def __init__(self):
        self.points = 0
        self.badges = set()
        self.quests = {
            "Mathe-Meister": {"target": 20, "reward": 10, "badge": "Logik-Guru"},
            "Code-Künstler": {"target": 1, "reward": 15, "badge": "Java-Magier"},
            "Physik-Detektiv": {"target": 5, "reward": 20, "badge": "Newton 2.0"},
        }
        self.progress = {quest: 0 for quest in self.quests}

    def complete_task(self, task_type):
        """Vollende eine Aufgabe und erhalte Punkte/Badges."""
        if task_type in self.quests:
            self.progress[task_type] += 1
            if self.progress[task_type] >= self.quests[task_type]["target"]:
                self.points += self.quests[task_type]["reward"]
                self.badges.add(self.quests[task_type]["badge"])
                return f"Quest '{task_type}' abgeschlossen! +{self.quests[task_type]['reward']} Punkte, Badge: {self.quests[task_type]['badge']}"
        return "Fortschritt aktualisiert."

    def get_status(self):
        return {
            "Punkte": self.points,
            "Badges": list(self.badges),
            "Fortschritt": self.progress
        }

# Beispiel:
