import networkx as nx
import matplotlib.pyplot as plt
from matplotlib.animation import FuncAnimation
import numpy as np

class InfinityZoom:
    def __init__(self):
        self.graph = nx.DiGraph()
        self.current_zoom = "Meso"  # Nano, Mikro, Meso, Makro, Meta
        self.knowledge_nodes = []  # Liste der gelernten Konzepte

    def add_knowledge(self, concept, zoom_level):
        """Fügt ein neues Konzept als Knoten hinzu."""
        self.graph.add_node(concept, zoom=zoom_level)
        self.knowledge_nodes.append(concept)
        if len(self.knowledge_nodes) > 1:
            self.graph.add_edge(self.knowledge_nodes[-2], self.knowledge_nodes[-1])

    def zoom_in(self, concept):
        """Zoomt in ein spezifisches Konzept."""
        self.current_zoom = self._get_zoom_level(concept)
        self._visualize()

    def zoom_out(self):
        """Zoomt eine Ebene heraus."""
        zoom_levels = ["Nano", "Mikro", "Meso", "Makro", "Meta"]
        idx = zoom_levels.index(self.current_zoom)
        if idx > 0:
            self.current_zoom = zoom_levels[idx - 1]
        self._visualize()

    def _get_zoom_level(self, concept):
        """Bestimmt die Zoom-Ebene eines Konzepts."""
        if "Atom" in concept or "Code" in concept:
            return "Nano"
        elif "Zelle" in concept or "Algorithmus" in concept:
            return "Mikro"
        elif "Mensch" in concept or "Gesellschaft" in concept:
            return "Meso"
        elif "Planet" in concept or "Universum" in concept:
            return "Makro"
        else:
            return "Meta"

    def _visualize(self):
        """Visualisiert den aktuellen Wissensgraphen."""
        plt.figure(figsize=(10, 8))
        pos = nx.spring_layout(self.graph)
        node_colors = []
        for node in self.graph.nodes:
            if self.graph.nodes[node]["zoom"] == self.current_zoom:
                node_colors.append("red")  # Aktueller Fokus
            else:
                node_colors.append("lightblue")

        nx.draw(self.graph, pos, with_labels=True, node_color=node_colors, node_size=2000, font_size=10)
        plt.title(f"Matrixgame v2.1 – Infinity Zoom: {self.current_zoom}")
        plt.show()

# Beispiel:
