class KonsistenzDebugger:
    def __init__(self):
        self.axiome = {}
        self.relationen = []  # [(A, op, B, kontext, zoom_level)]
        self.konflikte = []

    def add_axiom(self, variable, wert, kontext, zoom_level="Meso"):
        self.axiome[variable] = {"wert": wert, "kontext": kontext, "zoom": zoom_level}

    def add_relation(self, A, op, B, kontext, zoom_level="Meso"):
        self.relationen.append((A, op, B, kontext, zoom_level))

    def check_physics(self, A, B, op, kontext):
        """Prüft physikalische Konsistenz (z. B. Zeit, Strecke, Beschleunigung)."""
        if op == "=" and A == "Zeit" and B == "Strecke / Geschwindigkeit":
            if kontext == "kinematisch":
                return True
            else:
                return False
        return True

    def find_conflicts(self):
        """Finde Widersprüche in den Relationen."""
        conflicts = []
        for rel in self.relationen:
            A, op, B, kontext, zoom = rel
            for axiom in self.axiome:
                if axiom in [A, B] and self.axiome[axiom]["kontext"] != kontext:
                    conflicts.append({
                        "A": A, "op": op, "B": B,
                        "Konflikt": f"Kontext {kontext} vs. {self.axiome[axiom]['kontext']}",
                        "Zoom": zoom
                    })
        return conflicts

# Beispiel:
debugger = KonsistenzDebugger()
debugger.add_axiom("Geschwindigkeit", 10, "kinematisch", "Meso")
debugger.add_relation("Strecke", "=", "Geschwindigkeit * Zeit", "kinematisch", "Meso")
debugger.add_relation("Zeit", "=", "Strecke / Geschwindigkeit", "kinematisch", "Meso")
print(debugger.find_conflicts())  # Keine Konflikte, da Kontext übereinstimmt



