import networkx as nx
import matplotlib.pyplot as plt
from sympy import symbols, Eq, solve

class ResonanzCompiler:
    def __init__(self):
        self.axiome = {}  # {Variable: {"wert": wert, "kontext": kontext, "zoom": zoom_level}}
        self.relationen = []  # [(A, op, B, kontext, zoom_level)]
        self.konflikte = []
        self.graph = nx.DiGraph()

    def add_axiom(self, variable, wert, kontext="global", zoom_level="Meso"):
        """Fügt ein Axiom hinzu (z. B. F = m * a)."""
        self.axiome[variable] = {"wert": wert, "kontext": kontext, "zoom": zoom_level}
        self.graph.add_node(variable, typ="Axiom", kontext=kontext, zoom=zoom_level)

    def add_relation(self, A, op, B, kontext="global", zoom_level="Meso"):
        """Fügt eine Relation hinzu (z. B. s = 0.5 * a * t²)."""
        self.relationen.append((A, op, B, kontext, zoom_level))
        self.graph.add_edge(A, B, label=f"{op} ({kontext})", zoom=zoom_level)

    def check_consistency(self, pfad):
        """Prüft, ob ein Pfad konsistent ist (z. B. A > B > C > A)."""
        # Extrahiere Variablen und Operatoren
        variablen = [A for A, _, _, _, _ in pfad] + [B for _, _, B, _, _ in pfad[-1:]]
        if len(set(variablen)) != len(variablen):
            return {"status": "Zyklus erkannt!", "typ": "Oszillator", "lösung": "Kontext-Trennung oder neue Variable einführen."}
        return {"status": "Konsistent", "typ": None}

    def solve_equation(self, equation_str, target_var):
        """Löst eine Gleichung symbolisch (z. B. 's = 0.5 * a * t**2' nach t)."""
        try:
            s, a, t = symbols('s a t')
            equation = Eq(eval(equation_str.replace("^", "**")), 0)
            solution = solve(equation, target_var)
            return {"solution": solution, "status": "Korrekt umgestellt!"}
        except:
            return {"solution": None, "status": "Fehler in der Gleichung!"}

    def visualize(self):
        """Visualisiert den Wissensgraphen mit Zoom-Ebenen."""
        pos = nx.spring_layout(self.graph)
        node_colors = []
        for node in self.graph.nodes:
            zoom = self.graph.nodes[node]["zoom"]
            if zoom == "Nano":
                node_colors.append("lightblue")
            elif zoom == "Mikro":
                node_colors.append("lightgreen")
            elif zoom == "Meso":
                node_colors.append("lightcoral")
            elif zoom == "Makro":
                node_colors.append("gold")
            else:
                node_colors.append("violet")

        nx.draw(self.graph, pos, with_labels=True, node_color=node_colors, node_size=2000, font_size=10)
        edge_labels = nx.get_edge_attributes(self.graph, "label")
        nx.draw_networkx_edge_labels(self.graph, pos, edge_labels=edge_labels)
        plt.title("Resonanz-Compiler: Wissensgraph")
        plt.show()

