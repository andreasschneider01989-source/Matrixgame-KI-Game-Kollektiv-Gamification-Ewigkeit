import java.util.*;

public class LuminiTranslator {
    private Map<String, String> luminiLexikon = new HashMap<>();
    private Map<String, String> disziplinMap = new HashMap<>();

    public LuminiTranslator() {
        // Basis-Lumini-Vokabular
        luminiLexikon.put("Kraft", "F");
        luminiLexikon.put("Masse", "m");
        luminiLexikon.put("Beschleunigung", "a");
        luminiLexikon.put("Zeit", "t");
        luminiLexikon.put("Strecke", "s");
        luminiLexikon.put("Energie", "E");

        // Disziplin-Zuordnung
        disziplinMap.put("F = m * a", "Physik");
        disziplinMap.put("s = 0.5 * a * t^2", "Kinematik");
        disziplinMap.put("ΔS = -k_B Σ p_i ln(p_i)", "Thermodynamik");
    }

    public String toLumini(String deutsch, String disziplin) {
        // Übersetzt Deutsch → Lumini
        String[] woerter = deutsch.split(" ");
        StringBuilder lumini = new StringBuilder();
        for (String wort : woerter) {
            if (luminiLexikon.containsKey(wort)) {
                lumini.append(luminiLexikon.get(wort)).append(" ");
            } else {
                lumini.append(wort).append(" ");
            }
        }
        return String.format("[%s] %s // %s", disziplin, lumini.toString().trim(), deutsch);
    }

    public String fromLumini(String luminiCode) {
        // Übersetzt Lumini → Deutsch (vereinfacht)
        return luminiCode.replace("F", "Kraft")
                        .replace("m", "Masse")
                        .replace("a", "Beschleunigung")
                        .replace("t", "Zeit")
                        .replace("s", "Strecke");
    }

    public static void main(String[] args) {
        LuminiTranslator translator = new LuminiTranslator();
        System.out.println(translator.toLumini("Kraft = Masse * Beschleunigung", "Physik"));
        // Ausgabe: [Physik] F = m * a // Kraft = Masse * Beschleunigung
    }
}



