public static String longToNewLumini(long n, int basis) {
    if (n < 0) return "-" + longToNewLumini(-n, basis);
    
    int len = 1;
    long countAtLen = basis;
    long offset = 0;

    // Finde die richtige Länge (Bucket)
    while (n >= offset + countAtLen) {
        offset += countAtLen;
        len++;
        countAtLen *= basis;
    }

    // Berechne den relativen Wert D im Bucket
    long d = n - offset;
    String s = Long.toString(d, basis);
    
    // Mit führenden Nullen auffüllen
    while (s.length() < len) {
        s = "0" + s;
    }
    return s;
}

