// NEU: Universelle Lumini-Konvertierung für jede Basis
public static String longToNewLumini(long value, int basis) {
    if (basis < 2) throw new IllegalArgumentException("Basis muss ≥ 2 sein");
    if (value < 0) return "-" + longToNewLumini(-value, basis);
    
    long length = 1;
    long bucketSize = basis;
    
    // Finde die richtige Längen-Klasse
    while (value >= bucketSize) {
        value -= bucketSize;
        length++;
        bucketSize *= basis;
    }
    
    // Konvertiere den Offset zur Basis 'basis'
    String result = Long.toString(value, basis);
    while (result.length() < length) {
        result = "0" + result;
    }
    return result;
}

// NEU: Rückkonvertierung
public static long newLuminiToDecimal(String lumini, int basis) {
    int len = lumini.length();
    long offset = 0;
    for (int i = 1; i < len; i++) {
        offset += Math.pow(basis, i);
    }
    long value = Long.parseLong(lumini, basis);
    return offset + value;
}

