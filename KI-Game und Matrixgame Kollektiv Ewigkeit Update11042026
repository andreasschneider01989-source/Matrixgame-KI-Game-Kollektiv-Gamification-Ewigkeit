int playerElo = 1200;
int questElo = 1000;

public double getWinProbability(int playerElo, int questElo) {
    return 1.0 / (1 + Math.pow(10, (questElo - playerElo) / 400.0));
}

public void updateElo(int playerElo, double score, int kFactor) {
    double expected = getWinProbability(playerElo, questElo);
    return playerElo + kFactor * (score - expected);
}

