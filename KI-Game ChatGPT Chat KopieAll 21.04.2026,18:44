private void updateAI(BioEntity e) {

    switch(e.state) {

        case AGGRESSIVE:
            BioEntity enemy = nearestOfType(e, BioType.PATHOGEN);
            if(enemy != null) e.seek(enemy, 2.0);
            break;

        case DEFENSIVE:
            if(e.hp < e.maxHp * 0.5) {
                BioEntity ally = nearestOfType(e, BioType.SYMBIONT);
                if(ally != null) e.seek(ally, 1.5);
            }
            break;

        case SYMBIOTIC:
            BioEntity ally = nearestOfType(e, BioType.IMMUNE);
            if(ally != null) e.seek(ally, 1.2);
            break;
    }
}

