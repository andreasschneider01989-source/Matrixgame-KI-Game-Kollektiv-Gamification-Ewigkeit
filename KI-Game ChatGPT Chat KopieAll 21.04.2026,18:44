private void applyPhysics(BioEntity e) {

    for(BioEntity other : bio) {
        if(e == other) continue;

        double dx = other.x - e.x;
        double dy = other.y - e.y;
        double dist = Math.hypot(dx, dy);

        if(dist > 0 && dist < 100) {
            double force = 0.01 / dist;

            e.vx += dx * force;
            e.vy += dy * force;
        }
    }
}

