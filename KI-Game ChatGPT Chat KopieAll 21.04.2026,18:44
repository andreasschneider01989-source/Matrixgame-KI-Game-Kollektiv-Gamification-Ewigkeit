public class AIEngine {

    public static void decide(BioEntity self, java.util.List<BioEntity> all) {

        BioEntity nearestEnemy = findNearest(self, all, BioType.PATHOGEN);
        BioEntity nearestAlly  = findNearest(self, all, BioType.SYMBIONT);

        // === PRIORITÄT 1: ÜBERLEBEN ===
        if(self.hp < self.maxHp * 0.4) {
            if(nearestAlly != null) {
                self.seek(nearestAlly, 1.5);
                self.state = AIState.DEFENSIVE;
                return;
            }
        }

        // === PRIORITÄT 2: ANGRIFF ===
        if(nearestEnemy != null && self.dist(nearestEnemy) < 100) {
            self.seek(nearestEnemy, 2.0);
            self.state = AIState.AGGRESSIVE;
            return;
        }

        // === PRIORITÄT 3: SYMBIOSE ===
        if(nearestAlly != null) {
            self.seek(nearestAlly, 1.2);
            self.state = AIState.SYMBIOTIC;
            return;
        }

        // === FALLBACK ===
        self.wander();
    }

    private static BioEntity findNearest(BioEntity self,
                                         java.util.List<BioEntity> list,
                                         BioType type) {

        BioEntity best = null;
        double min = Double.MAX_VALUE;

        for(BioEntity e : list) {
            if(e.type == type && e != self) {
                double d = self.dist(e);
                if(d < min) {
                    min = d;
                    best = e;
                }
            }
        }
        return best;
    }
}

