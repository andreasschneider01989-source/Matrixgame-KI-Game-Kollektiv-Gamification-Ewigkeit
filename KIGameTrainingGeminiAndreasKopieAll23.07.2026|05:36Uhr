import java.util.ArrayList;
import java.util.List;

public class MatrixgameTicTacToe {

    // Repräsentiert den diskreten Zustand s im Matrixgame
    public static class BoardState {
        private final int[][] board;
        private final int turn; // 1 oder -1

        public BoardState(int[][] board, int turn) {
            this.board = new int[3][3];
            for (int r = 0; r < 3; r++) {
                System.arraycopy(board[r], 0, this.board[r], 0, 3);
            }
            this.turn = turn;
        }

        public List<int[]> getValidActions() {
            List<int[]> actions = new ArrayList<>();
            for (int r = 0; r < 3; r++) {
                for (int c = 0; c < 3; c++) {
                    if (board[r][c] == 0) {
                        actions.add(new int[]{r, c});
                    }
                }
            }
            return actions;
        }

        public BoardState applyAction(int[] action) {
            int[][] newBoard = new int[3][3];
            for (int r = 0; r < 3; r++) {
                System.arraycopy(this.board[r], 0, newBoard[r], 0, 3);
            }
            newBoard[action[0]][action[1]] = this.turn;
            return new BoardState(newBoard, -this.turn);
        }

        public Integer checkWinner() {
            for (int i = 0; i < 3; i++) {
                if (Math.abs(board[i][0] + board[i][1] + board[i][2]) == 3) return board[i][0];
                if (Math.abs(board[0][i] + board[1][i] + board[2][i]) == 3) return board[0][i];
            }
            if (Math.abs(board[0][0] + board[1][1] + board[2][2]) == 3) return board[1][1];
            if (Math.abs(board[0][2] + board[1][1] + board[2][0]) == 3) return board[1][1];

            if (getValidActions().isEmpty()) return 0; // Unentschieden
            return null; // Spiel läuft noch
        }
    }

    // Rekursive Minimax-Entscheidungs-Engine
    public static class DecisionEngine {
        
        public int evaluate(BoardState state) {
            Integer winner = state.checkWinner();
            if (winner != null) return winner;

            if (state.turn == 1) {
                int bestValue = Integer.MIN_VALUE;
                for (int[] action : state.getValidActions()) {
                    BoardState nextState = state.applyAction(action);
                    int value = evaluate(nextState);
                    bestValue = Math.max(bestValue, value);
                }
                return bestValue;
            } else {
                int bestValue = Integer.MAX_VALUE;
                for (int[] action : state.getValidActions()) {
                    BoardState nextState = state.applyAction(action);
                    int value = evaluate(nextState);
                    bestValue = Math.min(bestValue, value);
                }
                return bestValue;
            }
        }
    }

    public static void main(String[] args) {
        int[][] initialBoard = {
            {1, 1, 0},
            {-1, -1, 0},
            {0, 0, 0}
        };
        
        BoardState state = new BoardState(initialBoard, 1);
        DecisionEngine engine = new DecisionEngine();
        
        System.out.println("Berechneter Minimax-Wert V(s) für Spieler 1: " + engine.evaluate(state));
    }
