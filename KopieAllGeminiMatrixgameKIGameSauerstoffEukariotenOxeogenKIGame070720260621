import math

class PhysicsParticle:
    def __init__(self, mass: float, x: float = 0.0, v: float = 0.0):
        if mass <= 0:
            raise ValueError("Masse muss strikt positiv sein.")
        self.m = mass
        self.x = x
        self.v = v

    def apply_force(self, force: float, dt: float):
        if dt <= 0:
            return
        # Axiom 2 & 5: Berechnung der Beschleunigung und Zustandsaktualisierung
        a = force / self.m
        self.v += a * dt
        self.x += self.v * dt + 0.5 * a * (dt ** 2)

    def get_kinetic_energy(self) -> float:
        return 0.5 * self.m * (self.v ** 2)

def calculate_gravitational_force(m1: float, m2: float, distance: float) -> float:
    G = 6.67430e-11  # m^3 kg^-1 s^-2
    if distance <= 0:
        raise ZeroDivisionError("Massenpunkte kollidieren oder Distanz ist negativ.")
    return G * (m1 * m2) / (distance ** 2)

