	public void zoomIn() {

		zoomFactor *= ZOOM_STEP;

		PAN_STEP = feinheit / zoomFactor;

		repaint();

	}


	public void zoomOut() {

		zoomFactor /= ZOOM_STEP;

		PAN_STEP = feinheit / zoomFactor;

		repaint();

	}


