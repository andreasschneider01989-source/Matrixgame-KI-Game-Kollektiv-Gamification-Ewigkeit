	public void EntrophieSpeed(double alpha) {

	    int n = bodies.size();

	    if (n < 2) return;


	    for (int i = 0; i < n; i++) {

	        MasseKugel body1 = bodies.get(i);


	        // Zufällige Auswahl eines zweiten Körpers für die Interaktion

	        int j = (int) (Math.random() * n);

	        while (i == j) { // Sicherstellen, dass nicht derselbe Körper gewählt wird

	            j = (int) (Math.random() * n);

	        }

	        MasseKugel body2 = bodies.get(j);


	        // Berechnung der mittleren Geschwindigkeit für die Angleichung

	        double avg_vx = (body1.vx + body2.vx) / 2;

	        double avg_vy = (body1.vy + body2.vy) / 2;

	        double avg_vz = (body1.vz + body2.vz) / 2;


	        // Entropie-basierte Geschwindigkeitsanpassung

	        // Die Geschwindigkeiten werden proportional zur Differenz zur mittleren Geschwindigkeit angepasst.

	        // Die Konstante alpha steuert die Stärke der Angleichung.

	        body1.vx += (avg_vx - body1.vx) * alpha;

	        body1.vy += (avg_vy - body1.vy) * alpha;

	        body1.vz += (avg_vz - body1.vz) * alpha;


	        body2.vx += (avg_vx - body2.vx) * alpha;

	        body2.vy += (avg_vy - body2.vy) * alpha;

	        body2.vz += (avg_vz - body2.vz) * alpha;

	    }

	}


