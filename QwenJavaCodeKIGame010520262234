package matrixgame.unitfight;

import java.util.*;

/**
 * Unit-Fight System – kompatibel mit Matrixgame Go Engine
 * Jede Go-Position kann als Unit im 3D-Raum dargestellt werden
 */
public class UnitFight {
    
    public static class Unit {
        public int team;           // 1=Schwarz, 2=Weiß
        public double posX, posY, posZ;
        public double leben, damage, speed, size;
        public String id;
        
        public boolean isAlive() { return leben > 0; }
        
        @Override
        public String toString() {
            return String.format("Unit[T%d@%.0f,%.0f,%.0f HP:%.0f ID:%s]", 
                               team, posX, posY, posZ, leben, id);
        }
    }
    
    /**
     * Simuliert einen Kampf-Tick zwischen Units
     * (kann mit deiner bestehenden getKreisGrav3-Logik kombiniert werden)
     */
    public static void simulateTick(List<Unit> units, int range, double damageFactor) {
        for(Unit attacker : units) {
            if(!attacker.isAlive()) continue;
            
            for(Unit defender : units) {
                if(!defender.isAlive() || attacker.team == defender.team) continue;
                
                double dist = Math.sqrt(
                    Math.pow(attacker.posX - defender.posX, 2) +
                    Math.pow(attacker.posY - defender.posY, 2) +
                    Math.pow(attacker.posZ - defender.posZ, 2)
                );
                
                if(dist <= range) {
                    double dealtDamage = attacker.damage * damageFactor * (1 - dist/range);
                    defender.leben -= dealtDamage;
                }
            }
        }
    }
}
