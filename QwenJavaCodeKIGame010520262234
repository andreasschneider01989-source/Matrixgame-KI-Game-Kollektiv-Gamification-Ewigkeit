        go.makeMove(1,2, 'b');  // C2
        go.makeMove(2,1, 'w');  // B3
        
        // 3. Lumini-Output
        System.out.println("=== LUMINI-STRING ===");
        System.out.println(go.toLuminiString());
        
        // 4. AlphaZero-Evaluation
        System.out.println("\n=== ALPHA-ZERO ESTIMATES ===");
        System.out.println("Policy (Top 3): " + 
            go.getPolicyDistribution().entrySet().stream()
              .sorted(Map.Entry.<String,Double>comparingByValue().reversed())
              .limit(3)
              .collect(Collectors.toList()));
        System.out.println("Value (Schwarz): " + go.getValueEstimate('b'));
        
        // 5. Transform zu Unit-Fight
        System.out.println("\n=== UNIT-FIGHT UNITS ===");
        List<UnitFight.Unit> units = go.toUnitFightUnits();
        units.forEach(System.out::println);
        
        // 6. Simuliere Kampf
        UnitFight.simulateTick(units, 1500, 0.1);
        System.out.println("\n=== AFTER COMBAT ===");
        units.forEach(System.out::println);
        
        // 7. Sync zurück zu Go-Board
        go.syncFromUnitFight(units);
        System.out.println("\n=== SYNCED BOARD ===");
        System.out.println(go.toLuminiString());
        
        // 8. Ergebnis
        System.out.println("\n=== GAME SUMMARY ===");
        System.out.println(go.getGameSummary());
