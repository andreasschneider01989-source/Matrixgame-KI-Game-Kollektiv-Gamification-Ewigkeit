                double mean = teamTotalHP.get(team) / hpValues.size();
                
                // Varianz
                double variance = 0.0;
                for (double hp : hpValues) {
                    variance += Math.pow(hp - mean, 2);
                }
                variance /= hpValues.size();
                
                // Standardabweichung
                double stdDev = Math.sqrt(variance);
                
                teamVariance.put(team, variance);
