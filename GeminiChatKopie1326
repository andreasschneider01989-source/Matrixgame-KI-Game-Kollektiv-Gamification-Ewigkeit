public class MassePunkt {
    public String id;
    public double m; // Masse in kg
    public double x, y, z; // Position in m
    public double vx, vy, vz; // Geschwindigkeit in m/s
    public double radius;

    public MassePunkt(String id, double m, double x, double y, double z, double vx, double vy, double vz) {
        this.id = id;
        this.m = m;
        this.x = x; this.y = y; this.z = z;
        this.vx = vx; this.vy = vy; this.vz = vz;
        this.radius = Math.pow((3.0 * m) / (4.0 * Math.PI * 5500), 1.0/3.0); // Dichte-Annahme
    }

    public void updateVelocity(double fx, double fy, double fz, double dt) {
        double ax = fx / m;
        double ay = fy / m;
        double az = fz / m;
        vx += ax * dt;
        vy += ay * dt;
        vz += az * dt;
    }

    public void updatePosition(double dt) {
        x += vx * dt;
        y += vy * dt;
        z += vz * dt;
    }
}

