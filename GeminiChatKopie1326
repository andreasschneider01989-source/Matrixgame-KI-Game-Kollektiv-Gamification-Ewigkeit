import java.util.*;

/**
 * MATRIXGAME EVOLUTION ENGINE - Version 3.0
 * Fokus: Selbst-Update, Fraktale Strukturen & IOO-Modell
 */
public class MatrixEvolutionEngine {

    // --- MATHEMATISCHE BASIS-BIBLIOTHEK & ZUFALL ---
    public static class MatrixMath {
        public static double getJavaRand() { return Math.random(); }
        
        // Der "Spezial-Rand" für extreme Entropie-Schwankungen
        public static double getSpezialRand() { 
            double r2 = Math.random();
            return (r2 == 0) ? 1.0 : Math.random() / r2; 
        }

        public static double calculateAbs(double input) { return Math.abs(input); }
        
        // Grundrechenarten als gekapselte Operationen für die KI-Steuerung
        public static double operate(double a, double b, String op) {
            return switch (op) {
                case "+" -> a + b;
                case "-" -> a - b;
                case "*" -> a * b;
                case "/" -> (b != 0) ? a / b : 0;
                default -> a;
            };
        }
    }

    // --- DAS FUNDAMENTALE IOO-MODELL (Input-Operation-Output) ---
    public static String IOOModell(String input, String operation) {
        // Lumini-String Transformation basierend auf Operation
        String output = "[O]" + operation + "(" + input + ")";
        // Simulation einer String-Manipulation (DNA-Mutation)
        if (operation.contains("MUTATE")) {
            output = output.replace("0", "1").substring(0, Math.min(output.length(), 16));
        }
        return output;
    }

    // --- FRAKTALE BASIS-KLASSE (Vererbung & Modularität) ---
    public abstract static class FractalEntity {
        public String id;
        public String luminiDNA;
        public double mass, posX, posY, velX, velY;
        public double hp, maxHp;
        public int team;
        
        // Modulare Sub-Objekte (Einheiten können andere Objekte tragen/enthalten)
        public List<FractalEntity> children = new ArrayList<>();
        
        public FractalEntity(String id, String dna, double m, double x, double y) {
            this.id = id;
            this.luminiDNA = dna;
            this.mass = m;
            this.posX = x; this.posY = y;
            this.maxHp = 100.0;
            this.hp = maxHp;
        }

        // Selbst-Update Mechanismus: Evolution in Echtzeit
        public void update(double deltaTime) {
            // Physikalisches Update
            this.posX += this.velX * deltaTime;
            this.posY += this.velY * deltaTime;
            
            // Logik-Evolution: Nutzt IOO-Modell zur Verhaltensänderung
            this.luminiDNA = IOOModell(this.luminiDNA, "EVOLVE_" + team);
            
            // Rekursives Update aller Kind-Elemente (Fraktalität)
            for (FractalEntity child : children) {
                child.update(deltaTime);
            }
        }
        
        public abstract void decide(MatrixEnvironment env);
    }

    // --- SPEZIALISIERTE EVOLUTIONEN ---

    // Beispiel für ein Zerg-Analogon (Entropen): Schnelle Mutation
    public static class EntropenSwarm extends FractalEntity {
        public EntropenSwarm(String id, double x, double y) {
            super(id, "101010", 10.0, x, y);
        }

        @Override
        public void decide(MatrixEnvironment env) {
            if (MatrixMath.getJavaRand() > 0.7) {
                this.velX = MatrixMath.getSpezialRand() - 0.5;
                this.velY = MatrixMath.getSpezialRand() - 0.5;
            }
        }
    }

    // Beispiel für ein Protoss-Analogon (Luminari): Zielorientierte Intelligenz
    public static class LuminariArchon extends FractalEntity {
        public LuminariArchon(String id, double x, double y) {
            super(id, "111000", 50.0, x, y);
        }

        @Override
        public void decide(MatrixEnvironment env) {
            // Zielorientierung: Suche das nächste Ziel mit niedrigster HP
            this.luminiDNA = IOOModell(this.luminiDNA, "TARGET_OPTIMIZE");
        }
    }

    // --- SIMULATIONS-UMGEBUNG ---
    public static class MatrixEnvironment {
        public List<FractalEntity> entities = new ArrayList<>();
        
        public void simulateStep() {
            for (FractalEntity e : entities) {
                e.decide(this);
                e.update(1.0); // 1 Tick
            }
        }
    }

    // --- DER KOMPILIERBARE TEST-LOOP ---
    public static void main(String[] args) {
        System.out.println(">>> MATRIXGAME EVOLUTION ENGINE GESTARTET <<<");
        MatrixEnvironment multiverse = new MatrixEnvironment();

        // Initialisierung von Einheiten und Helden
        multiverse.entities.add(new EntropenSwarm("Swarm_Unit_Alpha", 0, 0));
