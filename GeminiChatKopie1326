public class MatrixgameMultiverse {

    // --- ENUMS & BASIS-STRUKTUREN ---
    public enum Faction { SYNTHETIKER, LUMINARI, ENTROPEN }
    public enum UnitType { WORKER, FIGHTER, HERO, BUILDING }

    // --- DIE ALPHA ZERO GRID-UMGEBUNG ---
    public static class TacticalGrid {
        public final int width, height;
        public Node[][] board;

        public TacticalGrid(int w, int h) {
            this.width = w; this.height = h;
            this.board = new Node[w][h];
            for (int x = 0; x < w; x++) {
                for (int y = 0; y < h; y++) {
                    board[x][y] = new Node(x, y);
                }
            }
        }
    }

    public static class Node {
        public int x, y;
        public double resourceLumini = 0;
        public double resourceMaterie = 0;
        public Unit occupant = null;

        public Node(int x, int y) { this.x = x; this.y = y; }
    }

    // --- EINHEITEN & HELDEN ---
    public static class Unit {
        public String id;
        public Faction faction;
        public UnitType type;
        public int x, y;
        public double hp, maxHp;
        public double attackPower;
        public String luminiDna; // Die "Seele" oder der Code der Einheit

        public Unit(String id, Faction f, UnitType t, int x, int y, double hp, double atk, String dna) {
            this.id = id; this.faction = f; this.type = t;
            this.x = x; this.y = y; this.hp = hp; this.maxHp = hp;
            this.attackPower = atk; this.luminiDna = dna;
        }

        public String executeAction(TacticalGrid grid, AlphaZeroBrain brain) {
            // Alpha Zero entscheidet den nächsten optimalen Zug
            Action optimalAction = brain.determineBestMove(this, grid);
            
            // Ausführung
            if(optimalAction.type.equals("MOVE")) {
                grid.board[this.x][this.y].occupant = null;
                this.x = optimalAction.targetX;
                this.y = optimalAction.targetY;
                grid.board[this.x][this.y].occupant = this;
            } else if (optimalAction.type.equals("ATTACK")) {
                Unit target = grid.board[optimalAction.targetX][optimalAction.targetY].occupant;
                if(target != null) target.hp -= this.attackPower;
            }

            // Lumini-String Output für den globalen Log
            return formatLuminiOutput(optimalAction);
        }

        private String formatLuminiOutput(Action a) {
            String base = String.format("%s_%s_%d_%d", this.id, a.type, a.targetX, a.targetY);
            return base.replace("0", "-").replace("1", "|"); // Lumini-Translation
        }
    }

