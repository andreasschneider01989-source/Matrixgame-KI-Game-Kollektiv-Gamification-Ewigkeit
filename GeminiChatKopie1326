import javax.swing.*;
import java.awt.*;
import java.util.ArrayList;
import java.util.List;

public class MatrixgameEngine extends JPanel implements Runnable {
    private static final double G = 6.67430e-11; // Gravitationskonstante
    private static final double DT = 3600; // 1 Stunde pro Tick (Schöne Zeit)
    
    private List<MassePunkt> universum;
    private long frameCount = 0;
    
    // Schöne Raumzeit & Zoom Variablen
    private double zoomFactor = 1.0e-9; 
    private double offsetX = 400;
    private double offsetY = 400;

    public MatrixgameEngine() {
        universum = new ArrayList<>();
        // Initiiere das Sonnensystem (Beispielwerte)
        universum.add(new MassePunkt("Sonne", 1.989e30, 0, 0, 0, 0, 0, 0));
        universum.add(new MassePunkt("Erde", 5.972e24, 149.6e9, 0, 0, 0, 29780, 0));
        universum.add(new MassePunkt("Mars", 6.39e23, 227.9e9, 0, 0, 0, 24070, 0));
    }

    public void run() {
        while (true) {
            calculatePhysics();
            repaint(); // Trigger Canvas Update
            
            if(frameCount % 60 == 0) { // Log-Output drosseln
                double totalEnergy = calculateSystemEnergy();
                System.out.println(LuminiTranslator.generateLog(frameCount, totalEnergy, "Physics_Updated_1|0|1"));
            }
            
            frameCount++;
            try { Thread.sleep(16); } catch (Exception e) {} // ~60 FPS
        }
    }

    private void calculatePhysics() {
        int n = universum.size();
        double[] fx = new double[n];
        double[] fy = new double[n];
        double[] fz = new double[n];

        // 1. Kräfte berechnen (N-Body)
        for (int i = 0; i < n; i++) {
            for (int j = i + 1; j < n; j++) {
                MassePunkt p1 = universum.get(i);
                MassePunkt p2 = universum.get(j);
                
                double dx = p2.x - p1.x;
                double dy = p2.y - p1.y;
                double dz = p2.z - p1.z;
                double distSq = dx*dx + dy*dy + dz*dz;
                double dist = Math.sqrt(distSq);
                
                if (dist > 0) {
                    double f = (G * p1.m * p2.m) / distSq;
                    fx[i] += f * (dx / dist); fy[i] += f * (dy / dist); fz[i] += f * (dz / dist);
                    fx[j] -= f * (dx / dist); fy[j] -= f * (dy / dist); fz[j] -= f * (dz / dist);
                }
            }
        }

        // 2. Positionen & Geschwindigkeiten updaten
        for (int i = 0; i < n; i++) {
            universum.get(i).updateVelocity(fx[i], fy[i], fz[i], DT);
            universum.get(i).updatePosition(DT);
        }
    }

    private double calculateSystemEnergy() {
        double kin = 0;
        for(MassePunkt p : universum) {
            kin += 0.5 * p.m * (p.vx*p.vx + p.vy*p.vy + p.vz*p.vz);
        }
        return kin; // Vereinfachte System-Entropie/Energie Metrik
    }

    @Override
    protected void paintComponent(Graphics g) {
        super.paintComponent(g);
        Graphics2D g2d = (Graphics2D) g;
        g2d.setColor(Color.BLACK);
        g2d.fillRect(0, 0, getWidth(), getHeight());

        for (MassePunkt p : universum) {
            int screenX = (int) (p.x * zoomFactor + offsetX);
            int screenY = (int) (p.y * zoomFactor + offsetY);
            int screenRadius = Math.max(2, (int) (p.radius * zoomFactor * 1000)); // Sichtbarkeits-Boost
            
            g2d.setColor(p.id.equals("Sonne") ? Color.YELLOW : Color.CYAN);
            g2d.fillOval(screenX - screenRadius, screenY - screenRadius, screenRadius * 2, screenRadius * 2);
            g2d.setColor(Color.WHITE);
            g2d.drawString(p.id, screenX + 5, screenY - 5);
        }
        
        g2d.setColor(Color.GREEN);
        g2d.drawString("MATRIXGAME CORE 3.0 - Frame: " + frameCount, 10, 20);
    }

    public static void main(String[] args) {
        JFrame frame = new JFrame("Spiel der Ewigkeit - Kollektives KI-Game");
        MatrixgameEngine engine = new MatrixgameEngine();
        frame.add(engine);
        frame.setSize(800, 800);
        frame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        frame.setVisible(true);
        new Thread(engine).start();
    }
}

