	public void orbitalRecyclerBasis() {
		// --- Kessler-Syndrom & Orbital-Recycling ---
		// Simulation eines Planeten mit gefährlichem Weltraumschrott und einer Recycler-Drohne.

		double erdMasse = 500000;
		// Der Heimatplanet
		MasseKugel erde = new MasseKugel(0, 0, 0, 0, 0, 0, erdMasse, 20, Color.BLUE);
		bodies.add(erde);

		// Weltraumschrott (hohe Entropie, extrem kreuzende, chaotische Bahnen)
		int schrottAnzahl = 50;
		for (int i = 0; i < schrottAnzahl; i++) {
			double dist = 60.0 + (Math.random() * 150.0);
			double angle = Math.random() * 2 * Math.PI;
			double vKreis = Math.sqrt(G * erdMasse / dist);
			
			// Elliptische und gegenläufige Geschwindigkeiten (0.4 bis 1.4 facher Speed)
			double vx = -Math.sin(angle) * vKreis * (0.4 + Math.random());
			double vy = Math.cos(angle) * vKreis * (0.4 + Math.random());
			
			MasseKugel schrott = new MasseKugel(Math.cos(angle)*dist, Math.sin(angle)*dist, 0, vx, vy, 0, 0.5, 2, Color.LIGHT_GRAY);
			bodies.add(schrott);
		}

		// Autonome / Steuerbare Recycler-Drohne
		// Startet in einem sicheren, weiten und perfekten Orbit
		double distRecycler = 280.0;
		double vRecycler = Math.sqrt(G * erdMasse / distRecycler);
		MasseKugel recycler = new MasseKugel(distRecycler, 0, 0, 0, -vRecycler, 0, 8.0, 6, Color.GREEN);
		
		bodies.add(recycler);
	}

Modul B: Kinetische Kernfusion (Mikro-Skala / Kombischritt-Update)
Diese Methode gehört nicht in die Initialisierung, sondern muss in deine actionPerformed oder KombiSchritt() aufgenommen werden, damit sie während der Laufzeit bei jedem Tick geprüft wird.
Java
	public void kinetischeFusion() {
		// --- Simulation von kinetischer Kernverschmelzung (Exotherm) ---
		List<MasseKugel> toRemove = new ArrayList<>();
		List<MasseKugel> toAdd = new ArrayList<>();

		for (int i = 0; i < bodies.size(); i++) {
			MasseKugel b1 = bodies.get(i);
			if (toRemove.contains(b1)) continue;

			for (int j = i + 1; j < bodies.size(); j++) {
				MasseKugel b2 = bodies.get(j);
				if (toRemove.contains(b2)) continue;

				double dx = b2.x - b1.x;
				double dy = b2.y - b1.y;
				double dz = b2.z - b1.z;
				double dist = Math.sqrt(dx*dx + dy*dy + dz*dz);

				// Kollisionsprüfung
				if (dist < (b1.radius + b2.radius)) {
					// Relativgeschwindigkeit ermitteln
					double dvx = b2.vx - b1.vx;
					double dvy = b2.vy - b1.vy;
					double dvz = b2.vz - b1.vz;
					
					// Skalare Geschwindigkeit im Quadrat (als Repräsentant der kinetischen Aufprallenergie)
					double vRelSq = dvx*dvx + dvy*dvy + dvz*dvz;

					// Schwellenwert: Nur wenn sie schnell genug aufeinanderprallen, fusionieren sie
					if (vRelSq > 2.0) { // Wert anpassbar für das Game-Balancing
						
						double neueMasse = b1.mass + b2.mass;
						
						// Völlig inelastischer Stoß: Impulserhaltung (p = m*v)
						double neuVx = (b1.mass * b1.vx + b2.mass * b2.vx) / neueMasse;
						double neuVy = (b1.mass * b1.vy + b2.mass * b2.vy) / neueMasse;
						double neuVz = (b1.mass * b1.vz + b2.mass * b2.vz) / neueMasse;
						
						// Das neu fusionierte, schwerere Element (z.B. Eisen)
						MasseKugel fusioniert = new MasseKugel(
								(b1.x + b2.x) / 2, (b1.y + b2.y) / 2, (b1.z + b2.z) / 2, 
								neuVx, neuVy, neuVz, 
								neueMasse, Math.max(b1.radius, b2.radius) + 1, Color.ORANGE);
						
						toRemove.add(b1);
						toRemove.add(b2);
						toAdd.add(fusioniert);
					}
				}
			}
		}
		// Listen aktualisieren
		bodies.removeAll(toRemove);
		bodies.addAll(toAdd);
	}

